@{
    ViewData["Title"] = "ATC Commands";
    bool lightsCurrentlyOn = ViewBag.LightsOn is bool b && b;
}

<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold mb-4 border border-blue-200">
        <span class="material-symbols-rounded text-[14px]">terminal</span>
        ATC COMMAND INVOKER
    </div>
    <div class="flex items-center gap-4">
        <h1 class="text-3xl font-bold text-slate-800 dark:text-slate-200">Runway Operations Control</h1>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-bold border @(lightsCurrentlyOn ? "bg-green-100 text-green-700 border-green-300" : "bg-slate-100 text-slate-500 border-slate-300")">
            <span class="w-2 h-2 rounded-full @(lightsCurrentlyOn ? "bg-green-500 animate-pulse" : "bg-slate-400")"></span>
            LIGHTS @(lightsCurrentlyOn ? "ON" : "OFF")
        </span>
    </div>
    <p class="text-slate-500 mt-1">Control and sequence operations for runway lighting systems.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
    <section class="bg-white dark:bg-slate-900 dark:text-slate-200 rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 px-6 py-4 border-b border-slate-200 flex items-center gap-3">
            <span class="material-symbols-rounded text-blue-600">sports_esports</span>
            <h3 class="font-bold text-slate-800 dark:text-slate-200 tracking-wide uppercase">Control Panel (Invoker)</h3>
        </div>
        
        <div class="p-6">
            <p class="text-sm text-slate-500 mb-6">Click buttons to issue commands. The Invoker will execute and store them in history.</p>

            <form asp-controller="ATC" asp-action="RunwayLights" method="get" class="grid grid-cols-2 gap-4">
                <button type="submit" name="commandName" value="ToggleLights" class="py-6 bg-blue-50 text-blue-700 border border-blue-200 rounded-xl flex flex-col items-center justify-center hover:bg-blue-100 transition active:scale-95 shadow-sm group">
                    <span class="material-symbols-rounded mb-3 text-3xl group-hover:text-blue-600">lightbulb</span>
                    <span class="text-xs font-bold uppercase tracking-wider">TOGGLE LIGHTS</span>
                </button>
                <button type="submit" name="commandName" value="PrepareRunway" class="py-6 bg-amber-50 text-amber-700 border border-amber-200 rounded-xl flex flex-col items-center justify-center hover:bg-amber-100 transition active:scale-95 shadow-sm group">
                    <span class="material-symbols-rounded mb-3 text-3xl group-hover:text-amber-600">flight_land</span>
                    <span class="text-xs font-bold uppercase tracking-wider">PREPARE RUNWAY</span>
                </button>
                
                <button type="submit" name="commandName" value="Undo" class="col-span-2 py-4 bg-slate-50 dark:bg-slate-800 dark:text-slate-200 text-slate-700 border border-slate-200 rounded-xl flex items-center justify-center gap-2 hover:bg-slate-100 transition active:scale-[0.98] shadow-sm">
                    <span class="material-symbols-rounded text-xl">undo</span>
                    <span class="text-sm font-bold uppercase tracking-wider">UNDO LAST COMMAND</span>
                </button>

                <button type="submit" name="commandName" value="Emergency" class="col-span-2 mt-2 py-4 bg-red-600 text-white border border-red-700 rounded-xl flex items-center justify-center gap-2 hover:bg-red-700 transition active:scale-[0.98] shadow-lg animate-pulse">
                    <span class="material-symbols-rounded text-xl">warning</span>
                    <span class="text-sm font-black uppercase tracking-wider">INITIATE EMERGENCY PROTOCOL</span>
                </button>
            </form>
        </div>
    </section>

    <section class="bg-slate-900 border border-slate-800 rounded-2xl shadow-lg flex flex-col min-h-[400px] overflow-hidden">
        <div class="bg-slate-950 px-6 py-4 border-b border-white/10 flex justify-between items-center">
            <h3 class="text-xs font-bold text-amber-400 uppercase tracking-widest">HARDWARE RECEIVER LOGS</h3>
            <span class="material-symbols-rounded text-sm text-amber-400">memory</span>
        </div>
        <div class="p-6 flex-1 font-mono text-sm space-y-2 overflow-y-auto max-h-[400px] flex flex-col-reverse">
            @if (ViewBag.Logs != null && ViewBag.Logs.Count > 0)
            {
                var logs = (List<string>)ViewBag.Logs;
                for (int i = logs.Count - 1; i >= 0; i--)
                {
                    <div class="flex items-center gap-3 text-slate-300 p-2 border-b border-white/5">
                        <span class="text-slate-600 text-xs font-bold bg-white dark:bg-slate-900 dark:text-slate-200/5 px-2 py-0.5 rounded">[@i.ToString("D4")]</span>
                        <span>@logs[i]</span>
                    </div>
                }
            }
            else
            {
                <div class="text-slate-500 italic flex items-center justify-center h-full opacity-50">
                    No commands executed yet...
                </div>
            }
        </div>
    </section>
</div>
