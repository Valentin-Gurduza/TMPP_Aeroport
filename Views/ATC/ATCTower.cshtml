@model dynamic
@{
    ViewData["Title"] = "ATC Tower Control";
    Layout = "~/Views/Shared/_LayoutCorporate.cshtml";
    
    var flights = ViewBag.Flights as List<TMPP_Aeroport.Models.Flight>;
    var towerLogs = ViewBag.TowerLogs as List<string>;
    var aircraftsDict = ViewBag.AircraftsDict as Dictionary<string, TMPP_Aeroport.Domain.Mediator.Aircraft>;
    var pendingRequests = ViewBag.PendingRequests as List<TMPP_Aeroport.Services.SimulatedFlight>;
}

<div class="max-w-6xl mx-auto space-y-6 animate-fade-in-up">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight flex items-center">
                <span class="material-symbols-outlined mr-3 text-4xl text-blue-600">radar</span>
                ATC Tower Operations
            </h1>
            <p class="text-slate-500 mt-2 text-lg">Central Mediator for Air Traffic Control and Aircraft Communications</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Left Col: Pending Clearance Requests -->
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden flex flex-col">
                <div class="bg-slate-50 border-b border-slate-200 px-6 py-4 flex items-center justify-between">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center">
                        <span class="material-symbols-outlined mr-2 text-orange-500">warning</span>
                        Pending Clearances
                    </h2>
                    <span class="px-2 py-1 bg-orange-100 text-orange-700 font-bold rounded-full text-xs">
                        @(pendingRequests?.Count ?? 0)
                    </span>
                </div>
                
                <div class="p-6 space-y-4 max-h-[500px] overflow-y-auto">
                    @if (pendingRequests != null && pendingRequests.Any())
                    {
                        foreach(var req in pendingRequests)
                        {
                            <div class="p-4 rounded-xl border border-orange-200 bg-orange-50 relative">
                                <div class="font-bold text-slate-800 text-lg">@req.FlightNumber</div>
                                <div class="text-sm font-medium text-orange-600 mb-3">@req.Status</div>
                                
                                <form action="/ATC/ATCTower" method="post" class="flex space-x-2">
                                    <input type="hidden" name="commandFlight" value="@req.FlightNumber" />
                                    @if(req.Status.Contains("Takeoff"))
                                    {
                                        <button type="submit" name="commandType" value="ClearTakeoff" class="flex-1 py-2 bg-blue-600 text-white rounded-lg text-sm font-bold shadow-md hover:bg-blue-700 transition">
                                            Clear Takeoff
                                        </button>
                                    }
                                    else if(req.Status.Contains("Holding"))
                                    {
                                        <button type="submit" name="commandType" value="ClearLanding" class="flex-1 py-2 bg-green-600 text-white rounded-lg text-sm font-bold shadow-md hover:bg-green-700 transition">
                                            Clear Landing
                                        </button>
                                        <button type="submit" name="commandType" value="Divert" class="py-2 px-3 bg-slate-600 text-white rounded-lg text-sm font-bold shadow-md hover:bg-slate-700 transition" title="Divert to Nearest">
                                            <span class="material-symbols-outlined text-sm">alt_route</span>
                                        </button>
                                    }
                                </form>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-10">
                            <span class="material-symbols-outlined text-4xl text-slate-300 mb-3 block">check_circle</span>
                            <p class="text-slate-500 font-medium">No pending clearance requests.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Middle Col: Radio Comms -->
        <div class="lg:col-span-1">
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden h-full">
                <div class="bg-slate-50 border-b border-slate-200 px-6 py-4">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center">
                        <span class="material-symbols-outlined mr-2 text-blue-600">headset_mic</span>
                        Radio Communications
                    </h2>
                </div>
                
                <div class="p-6">
                    <form action="/ATC/ATCTower" method="post" class="space-y-6">
                        <div>
                            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Select Aircraft (Colleague)</label>
                            <select name="senderFlightNumber" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none font-medium text-slate-700" required>
                                <option value="">-- Choose Aircraft --</option>
                                @if (flights != null)
                                {
                                    foreach (var f in flights)
                                    {
                                        <option value="@f.FlightNumber">@f.FlightNumber (@f.Status)</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="space-y-3">
                            <button type="submit" name="actionType" value="Landing" class="w-full py-3 bg-slate-100 hover:bg-slate-200 text-slate-700 border border-slate-300 rounded-xl font-bold flex justify-center items-center transition">
                                <span class="material-symbols-outlined mr-2 text-lg">flight_land</span>
                                Request Landing Clearance
                            </button>
                            
                            <div class="relative flex items-center py-2">
                                <div class="flex-grow border-t border-slate-200"></div>
                                <span class="flex-shrink-0 mx-4 text-slate-400 text-xs font-semibold uppercase">Or Send Custom Msg</span>
                                <div class="flex-grow border-t border-slate-200"></div>
                            </div>
                            
                            <div>
                                <textarea name="message" rows="3" placeholder="Message content..." class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none font-medium text-slate-700"></textarea>
                            </div>
                            
                            <button type="submit" name="actionType" value="Message" class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white shadow-md rounded-xl font-bold flex justify-center items-center transition">
                                <span class="material-symbols-outlined mr-2 text-lg">send</span>
                                Transmit to Tower
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Col: Mediator Logs -->
        <div class="lg:col-span-1">
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden h-full flex flex-col">
                <div class="bg-slate-50 border-b border-slate-200 px-6 py-4">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center">
                        <span class="material-symbols-outlined mr-2 text-slate-600">terminal</span>
                        Tower Logs
                    </h2>
                </div>
                
                <div class="p-0 bg-slate-900 flex-grow h-[500px] overflow-y-auto font-mono text-sm">
                    @if (towerLogs != null && towerLogs.Any())
                    {
                        foreach (var log in towerLogs)
                        {
                            <div class="px-6 py-3 border-b border-slate-800 text-slate-300 hover:bg-slate-800 transition">
                                @if (log.Contains("[TOWER]"))
                                {
                                    <span class="text-blue-400 font-bold">@log</span>
                                }
                                else if (log.Contains("LANDING"))
                                {
                                    <span class="text-green-400">@log</span>
                                }
                                else
                                {
                                    @log
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-6 text-slate-500 italic">No communication logs yet.</div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>
