@model dynamic
@{
    ViewData["Title"] = "Pre-Flight Checks";
    Layout = "~/Views/Shared/_LayoutCorporate.cshtml";
    
    var flightLog = ViewBag.FlightLog as List<string>;
    var routineLogs = ViewBag.RoutineLogs as List<string>;
    var flights = ViewBag.Flights as List<TMPP_Aeroport.Models.Flight>;
}

<div class="max-w-5xl mx-auto space-y-6 animate-fade-in-up">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-800 dark:text-slate-200 tracking-tight flex items-center">
                <span class="material-symbols-rounded mr-3 text-4xl text-blue-600">checklist</span>
                Pre-Flight Checks
            </h1>
            <p class="text-slate-500 mt-2 text-lg">Automating Ground Operations and Dispatch</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        <!-- Facade Controller -->
        <div class="bg-white dark:bg-slate-900 dark:text-slate-200 border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
            <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 border-b border-slate-200 px-6 py-4">
                <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">Ground Operations Console</h2>
            </div>
            <div class="p-6">
                <form action="/GroundOps/PreFlightChecksExecute" method="post" data-turbo="false" class="space-y-5">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Select Flight</label>
                        <select name="flightNumber" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none font-medium text-slate-700 dark:text-slate-300 dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200" required>
                            <option value="">-- Choose Flight --</option>
                            @if (flights != null)
                            {
                                foreach (var f in flights)
                                {
                                    <option value="@f.FlightNumber">@f.FlightNumber – @f.Destination (@f.Status)</option>
                                }
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Assign Runway</label>
                        <select name="runway" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none font-medium text-slate-700 dark:text-slate-300 dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200" required>
                            <option value="08R">08R</option>
                            <option value="08L">08L</option>
                            <option value="26R">26R</option>
                            <option value="26L">26L</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Flight Type</label>
                        <select name="flightType" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none font-medium text-slate-700 dark:text-slate-300 dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200" required>
                            <option value="passenger">Passenger Flight</option>
                            <option value="cargo">Cargo Flight</option>
                        </select>
                    </div>

                    <button type="submit" class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-bold shadow-md transition flex justify-center items-center">
                        <span class="material-symbols-rounded mr-2">play_arrow</span>
                        Run Pre-Flight SOP
                    </button>
                </form>
            </div>
        </div>

        <!-- Output Logs -->
        <div class="space-y-6">
            <!-- Template Method Logs -->
            @if (routineLogs != null)
            {
                <div class="bg-white dark:bg-slate-900 dark:text-slate-200 border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
                    <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 border-b border-slate-200 px-6 py-4 flex items-center justify-between">
                        <h2 class="text-sm font-bold text-slate-800 dark:text-slate-200 uppercase tracking-wider text-green-600">SOP Checklist</h2>
                        <span class="material-symbols-rounded text-green-600">done_all</span>
                    </div>
                    <div class="p-6 bg-slate-900 font-mono text-sm text-slate-300 max-h-[250px] overflow-y-auto">
                        <ul class="space-y-2">
                            @foreach (var log in routineLogs)
                            {
                                <li class="flex items-start">
                                    <span class="text-green-500 mr-2">✔</span> @log
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }

            <!-- Facade Logs -->
            @if (flightLog != null)
            {
                <div class="bg-white dark:bg-slate-900 dark:text-slate-200 border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
                    <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 border-b border-slate-200 px-6 py-4 flex items-center justify-between">
                        <h2 class="text-sm font-bold text-slate-800 dark:text-slate-200 uppercase tracking-wider text-blue-600">Pre-Flight Diagnostics</h2>
                        <span class="material-symbols-rounded text-blue-600">precision_manufacturing</span>
                    </div>
                    <div class="p-6 bg-slate-900 font-mono text-sm text-slate-300 max-h-[250px] overflow-y-auto">
                        <ul class="space-y-2">
                            @foreach (var log in flightLog)
                            {
                                <li class="flex items-start">
                                    <span class="text-blue-400 mr-2">></span> @log
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
