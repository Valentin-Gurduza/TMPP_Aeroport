@using TMPP_Aeroport.Domain.Composite
@{
    ViewData["Title"] = "Cargo Manifest";
    var totalWeight = ViewBag.TotalWeight as double?;
    var mainCargo = ViewBag.MainCargo as LuggageContainer;
    var flights = ViewBag.Flights as List<TMPP_Aeroport.Models.Flight>;
}

@functions {
    void RenderTree(ILuggageItem item)
    {
        if (item is LuggageContainer container)
        {
            <details class="mb-2 ml-4">
                <summary class="cursor-pointer font-bold text-blue-800 dark:text-blue-300 bg-blue-50 dark:bg-blue-900/30 p-2 rounded flex items-center hover:bg-blue-100 dark:hover:bg-blue-800/50 transition outline-none">
                    <span class="material-symbols-rounded mr-2 text-sm">inventory_2</span>
                    @container.GetName() 
                    <span class="ml-auto text-xs bg-blue-200 dark:bg-blue-800 text-blue-800 dark:text-blue-200 px-2 py-1 rounded-full">@container.GetWeight() kg</span>
                </summary>
                <div class="mt-2 border-l-2 border-blue-200 dark:border-blue-800 pl-2">
                    @{
                        var childrenToDisplay = container.Children.Take(10).ToList();
                        foreach (var child in childrenToDisplay)
                        {
                            RenderTree(child);
                        }
                        if (container.Children.Count > 10)
                        {
                            <div class="ml-4 mb-1 text-slate-500 italic text-xs py-1">
                                ... and @(container.Children.Count - 10) more items
                            </div>
                        }
                    }
                </div>
            </details>
        }
        else
        {
            <div class="ml-4 mb-1 text-slate-700 dark:text-slate-300 bg-white dark:bg-slate-900 p-2 rounded flex items-center border border-slate-200 dark:border-slate-700 shadow-sm">
                <span class="material-symbols-rounded mr-2 text-slate-500 dark:text-slate-400 text-sm">
                    @(item.GetName().Contains("Backpack") ? "backpack" : "luggage")
                </span>
                <span class="font-mono text-sm font-bold mr-auto">@item.GetName()</span>
                <span class="text-xs font-bold text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 px-2 py-1 rounded">@item.GetWeight() kg</span>
            </div>
        }
    }
}

<div class="max-w-5xl mx-auto space-y-6 animate-fade-in-up">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-800 dark:text-slate-200 tracking-tight flex items-center">
                <span class="material-symbols-rounded mr-3 text-4xl text-blue-600">luggage</span>
                Cargo & Baggage Manifest
            </h1>
        </div>
        <div class="bg-blue-50 border border-blue-200 px-6 py-3 rounded-2xl flex flex-col items-end">
            <span class="text-xs font-bold text-blue-500 uppercase tracking-wide">Total Displayed Weight</span>
            <span class="text-3xl font-black text-blue-700">@totalWeight kg</span>
        </div>
    </div>

    <!-- Filter Form -->
    <div class="bg-white dark:bg-slate-900 dark:text-slate-200 border border-slate-200 rounded-2xl shadow-sm overflow-hidden mb-6">
        <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 border-b border-slate-200 px-6 py-4 flex items-center">
            <span class="material-symbols-rounded mr-2 text-slate-600">filter_alt</span>
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">Filter Cargo by Flight</h2>
        </div>
        <div class="p-6">
            <form action="/GroundOps/CargoManifest" method="get" class="flex items-end gap-4">
                <div class="flex-1">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Select Flight</label>
                    <select name="flightNumberFilter" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none font-bold text-slate-700 bg-white dark:bg-slate-900 dark:text-slate-200">
                        <option value="">All Flights (Airport Main Hub)</option>
                        @if(flights != null)
                        {
                            foreach(var f in flights)
                            {
                                <option value="@f.FlightNumber" selected="@(ViewBag.FlightNumberFilter == f.FlightNumber)">@f.FlightNumber - @f.Destination</option>
                            }
                        }
                    </select>
                </div>
                <button type="submit" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg shadow-sm transition">
                    Apply Filter
                </button>
            </form>
        </div>
    </div>

    <!-- Hierarchical Tree -->
    <div class="bg-white dark:bg-slate-900 dark:text-slate-200 border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 border-b border-slate-200 px-6 py-4 flex items-center">
            <span class="material-symbols-rounded mr-2 text-slate-600">account_tree</span>
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">Interactive Manifest Tree</h2>
        </div>
        
        <div class="p-6 bg-slate-50 dark:bg-slate-800 dark:text-slate-200/50">
            @if(mainCargo != null && mainCargo.Children.Count > 0)
            {
                <div class="bg-white dark:bg-slate-900 dark:text-slate-200 p-4 rounded-xl border border-slate-200 shadow-sm">
                    @{ RenderTree(mainCargo); }
                </div>
            }
            else
            {
                <div class="text-center py-8 text-slate-500 italic">No cargo found for the selected criteria.</div>
            }
        </div>
    </div>
</div>
