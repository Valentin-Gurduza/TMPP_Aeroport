@{
    ViewData["Title"] = "Baggage Handling System";
    Layout = "~/Views/Shared/_LayoutCorporate.cshtml";
    var stages = ViewBag.Stages as string[];
    var bags = ViewBag.Bags as List<TMPP_Aeroport.Models.BaggageItem>;
    var stageLabels = new Dictionary<string, string> {
        {"CheckedIn", "✅ Checked In"},
        {"OnConveyor", "🔄 On Conveyor"},
        {"XRayScreening", "🔬 X-Ray Screening"},
        {"Sorted", "📦 Sorted"},
        {"LoadedOnAircraft", "✈️ Loaded"}
    };
    var stageColors = new Dictionary<string, string> {
        {"CheckedIn", "border-slate-400 bg-slate-50"},
        {"OnConveyor", "border-blue-400 bg-blue-50"},
        {"XRayScreening", "border-orange-400 bg-orange-50"},
        {"Sorted", "border-green-400 bg-green-50"},
        {"LoadedOnAircraft", "border-emerald-500 bg-emerald-50"}
    };
    var headerColors = new Dictionary<string, string> {
        {"CheckedIn", "bg-slate-600"},
        {"OnConveyor", "bg-blue-600"},
        {"XRayScreening", "bg-orange-500"},
        {"Sorted", "bg-green-600"},
        {"LoadedOnAircraft", "bg-emerald-600"}
    };
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 dark:text-white/90 flex items-center">
                <span class="material-symbols-outlined mr-3 text-blue-600 text-3xl">conveyor_belt</span>
                Baggage Handling System
            </h1>
            <p class="text-slate-500 dark:text-gray-400 mt-1">Live baggage pipeline — State Pattern</p>
        </div>
        <div class="flex gap-3">
            <div class="flex items-center gap-2 text-xs text-slate-500 dark:text-gray-400 bg-white dark:bg-gray-900 border border-slate-200 dark:border-gray-700 rounded-xl px-3 py-2">
                <span class="material-symbols-outlined text-[16px] animate-spin" style="animation-duration:3s">sync</span>
                Refresh in <span id="refresh-countdown" class="font-bold text-slate-700 dark:text-gray-300 mx-1">10</span>s
            </div>
            <div class="bg-white dark:bg-gray-900 border border-slate-200 dark:border-gray-700 rounded-xl px-4 py-2 text-center">
                <div class="text-2xl font-bold text-slate-800 dark:text-white/90">@(bags?.Count ?? 0)</div>
                <div class="text-xs text-slate-500 dark:text-gray-400">Total Bags</div>
            </div>
            <div class="bg-white dark:bg-gray-900 border border-slate-200 dark:border-gray-700 rounded-xl px-4 py-2 text-center">
                <div class="text-2xl font-bold text-emerald-600 dark:text-emerald-400">@(bags?.Count(b => b.BaggageStage == "LoadedOnAircraft") ?? 0)</div>
                <div class="text-xs text-slate-500 dark:text-gray-400">Loaded</div>
            </div>
            <div class="bg-white dark:bg-gray-900 border border-slate-200 dark:border-gray-700 rounded-xl px-4 py-2 text-center">
                <div class="text-2xl font-bold text-red-500 dark:text-red-400">@(bags?.Count(b => b.SecurityStatus == "Flagged") ?? 0)</div>
                <div class="text-xs text-slate-500 dark:text-gray-400">Flagged</div>
            </div>
        </div>
    </div>

    <!-- Kanban Board -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4" style="min-height: 60vh;">
        @if (stages != null)
        {
            foreach (var stage in stages)
            {
                var stageBags = bags?.Where(b => b.BaggageStage == stage).ToList() ?? new List<TMPP_Aeroport.Models.BaggageItem>();
                var borderColor = stageColors.GetValueOrDefault(stage, "border-slate-300 bg-slate-50");
                var headerColor = headerColors.GetValueOrDefault(stage, "bg-slate-600");
                <div class="flex flex-col rounded-xl border-2 @borderColor overflow-hidden">
                    <div class="@headerColor text-white px-3 py-2 flex justify-between items-center">
                        <span class="text-xs font-bold">@stageLabels.GetValueOrDefault(stage, stage)</span>
                        <span class="bg-white/20 text-white text-xs font-bold rounded-full px-2 py-0.5">@stageBags.Count</span>
                    </div>
                    <div class="flex-1 p-2 space-y-2 overflow-y-auto max-h-[65vh]">
                        @foreach (var bag in stageBags)
                        {
                            var secColor = bag.SecurityStatus == "Flagged" ? "border-red-400 bg-red-50" :
                                          bag.SecurityStatus == "Cleared" ? "border-green-300 bg-green-50" :
                                          "border-slate-200 bg-white";
                            <div class="p-2 rounded-lg border @secColor shadow-sm">
                                <div class="font-bold text-slate-700 text-xs">@bag.TagCode</div>
                                <div class="text-[10px] text-slate-500 mt-0.5">@bag.Type · @bag.Weight kg</div>
                                <div class="text-[10px] font-semibold mt-1 @(bag.SecurityStatus == "Flagged" ? "text-red-600" : "text-slate-600")">
                                    @(bag.Flight?.FlightNumber ?? "N/A")
                                </div>
                                @if (bag.SecurityStatus == "Flagged")
                                {
                                    <span class="inline-block mt-1 text-[9px] bg-red-500 text-white rounded px-1">⚠ FLAGGED</span>
                                }
                            </div>
                        }
                        @if (!stageBags.Any())
                        {
                            <div class="text-center py-8 text-slate-300">
                                <span class="material-symbols-outlined text-3xl block mb-1">inbox</span>
                                <span class="text-xs">Empty</span>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
<script>
    // Auto-advance baggage stages via AJAX every 8 seconds
    async function advanceBaggageStages() {
        try {
            const resp = await fetch('/GroundOps/AdvanceBaggageStages', { method: 'POST' });
            if (resp.ok) {
                setTimeout(() => location.reload(), 500);
            }
        } catch(e) { console.error(e); }
    }

    // Auto-refresh every 10 seconds with countdown indicator
    let countdown = 10;
    const countdownEl = document.getElementById('refresh-countdown');
    const interval = setInterval(() => {
        countdown--;
        if (countdownEl) countdownEl.textContent = countdown;
        if (countdown <= 0) {
            clearInterval(interval);
            location.reload();
        }
    }, 1000);
</script>
}
