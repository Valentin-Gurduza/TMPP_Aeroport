@model List<TMPP_Aeroport.Models.UserRolesViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="mb-8 flex items-center justify-between">
    <div>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-800 text-white text-xs font-bold mb-4 border border-slate-700">
            <span class="material-symbols-outlined text-[14px]">admin_panel_settings</span>
            ADMINISTRATION
        </div>
        <h1 class="text-3xl font-bold text-slate-800">User Management</h1>
        <p class="text-slate-500 mt-1">Manage system access and assign roles to users.</p>
    </div>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-slate-200">
                    <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">User Info</th>
                    <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider">Roles</th>
                    <th class="px-6 py-4 text-xs font-semibold text-slate-500 uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var user in Model)
                {
                    <tr class="hover:bg-slate-50 transition">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold">
                                    @(user.FirstName?.Substring(0, 1) ?? user.Email?.Substring(0, 1).ToUpper())
                                </div>
                                <div>
                                    <div class="font-bold text-slate-800">@user.FirstName @user.LastName</div>
                                    <div class="text-xs text-slate-500 font-mono">@user.Email</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-wrap gap-2">
                                @if (user.Roles.Any())
                                {
                                    foreach (var role in user.Roles)
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold @(role == "Admin" ? "bg-red-100 text-red-700 border border-red-200" : (role == "Passenger" ? "bg-slate-100 text-slate-600 border border-slate-200" : "bg-blue-100 text-blue-700 border border-blue-200"))">
                                            @role
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-xs text-slate-400 italic">No roles assigned</span>
                                }
                            </div>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <a asp-action="ManageRoles" asp-route-userId="@user.UserId" class="inline-flex items-center gap-1 px-3 py-1.5 bg-white border border-slate-300 rounded-lg text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:text-blue-600 transition shadow-sm">
                                <span class="material-symbols-outlined text-[18px]">manage_accounts</span>
                                Manage Roles
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
