@model List<TMPP_Aeroport.Controllers.ManageUserRolesViewModel>
@{
    ViewData["Title"] = "Manage Roles";
}

<div class="mb-8">
    <a asp-action="Index" class="inline-flex items-center gap-1 text-sm font-semibold text-slate-500 hover:text-blue-600 transition mb-4">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
        Back to Users
    </a>
    <h1 class="text-3xl font-bold text-slate-800">Manage Roles</h1>
    <p class="text-slate-500 mt-1">Assign or remove roles for user: <strong class="text-blue-600 font-mono">@ViewBag.UserName</strong></p>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden max-w-2xl">
    <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center gap-3">
        <span class="material-symbols-outlined text-slate-400">admin_panel_settings</span>
        <h3 class="font-bold text-slate-800 tracking-wide">Role Assignments</h3>
    </div>
    
    <div class="p-6">
        <form method="post">
            <input type="hidden" name="userId" value="@ViewBag.userId" />
            
            <div class="space-y-3 mb-8">
                @for (int i = 0; i < Model.Count; i++)
                {
                    <div class="flex items-center p-3 rounded-lg border border-slate-200 hover:bg-slate-50 transition">
                        <input type="hidden" asp-for="@Model[i].RoleId" />
                        <input type="hidden" asp-for="@Model[i].RoleName" />
                        
                        <div class="flex items-center h-5">
                            <input asp-for="@Model[i].Selected" class="w-5 h-5 border-slate-300 rounded text-blue-600 focus:ring-blue-500 cursor-pointer" />
                        </div>
                        <div class="ml-3 text-sm">
                            <label class="font-medium text-slate-700 cursor-pointer" asp-for="@Model[i].Selected">
                                @Model[i].RoleName
                            </label>
                        </div>
                    </div>
                }
                
                <div asp-validation-summary="All" class="text-red-500 text-sm mt-4"></div>
            </div>
            
            <div class="flex items-center gap-3">
                <button type="submit" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-bold transition shadow-md flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">save</span>
                    Save Changes
                </button>
                <a asp-action="Index" class="px-6 py-2.5 bg-white border border-slate-300 text-slate-700 rounded-xl font-bold hover:bg-slate-50 transition">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
