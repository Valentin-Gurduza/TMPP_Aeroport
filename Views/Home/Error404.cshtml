@{
    ViewData["Title"] = "Page Not Found";
    Layout = "_LayoutCorporate";
}

<div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="w-24 h-24 rounded-full bg-slate-100 flex items-center justify-center mb-6 border border-slate-200">
        <span class="material-symbols-rounded text-slate-400 text-5xl">flight_land</span>
    </div>

    <h1 class="text-4xl font-extrabold text-slate-900 mb-2 tracking-tight">404</h1>
    <h2 class="text-xl font-semibold text-slate-700 dark:text-slate-300 mb-3">Destination Not Found</h2>
    
    <p class="text-slate-500 text-base max-w-md mb-8 leading-relaxed">
        We couldn't find the page you're looking for. It might have been moved, deleted, or perhaps the URL is incorrect.
    </p>

    <div class="flex gap-4">
        <a asp-controller="Airport" asp-action="Index"
           class="px-6 py-2.5 bg-primary-600 text-white rounded-lg text-sm font-semibold shadow-sm hover:bg-primary-700 hover:shadow transition-all flex items-center">
            <span class="material-symbols-rounded text-[18px] mr-2">home</span>
            Return to Dashboard
        </a>
        <a href="javascript:history.back()"
           class="px-6 py-2.5 bg-white dark:bg-slate-900 dark:text-slate-200 border border-slate-300 text-slate-700 rounded-lg text-sm font-semibold hover:bg-slate-50 dark:hover:bg-slate-800 transition-all flex items-center">
            <span class="material-symbols-rounded text-[18px] mr-2">arrow_back</span>
            Go Back
        </a>
    </div>

    <div class="mt-12 p-4 bg-blue-50 border border-blue-100 rounded-xl max-w-sm text-left">
        <div class="flex items-start">
            <span class="material-symbols-rounded text-blue-500 mr-3 mt-0.5">info</span>
            <div>
                <p class="text-sm font-semibold text-blue-900 mb-1">Need help?</p>
                <p class="text-xs text-blue-700">If you believe this is an error, please contact the IT Service Desk or check the flight control logs.</p>
            </div>
        </div>
    </div>
</div>
