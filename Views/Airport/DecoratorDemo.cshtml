@{
    ViewData["Title"] = "Passenger Alert System";
}
<div class="px-0 pt-0 pb-lg">
    <h2 class="font-headline-lg text-white mb-xs">Passenger Alert System</h2>
    <p class="font-body-md text-on-surface-variant flex items-center">
        <span class="text-cyan-400 mr-2">●</span>Decorator Pattern — Dynamically wrap notification layers at runtime
    </p>
</div>

<div class="grid grid-cols-12 gap-gutter">
    <!-- LEFT: Config Panel -->
    <div class="col-span-5 glass-panel p-lg flex flex-col space-y-md">
        <div class="flex items-center space-x-2 mb-sm">
            <span class="material-symbols-outlined text-cyan-400">tune</span>
            <h3 class="font-label-caps text-on-surface-variant">CONFIGURATION PANEL</h3>
        </div>
        <div class="space-y-sm">
            <label class="font-label-caps text-[10px] text-cyan-400/70 tracking-widest block">PASSENGER NAME</label>
            <input class="w-full bg-surface-container-lowest border-b border-outline-variant text-white font-data-mono py-3 focus:outline-none focus:border-cyan-400"
                   type="text" value="@(ViewBag.PassengerName ?? "Maria Popescu")" />
        </div>
        <div class="space-y-sm">
            <label class="font-label-caps text-[10px] text-cyan-400/70 tracking-widest block">GATE CHANGE MESSAGE</label>
            <textarea class="w-full bg-surface-container-lowest border-b border-outline-variant text-white font-data-mono py-3 resize-none focus:outline-none focus:border-cyan-400" rows="3">Your flight has been moved to Gate E02. Please proceed immediately.</textarea>
        </div>
        <div class="flex items-center space-x-4 py-md">
            <div class="h-[1px] bg-outline-variant flex-grow"></div>
            <span class="font-label-caps text-[10px] text-outline tracking-[0.3em]">NOTIFICATION CHANNELS</span>
            <div class="h-[1px] bg-outline-variant flex-grow"></div>
        </div>
        <!-- Toggle Rows -->
        <div class="space-y-md">
            <div class="flex items-center justify-between p-md bg-white/5 rounded-lg opacity-50 border border-transparent">
                <div>
                    <span class="text-white font-bold text-body-sm block">🌐 Web App Notification</span>
                    <span class="text-[10px] font-mono text-slate-400">Base (Always Active)</span>
                </div>
                <div class="w-10 h-5 bg-slate-700 rounded-full relative">
                    <div class="absolute right-1 top-1 w-3 h-3 bg-slate-400 rounded-full"></div>
                </div>
            </div>
            <div class="flex items-center justify-between p-md bg-cyan-400/10 border border-cyan-400/30 rounded-lg">
                <div>
                    <span class="text-white font-bold text-body-sm block">📱 SMS Notification</span>
                    <span class="text-[10px] font-mono text-cyan-400">SMSNotifierDecorator</span>
                </div>
                <div class="w-12 h-6 bg-cyan-900 rounded-full relative p-1 cursor-pointer">
                    <div class="absolute right-1 top-1 bottom-1 w-4 h-4 bg-cyan-400 rounded-full shadow-[0_0_8px_rgba(0,212,255,0.6)]"></div>
                </div>
            </div>
            <div class="flex items-center justify-between p-md bg-white/5 border border-white/5 rounded-lg">
                <div>
                    <span class="text-white font-bold text-body-sm block">📧 Email Notification</span>
                    <span class="text-[10px] font-mono text-slate-400">EmailNotifierDecorator</span>
                </div>
                <div class="w-12 h-6 bg-slate-800 rounded-full relative p-1 cursor-pointer">
                    <div class="absolute left-1 top-1 bottom-1 w-4 h-4 bg-slate-600 rounded-full"></div>
                </div>
            </div>
        </div>
        <div class="pt-lg mt-auto">
            <a asp-controller="Airport" asp-action="DecoratorDemo" class="w-full bg-cyan-400 hover:bg-cyan-300 text-black font-label-caps py-4 tracking-[0.2em] flex items-center justify-center space-x-2 transition-all">
                <span class="material-symbols-outlined font-bold">send</span>
                <span>SEND NOTIFICATIONS</span>
            </a>
        </div>
    </div>

    <!-- RIGHT: Live Preview -->
    <div class="col-span-7 flex flex-col space-y-gutter">
        <div class="flex-grow glass-panel border-cyan-400/20 flex flex-col overflow-hidden">
            <div class="bg-slate-950/50 p-md border-b border-white/10 flex justify-between items-center">
                <div class="flex items-center space-x-3">
                    <div class="flex space-x-1">
                        <div class="w-2 h-2 rounded-full bg-red-500/50"></div>
                        <div class="w-2 h-2 rounded-full bg-yellow-500/50"></div>
                        <div class="w-2 h-2 rounded-full bg-green-500/50"></div>
                    </div>
                    <h3 class="font-label-caps text-cyan-400">DECORATOR CHAIN — EXECUTION TRACE</h3>
                </div>
            </div>
            <div class="p-lg flex-grow flex flex-col">
                <div class="flex-grow flex flex-col items-center justify-center space-y-4">
                    <!-- Nested decorator visualization -->
                    <div class="w-full max-w-lg border border-dashed border-amber-500/30 p-md rounded-lg relative opacity-40">
                        <span class="absolute -top-3 left-4 bg-surface-dim px-2 text-[10px] font-mono text-amber-500">EmailNotifierDecorator (Inactive)</span>
                        <div class="border-2 border-cyan-400 p-md rounded-lg relative glow-line">
                            <span class="absolute -top-3 left-4 bg-surface-dim px-2 text-[10px] font-mono text-cyan-400">SMSNotifierDecorator</span>
                            <div class="border border-slate-500 bg-slate-800/50 p-lg rounded text-center">
                                <p class="font-label-caps text-slate-400 text-[10px] mb-1">CORE COMPONENT</p>
                                <p class="text-white font-bold">WebAppNotifier</p>
                            </div>
                            <div class="mt-4 flex justify-center">
                                <div class="w-[1px] h-6 bg-cyan-400/50"></div>
                            </div>
                            <div class="text-center text-[10px] font-mono text-cyan-400 mt-1 uppercase tracking-tighter">
                                + Adding SMS Header &amp; Protocol
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Execution Log -->
                <div class="bg-black/40 p-md rounded border border-white/5 font-mono text-xs space-y-2 mt-lg">
                    @if (ViewBag.NotificationLog != null)
                    {
                        foreach (var line in (List<string>)ViewBag.NotificationLog)
                        {
                            <p class="text-green-400">@line ✓</p>
                        }
                    }
                    else
                    {
                        <p class="text-green-400">[14:22:01] [WEB] → Sent to Maria Popescu's account: Gate E02 ✓</p>
                        <p class="text-green-400">[14:22:01] [SMS] → Sent to mobile: BEEP! Gate E02 ✓</p>
                    }
                    <p class="text-cyan-400 animate-pulse"><span class="opacity-50">_</span> Waiting for dispatch...</p>
                </div>
            </div>
            <div class="p-md bg-slate-900/50 border-t border-white/5">
                <p class="text-[10px] italic text-slate-500 text-center">
                    "Each decorator calls base.SendNotification() first, then adds its own behavior"
                </p>
            </div>
        </div>
        <!-- Stats -->
        <div class="h-32 glass-panel p-md grid grid-cols-3 gap-md">
            <div class="flex flex-col justify-center items-center text-center border-r border-white/5">
                <span class="text-cyan-400 text-3xl font-bold">2</span>
                <span class="text-[9px] font-label-caps tracking-widest text-on-surface-variant">ACTIVE LAYERS</span>
            </div>
            <div class="flex flex-col justify-center items-center text-center border-r border-white/5">
                <span class="text-white text-3xl font-bold">412ms</span>
                <span class="text-[9px] font-label-caps tracking-widest text-on-surface-variant">TOTAL LATENCY</span>
            </div>
            <div class="flex flex-col justify-center items-center text-center">
                <span class="text-on-surface-variant text-3xl font-bold">1</span>
                <span class="text-[9px] font-label-caps tracking-widest text-on-surface-variant">DORMANT DECORATORS</span>
            </div>
        </div>
    </div>
</div>
