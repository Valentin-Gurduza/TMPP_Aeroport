@{
    ViewData["Title"] = "ATC Commands";
}

<header class="border-l-4 pl-lg mb-xl" style="border-color:#3cd7ff;">
    <h1 class="font-headline-lg text-display-xl text-on-surface">ATC Command Invoker</h1>
    <p class="font-body-sm text-on-surface-variant max-w-2xl">Command Pattern — Encapsulates requests as objects, allowing for queueing and Undo functionality.</p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-xl items-start">
    <section class="glass-card p-lg rounded-lg shadow-2xl space-y-lg border-t-2" style="border-top-color:#3cd7ff;">
        <h3 class="font-headline-md text-cyan-400">Control Panel (Invoker)</h3>
        <p class="text-xs text-slate-400 mb-4">Click buttons to issue commands. Invoker will execute and store them in history.</p>

        <form asp-action="CommandDemo" method="get" class="grid grid-cols-2 gap-md">
            <button type="submit" name="commandName" value="ToggleLights" class="py-4 bg-cyan-600/20 text-cyan-400 border border-cyan-500/50 rounded flex flex-col items-center hover:bg-cyan-500/30">
                <span class="material-symbols-outlined mb-2 text-2xl">lightbulb</span>
                <span class="font-label-caps">TOGGLE LIGHTS</span>
            </button>
            <button type="submit" name="commandName" value="PrepareRunway" class="py-4 bg-amber-600/20 text-amber-400 border border-amber-500/50 rounded flex flex-col items-center hover:bg-amber-500/30">
                <span class="material-symbols-outlined mb-2 text-2xl">flight_land</span>
                <span class="font-label-caps">PREPARE RUNWAY</span>
            </button>
            
            <button type="submit" name="commandName" value="Undo" class="col-span-2 mt-4 py-3 bg-red-900/40 text-red-400 border border-red-500/50 rounded flex items-center justify-center gap-2 hover:bg-red-800/60">
                <span class="material-symbols-outlined text-lg">undo</span>
                <span class="font-label-caps">UNDO LAST COMMAND</span>
            </button>
        </form>
    </section>

    <section class="bg-surface-container-low border border-white/10 rounded-lg shadow-2xl flex flex-col min-h-[300px]">
        <div class="bg-surface-container-high px-lg py-md border-b border-white/10 flex justify-between items-center">
            <h3 class="font-label-caps text-amber-400 tracking-widest">HARDWARE RECEIVER LOGS</h3>
            <span class="material-symbols-outlined text-sm text-amber-400">memory</span>
        </div>
        <div class="p-lg flex-1 font-data-mono text-sm space-y-2 overflow-y-auto max-h-[300px] flex flex-col-reverse">
            @if (ViewBag.Logs != null && ViewBag.Logs.Count > 0)
            {
                var logs = (List<string>)ViewBag.Logs;
                for (int i = logs.Count - 1; i >= 0; i--)
                {
                    <div class="flex items-center gap-2 text-on-surface">
                        <span class="text-slate-600 text-xs">[@i.ToString("D4")]</span>
                        <span>@logs[i]</span>
                    </div>
                }
            }
            else
            {
                <div class="text-slate-600 italic">No commands executed yet...</div>
            }
        </div>
    </section>
</div>
