@{
    ViewData["Title"] = "Digital Flight Boards";
}
<header class="mb-xl">
    <h1 class="font-headline-lg text-headline-lg text-cyan-400 uppercase tracking-tight">Digital Flight Boards</h1>
    <p class="font-body-md text-on-surface-variant mt-xs opacity-80">Bridge Pattern — Decouple abstraction (board type) from implementation (hardware)</p>
</header>

<!-- Top Control Bar -->
<section class="mb-xl">
    <div class="bg-[#111827]/85 backdrop-blur-[12px] p-lg rounded-xl border border-white/10 flex flex-col md:flex-row md:items-center justify-between gap-lg">
        <div class="flex items-center gap-sm">
            <span class="material-symbols-outlined text-cyan-400">devices</span>
            <span class="font-label-caps text-on-surface uppercase tracking-widest">SELECT DISPLAY HARDWARE:</span>
        </div>
        <div class="flex flex-wrap gap-md">
            <button class="flex items-center gap-sm px-6 py-3 bg-error/10 border-2 border-error text-error rounded-lg shadow-[0_0_15px_rgba(239,68,68,0.3)] font-headline-md text-body-md active:scale-95">
                <span class="material-symbols-outlined">tv</span> LED Matrix (Legacy)
            </button>
            <a asp-controller="Airport" asp-action="BridgeDemo" class="flex items-center gap-sm px-6 py-3 bg-white/5 border border-cyan-400/40 text-cyan-400/60 rounded-lg hover:bg-cyan-400/10 hover:text-cyan-400 transition-all">
                <span class="material-symbols-outlined">desktop_windows</span> Smart Web Display (Modern)
            </a>
        </div>
    </div>
</section>

<!-- Boards Grid -->
<div class="grid grid-cols-1 xl:grid-cols-2 gap-xl mb-xl">
    <!-- DEPARTURES -->
    <article class="flex flex-col gap-sm">
        <div>
            <h3 class="font-headline-md text-headline-md text-cyan-400">DEPARTURES BOARD</h3>
            <p class="font-data-mono text-xs text-outline tracking-wider mb-sm">DeparturesBoard + LEDRenderer</p>
        </div>
        <div class="bg-black p-lg rounded-lg border-4 border-surface-container-highest led-panel-bg shadow-2xl relative overflow-hidden h-[320px]">
            <div class="absolute top-2 left-2 w-2 h-2 rounded-full bg-slate-800 shadow-inner"></div>
            <div class="absolute top-2 right-2 w-2 h-2 rounded-full bg-slate-800 shadow-inner"></div>
            <div class="absolute bottom-2 left-2 w-2 h-2 rounded-full bg-slate-800 shadow-inner"></div>
            <div class="absolute bottom-2 right-2 w-2 h-2 rounded-full bg-slate-800 shadow-inner"></div>
            <div class="font-mono text-base space-y-3 pt-2 dot-matrix-glow leading-relaxed">
                <div class="text-center border-b border-error/20 pb-3 mb-3">---- PLECĂRI IMEDIAT (DEPARTURES) ----</div>
                @if (ViewBag.DepartureFlights != null)
                {
                    foreach (var flight in (List<string>)ViewBag.DepartureFlights)
                    {
                        <div class="flex items-center gap-4">
                            <span class="flex-1">&gt; @flight</span>
                            <span class="bg-error/20 px-2 py-0.5 rounded text-sm animate-pulse">TAKEOFF READY</span>
                        </div>
                    }
                }
                else
                {
                    <div class="flex items-center gap-4">
                        <span class="text-sm opacity-60">09:15</span>
                        <span class="flex-1">&gt; RO-302 - BUCHAREST</span>
                        <span class="bg-error/20 px-2 py-0.5 rounded text-sm animate-pulse">TAKEOFF READY</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="text-sm opacity-60">09:30</span>
                        <span class="flex-1">&gt; WZZ-15K - LONDON LTN</span>
                        <span class="bg-error/20 px-2 py-0.5 rounded text-sm animate-pulse">TAKEOFF READY</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="text-sm opacity-60">09:45</span>
                        <span class="flex-1">&gt; LH-1652 - MUNICH</span>
                        <span class="bg-error/20 px-2 py-0.5 rounded text-sm animate-pulse">TAKEOFF READY</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="text-sm opacity-60">10:00</span>
                        <span class="flex-1">&gt; BA-092 - LONDON LHR</span>
                        <span class="bg-error/20 px-2 py-0.5 rounded text-sm animate-pulse">TAKEOFF READY</span>
                    </div>
                }
                <div class="text-center border-t border-error/20 pt-3 mt-4">------------------------------------</div>
            </div>
        </div>
    </article>

    <!-- ARRIVALS -->
    <article class="flex flex-col gap-sm">
        <div>
            <h3 class="font-headline-md text-headline-md text-cyan-400">ARRIVALS BOARD</h3>
            <p class="font-data-mono text-xs text-outline tracking-wider mb-sm">ArrivalsBoard + LEDRenderer</p>
        </div>
        <div class="bg-black p-lg rounded-lg border-4 border-surface-container-highest led-panel-bg shadow-2xl relative overflow-hidden h-[320px]">
            <div class="absolute top-2 left-2 w-2 h-2 rounded-full bg-slate-800 shadow-inner"></div>
            <div class="absolute top-2 right-2 w-2 h-2 rounded-full bg-slate-800 shadow-inner"></div>
            <div class="absolute bottom-2 left-2 w-2 h-2 rounded-full bg-slate-800 shadow-inner"></div>
            <div class="absolute bottom-2 right-2 w-2 h-2 rounded-full bg-slate-800 shadow-inner"></div>
            <div class="font-mono text-base space-y-3 pt-2 dot-matrix-glow leading-relaxed">
                <div class="text-center border-b border-error/20 pb-3 mb-3">---- SOSIRI CURENTE (ARRIVALS) ----</div>
                @if (ViewBag.ArrivalFlights != null)
                {
                    foreach (var flight in (List<string>)ViewBag.ArrivalFlights)
                    {
                        <div class="flex items-center gap-4">
                            <span class="flex-1">&gt; @flight</span>
                            <span class="text-sm">BAGGAGE GATE 4</span>
                        </div>
                    }
                }
                else
                {
                    <div class="flex items-center gap-4"><span class="text-sm opacity-60">08:55</span><span class="flex-1">&gt; RO-302 - LANDED</span><span class="text-sm">BAGGAGE GATE 4</span></div>
                    <div class="flex items-center gap-4"><span class="text-sm opacity-60">09:05</span><span class="flex-1">&gt; WZZ-15K - LANDED</span><span class="text-sm">BAGGAGE GATE 4</span></div>
                    <div class="flex items-center gap-4"><span class="text-sm opacity-60">09:20</span><span class="flex-1">&gt; LH-1652 - LANDED</span><span class="text-sm">BAGGAGE GATE 4</span></div>
                    <div class="flex items-center gap-4 text-error/30"><span class="text-sm opacity-40">09:40</span><span class="flex-1">&gt; KL-1382 - ON APPROACH</span><span class="text-sm">--</span></div>
                }
                <div class="text-center border-t border-error/20 pt-3 mt-4">------------------------------------</div>
            </div>
        </div>
    </article>
</div>

<!-- Bridge Info -->
<section>
    <div class="bg-[#111827]/85 backdrop-blur-[12px] p-xl rounded-xl border border-cyan-400/20 shadow-[inset_0_0_20px_rgba(0,212,255,0.05)]">
        <div class="flex items-center gap-md mb-sm">
            <div class="w-12 h-12 bg-cyan-400/20 rounded-full flex items-center justify-center">
                <span class="material-symbols-outlined text-cyan-400">account_tree</span>
            </div>
            <h2 class="font-headline-md text-on-surface">Bridge Connection: DeparturesBoard ←[renderer]→ LEDRenderer</h2>
        </div>
        <p class="font-body-lg text-on-surface-variant leading-relaxed max-w-3xl">
            Switching to Smart Display changes only the <code class="bg-surface-container px-2 py-0.5 rounded text-cyan-400 font-data-mono text-sm">IDisplayRenderer</code>.
            Zero changes to <code class="bg-surface-container px-2 py-0.5 rounded text-cyan-400 font-data-mono text-sm">DeparturesBoard</code> or
            <code class="bg-surface-container px-2 py-0.5 rounded text-cyan-400 font-data-mono text-sm">ArrivalsBoard</code> classes.
        </p>
        <div class="flex gap-lg mt-lg pt-lg border-t border-white/10">
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                <span class="text-xs uppercase tracking-tighter text-outline font-bold">Abstraction Layer Ready</span>
            </div>
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-cyan-400"></span>
                <span class="text-xs uppercase tracking-tighter text-outline font-bold">Implementation Injected</span>
            </div>
        </div>
    </div>
</section>
