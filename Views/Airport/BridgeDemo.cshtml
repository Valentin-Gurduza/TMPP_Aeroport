@{
    ViewData["Title"] = "Digital Flight Boards";
}

<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-100 text-cyan-800 text-xs font-bold mb-4 border border-cyan-200">
        <span class="material-symbols-outlined text-[14px]">connected_tv</span>
        DIGITAL FLIGHT BOARDS
    </div>
    <h1 class="text-3xl font-bold text-slate-800">Digital Flight Boards</h1>
    <p class="text-slate-500 mt-1">Bridge Pattern — Decouple abstraction (board type) from implementation (hardware)</p>
</div>

<!-- Top Control Bar -->
<div class="mb-8 bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-6">
    <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-cyan-100 text-cyan-600 rounded-lg flex items-center justify-center">
            <span class="material-symbols-outlined">devices</span>
        </div>
        <div>
            <h3 class="font-bold text-slate-800 text-sm tracking-wide uppercase">Select Display Hardware</h3>
            <p class="text-xs text-slate-500">Change renderer without affecting the boards</p>
        </div>
    </div>
    <div class="flex flex-wrap gap-4">
        @{
            var isLed = ViewBag.Hardware == "led";
            var isWeb = ViewBag.Hardware == "web";
            
            var ledClass = isLed 
                ? "flex items-center gap-2 px-6 py-3 bg-red-600 border border-red-600 text-white rounded-xl shadow-md shadow-red-600/20 font-semibold text-sm" 
                : "flex items-center gap-2 px-6 py-3 bg-white border border-slate-300 text-slate-500 rounded-xl hover:bg-slate-50 hover:text-slate-700 transition shadow-sm font-semibold text-sm";
                
            var webClass = isWeb 
                ? "flex items-center gap-2 px-6 py-3 bg-cyan-600 border border-cyan-600 text-white rounded-xl shadow-md shadow-cyan-600/20 font-semibold text-sm" 
                : "flex items-center gap-2 px-6 py-3 bg-white border border-slate-300 text-slate-500 rounded-xl hover:bg-slate-50 hover:text-slate-700 transition shadow-sm font-semibold text-sm";
        }
        <a asp-controller="Airport" asp-action="BridgeDemo" asp-route-hardware="led" class="@ledClass">
            <span class="material-symbols-outlined text-[18px]">tv</span> LED Matrix (Legacy)
        </a>
        <a asp-controller="Airport" asp-action="BridgeDemo" asp-route-hardware="web" class="@webClass">
            <span class="material-symbols-outlined text-[18px]">desktop_windows</span> Smart Web Display (Modern)
        </a>
    </div>
</div>

<!-- Boards Grid -->
<div class="grid grid-cols-1 xl:grid-cols-2 gap-8 mb-8">
    <!-- DEPARTURES -->
    <div class="flex flex-col gap-3">
        <div>
            <h3 class="font-bold text-slate-800 uppercase tracking-wide">Departures Board</h3>
            <p class="font-mono text-xs text-slate-500 mb-2">DeparturesBoard + WebRenderer</p>
        </div>
        <div class="bg-slate-900 p-6 rounded-2xl border border-slate-700 shadow-xl relative overflow-hidden h-[320px]">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-cyan-500 to-transparent opacity-50"></div>
            <div class="font-mono text-sm space-y-3 leading-relaxed text-cyan-400">
                @if (ViewBag.DeparturesRender != null)
                {
                    @Html.Raw(ViewBag.DeparturesRender)
                }
            </div>
        </div>
    </div>

    <!-- ARRIVALS -->
    <div class="flex flex-col gap-3">
        <div>
            <h3 class="font-bold text-slate-800 uppercase tracking-wide">Arrivals Board</h3>
            <p class="font-mono text-xs text-slate-500 mb-2">ArrivalsBoard + WebRenderer</p>
        </div>
        <div class="bg-slate-900 p-6 rounded-2xl border border-slate-700 shadow-xl relative overflow-hidden h-[320px]">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-emerald-500 to-transparent opacity-50"></div>
            <div class="font-mono text-sm space-y-3 leading-relaxed text-emerald-400">
                @if (ViewBag.ArrivalsRender != null)
                {
                    @Html.Raw(ViewBag.ArrivalsRender)
                }
            </div>
        </div>
    </div>
</div>

<!-- Bridge Info -->
<div class="bg-blue-50 p-6 rounded-2xl border border-blue-100 shadow-sm">
    <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center">
            <span class="material-symbols-outlined text-[20px]">account_tree</span>
        </div>
        <h2 class="font-bold text-blue-900">Bridge Connection: DeparturesBoard &larr;[renderer]&rarr; WebRenderer</h2>
    </div>
    <p class="text-blue-800 text-sm leading-relaxed max-w-3xl ml-13">
        Switching to Smart Display changes only the <code class="bg-white px-2 py-0.5 rounded text-blue-600 font-mono text-xs border border-blue-200">IDisplayRenderer</code>.
        Zero changes to <code class="bg-white px-2 py-0.5 rounded text-blue-600 font-mono text-xs border border-blue-200">DeparturesBoard</code> or
        <code class="bg-white px-2 py-0.5 rounded text-blue-600 font-mono text-xs border border-blue-200">ArrivalsBoard</code> classes.
    </p>
</div>
