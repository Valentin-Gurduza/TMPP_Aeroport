@{
    ViewData["Title"] = "Ticket Machine (State)";
}

<header class="border-l-4 pl-lg mb-xl" style="border-color:#3cd7ff;">
    <h1 class="font-headline-lg text-display-xl text-on-surface">Ticket Vending Machine</h1>
    <p class="font-body-sm text-on-surface-variant max-w-2xl">State Pattern — Machine alters behavior when its internal state changes.</p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-xl items-start">
    <section class="glass-card p-lg rounded-lg shadow-2xl space-y-lg border-t-2" style="border-top-color:#3cd7ff;">
        <div class="flex justify-between items-center mb-6">
            <h3 class="font-headline-md text-cyan-400">Controls</h3>
            <span class="px-2 py-1 text-xs font-data-mono bg-white/10 rounded border border-white/20 text-slate-300">
                STATE: <span class="text-amber-400">@ViewBag.CurrentState</span>
            </span>
        </div>
        
        <form asp-action="StateDemo" method="get" class="grid grid-cols-2 gap-4">
            <div class="col-span-2 p-4 bg-black/30 rounded border border-white/10 mb-2">
                <div class="text-slate-400 text-sm mb-1 font-label-caps">TICKET PRICE: $50</div>
                <div class="text-3xl font-data-mono text-green-400 glow-green">BALANCE: $@ViewBag.Balance</div>
            </div>

            <button type="submit" name="actionType" value="Insert" class="py-3 bg-green-600/20 text-green-400 border border-green-500/50 rounded flex flex-col items-center hover:bg-green-500/30">
                <span class="material-symbols-outlined mb-1">payments</span>
                <span class="font-label-caps text-xs">INSERT $10</span>
                <input type="hidden" name="amount" value="10" disabled="@(Context.Request.Query["actionType"] != "Insert")" id="amt10" />
            </button>
            <script>
                // Small hack to ensure amount is sent correctly only for Insert button
                document.querySelectorAll('button[name="actionType"][value="Insert"]').forEach(btn => {
                    btn.onclick = () => document.getElementById('amt10').disabled = false;
                });
            </script>

            <button type="submit" name="actionType" value="Request" class="py-3 bg-amber-600/20 text-amber-400 border border-amber-500/50 rounded flex flex-col items-center hover:bg-amber-500/30">
                <span class="material-symbols-outlined mb-1">receipt_long</span>
                <span class="font-label-caps text-xs">REQUEST TICKET</span>
            </button>

            <button type="submit" name="actionType" value="Dispense" class="col-span-2 py-3 bg-cyan-600/20 text-cyan-400 border border-cyan-500/50 rounded flex flex-col items-center hover:bg-cyan-500/30">
                <span class="material-symbols-outlined mb-1">print</span>
                <span class="font-label-caps text-xs">DISPENSE</span>
            </button>
        </form>

        <form asp-action="StateDemo" method="get" class="mt-4 border-t border-white/10 pt-4 text-right">
            <button type="submit" name="actionType" value="ResetLogs" class="text-xs text-slate-500 hover:text-white transition-colors">CLEAR LOGS</button>
        </form>
    </section>

    <section class="bg-surface-container-low border border-white/10 rounded-lg shadow-2xl flex flex-col min-h-[300px]">
        <div class="bg-surface-container-high px-lg py-md border-b border-white/10 flex justify-between items-center">
            <h3 class="font-label-caps text-cyan-400 tracking-widest">MACHINE AUDIT LOG</h3>
            <span class="material-symbols-outlined text-sm text-cyan-400">terminal</span>
        </div>
        <div class="p-lg flex-1 font-data-mono text-sm space-y-2 overflow-y-auto max-h-[300px] flex flex-col-reverse">
            @if (ViewBag.Logs != null && ViewBag.Logs.Count > 0)
            {
                var logs = (List<string>)ViewBag.Logs;
                for (int i = logs.Count - 1; i >= 0; i--)
                {
                    <div class="text-slate-300 border-b border-white/5 pb-1">
                        > @logs[i]
                    </div>
                }
            }
        </div>
    </section>
</div>
