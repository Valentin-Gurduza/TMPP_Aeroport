@{
    ViewData["Title"] = "Pre-flight Routine";
}

<header class="border-l-4 pl-lg mb-xl" style="border-color:#3cd7ff;">
    <h1 class="font-headline-lg text-display-xl text-on-surface">Pre-flight Checklist</h1>
    <p class="font-body-sm text-on-surface-variant max-w-2xl">Template Method Pattern — Base algorithm executes, allowing subclasses to provide specific payload steps.</p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-xl items-start">
    <section class="glass-card p-lg rounded-lg shadow-2xl space-y-lg border-t-2" style="border-top-color:#3cd7ff;">
        <h3 class="font-headline-md text-cyan-400">Initialize Flight Routine</h3>
        
        <form asp-action="TemplateMethodDemo" method="get" class="grid grid-cols-2 gap-4">
            <button type="submit" name="flightType" value="passenger" class="py-6 bg-[#05070A] border @(ViewBag.FlightType == "passenger" ? "border-cyan-500 shadow-[0_0_15px_rgba(6,182,212,0.3)]" : "border-white/10") rounded flex flex-col items-center hover:border-cyan-400 transition-all group">
                <span class="material-symbols-outlined text-4xl mb-2 text-slate-400 group-hover:text-cyan-400">airline_seat_recline_normal</span>
                <span class="font-label-caps text-slate-300">PASSENGER FLIGHT</span>
            </button>

            <button type="submit" name="flightType" value="cargo" class="py-6 bg-[#05070A] border @(ViewBag.FlightType == "cargo" ? "border-amber-500 shadow-[0_0_15px_rgba(245,158,11,0.3)]" : "border-white/10") rounded flex flex-col items-center hover:border-amber-400 transition-all group">
                <span class="material-symbols-outlined text-4xl mb-2 text-slate-400 group-hover:text-amber-400">local_shipping</span>
                <span class="font-label-caps text-slate-300">CARGO FLIGHT</span>
            </button>
        </form>
        
        <div class="text-xs text-slate-500 mt-4">
            * Clicking a button invokes the `ExecuteRoutine()` template method on the abstract class.
        </div>
    </section>

    <section class="bg-surface-container-low border border-white/10 rounded-lg shadow-2xl flex flex-col min-h-[300px]">
        <div class="bg-surface-container-high px-lg py-md border-b border-white/10 flex justify-between items-center">
            <h3 class="font-label-caps text-cyan-400 tracking-widest">ROUTINE EXECUTION LOGS</h3>
            <span class="material-symbols-outlined text-sm text-cyan-400">checklist</span>
        </div>
        <div class="p-lg flex-1 font-data-mono text-sm space-y-3 overflow-y-auto max-h-[300px]">
            @if (ViewBag.RoutineLogs != null)
            {
                foreach (var log in ViewBag.RoutineLogs)
                {
                    <div class="flex items-start gap-2">
                        @if(log.Contains("---")) {
                            <span class="text-cyan-600 font-bold w-full text-center my-2 block">@log</span>
                        } else if (log.Contains("📦") || log.Contains("👥") || log.Contains("🍲") || log.Contains("⚖️")) {
                            <span class="text-amber-300 font-bold p-2 bg-amber-500/10 rounded w-full">@log (Abstract Step)</span>
                        } else {
                            <span class="text-slate-300">@log</span>
                        }
                    </div>
                }
            }
        </div>
    </section>
</div>
