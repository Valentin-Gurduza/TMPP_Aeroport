@{
    ViewData["Title"] = "System Log - Singleton";
}
<header class="mb-xl">
    <h1 class="font-headline-lg text-display-xl text-on-surface">System Event Log</h1>
    <p class="font-body-md text-on-surface-variant mt-1">Singleton Pattern — Only <span class="text-cyan-400 font-data-mono">one</span> AirportLogger instance exists throughout the entire application lifecycle.</p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-xl">
    <!-- Stats -->
    <div class="lg:col-span-1 space-y-md">
        <div class="glass-card p-lg border-l-4 border-cyan-400">
            <p class="font-label-caps text-[10px] text-cyan-400 mb-2">SINGLETON INSTANCE ID</p>
            <p class="font-data-mono text-2xl text-white">0x001A</p>
            <p class="font-body-sm text-slate-500 mt-1 italic">Always the same object</p>
        </div>
        <div class="glass-card p-lg border-l-4 border-green-400">
            <p class="font-label-caps text-[10px] text-green-400 mb-2">TOTAL LOG ENTRIES</p>
            <p class="font-data-mono text-2xl text-white">@(ViewBag.LogCount ?? "7")</p>
            <p class="font-body-sm text-slate-500 mt-1 italic">Accumulated since boot</p>
        </div>
        <div class="glass-card p-lg border-l-4 border-orange-400">
            <p class="font-label-caps text-[10px] text-orange-400 mb-2">INSTANCE REQUESTS</p>
            <p class="font-data-mono text-2xl text-white">@(ViewBag.InstanceRequests ?? "12")</p>
            <p class="font-body-sm text-slate-500 mt-1 italic">All returned same instance</p>
        </div>
        <div class="glass-card p-lg">
            <p class="font-label-caps text-[10px] text-slate-400 mb-3">PATTERN PROOF</p>
            <div class="font-data-mono text-xs space-y-2">
                <div class="flex items-center gap-2">
                    <span class="text-cyan-400">Logger.Instance</span>
                    <span class="text-green-400">→ 0x001A</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-cyan-400">Logger.Instance</span>
                    <span class="text-green-400">→ 0x001A ♻</span>
                </div>
                <div class="flex items-center gap-2 bg-white/5 p-2 rounded">
                    <span class="text-orange-400">ReferenceEquals(a, b)</span>
                    <span class="text-green-400">→ TRUE ✓</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Log Terminal -->
    <div class="lg:col-span-2">
        <div class="glass-panel flex flex-col h-full min-h-[500px]">
            <div class="bg-slate-950/50 p-md border-b border-white/10 flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <div class="flex gap-1">
                        <div class="w-2 h-2 rounded-full bg-red-500/50"></div>
                        <div class="w-2 h-2 rounded-full bg-amber-500/50"></div>
                        <div class="w-2 h-2 rounded-full bg-green-500/50"></div>
                    </div>
                    <span class="font-label-caps text-cyan-400">SINGLETON LOG TERMINAL — AIRPORT_LOGGER.INSTANCE</span>
                </div>
                <span class="font-data-mono text-[10px] text-slate-500">PID: 0x001A</span>
            </div>
            <div class="p-lg flex-grow font-data-mono text-sm space-y-3 overflow-y-auto">
                @if (ViewBag.Logs != null)
                {
                    foreach (var log in (List<string>)ViewBag.Logs)
                    {
                        <div class="flex items-start gap-3 group">
                            <span class="text-slate-600 whitespace-nowrap">[@DateTime.Now.ToString("HH:mm:ss")]</span>
                            <p class="text-on-surface-variant group-hover:text-green-300 transition-colors">@log</p>
                        </div>
                    }
                }
                else
                {
                    <div class="flex items-start gap-3"><span class="text-slate-600">[09:12:01]</span><p class="text-on-surface-variant">AirportLogger.Instance created (first call)</p></div>
                    <div class="flex items-start gap-3"><span class="text-slate-600">[09:12:02]</span><p class="text-green-400">Flight RO-302 cloned from schedule template</p></div>
                    <div class="flex items-start gap-3"><span class="text-slate-600">[09:12:03]</span><p class="text-cyan-400">Check-in kiosk activated for passenger Popescu</p></div>
                    <div class="flex items-start gap-3"><span class="text-slate-600">[09:12:04]</span><p class="text-on-surface-variant">Weather adapter: OTP temperature = 25°C</p></div>
                    <div class="flex items-start gap-3"><span class="text-slate-600">[09:12:05]</span><p class="text-amber-400">Cargo CARGO-MAIN-737 total weight: 88.7 kg</p></div>
                    <div class="flex items-start gap-3"><span class="text-slate-600">[09:12:06]</span><p class="text-on-surface-variant">FlightDepartureFacade.AuthorizeDeparture() called</p></div>
                    <div class="flex items-start gap-3"><span class="text-slate-600">[09:12:07]</span><p class="text-green-400">TAROM-301 departed from runway 08R ✓</p></div>
                }
                <div class="flex items-center gap-2 animate-pulse mt-4">
                    <span class="text-slate-600">▌</span>
                    <span class="text-cyan-400">_</span>
                </div>
            </div>
            <div class="p-md border-t border-white/10 bg-black/20">
                <a asp-controller="Airport" asp-action="SingletonDemo" class="w-full py-3 bg-primary-container text-on-primary-fixed font-label-caps tracking-widest text-center flex items-center justify-center gap-2 hover:brightness-110 transition-all">
                    <span class="material-symbols-outlined text-sm">refresh</span> ADD NEW LOG ENTRY
                </a>
            </div>
        </div>
    </div>
</div>
