@{
    ViewData["Title"] = "Check-In Terminal";
}
<div class="mb-8 text-center mt-6">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-100 text-blue-600 rounded-full mb-4">
        <span class="material-symbols-outlined text-4xl">touch_app</span>
    </div>
    <h1 class="text-4xl font-black text-slate-800 tracking-tight">Self-Service Check-In</h1>
    <p class="text-slate-500 mt-2 text-lg">Please enter your flight details to print your boarding pass.</p>
</div>

<div class="max-w-4xl mx-auto">
    <!-- Passenger Form -->
    <div class="bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden mb-8">
        <div class="bg-slate-50 px-8 py-6 border-b border-slate-100 flex items-center justify-center">
            <h3 class="text-2xl font-bold text-slate-700">Passenger Details</h3>
        </div>
        <div class="p-6">
            <form action="/Airport/CheckIn" method="get" class="space-y-6">
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Passenger Name</label>
                        <input name="passengerName" type="text" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" value="@(ViewBag.PassengerName ?? "Maria Popescu")" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Flight Number</label>
                        <input name="flightNumber" type="text" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" value="@(ViewBag.FlightNumber ?? "RO-302")" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Seat Class</label>
                        <select name="ticketType" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none bg-white">
                            <option value="Economy" selected="@(ViewBag.TicketType == "Economy")">Economy</option>
                            <option value="Business" selected="@(ViewBag.TicketType == "Business")">Business</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Baggage (KG)</label>
                        <input name="baggageKg" type="number" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" value="23" />
                    </div>
                </div>
                <button type="submit" class="w-full py-5 bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white rounded-2xl font-black tracking-widest text-lg transition shadow-xl shadow-blue-600/30 flex justify-center items-center gap-3 mt-8">
                    <span class="material-symbols-outlined text-2xl">print</span>
                    PRINT BOARDING PASS
                </button>
            </form>
        </div>
    </div>

        @if (ViewBag.BoardingPass != null)
        {
            <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-3xl p-8 shadow-2xl text-white relative overflow-hidden animate-fade-in-up">
                <span class="material-symbols-outlined absolute -right-10 -bottom-10 text-[200px] opacity-5 text-white">airplane_ticket</span>
                <div class="flex items-start justify-between mb-10 relative z-10">
                    <div>
                        <div class="flex items-center gap-2 mb-2">
                            <span class="material-symbols-outlined text-emerald-400">check_circle</span>
                            <p class="text-emerald-400 text-sm font-bold uppercase tracking-widest">Boarding Pass Issued</p>
                        </div>
                        <p class="text-4xl font-black tracking-tight">@ViewBag.BoardingPass.PassengerName</p>
                    </div>
                    <div class="bg-white/10 px-6 py-2 rounded-full text-lg font-bold border border-white/20 backdrop-blur-md">
                        @ViewBag.TicketType Class
                    </div>
                </div>
                <div class="grid grid-cols-3 gap-6 text-center relative z-10 bg-black/20 rounded-2xl p-6 border border-white/10">
                    <div>
                        <p class="text-sm text-slate-400 font-semibold uppercase tracking-widest mb-2">Flight</p>
                        <p class="font-black text-3xl font-mono">@ViewBag.BoardingPass.FlightNumber</p>
                    </div>
                    <div>
                        <p class="text-sm text-slate-400 font-semibold uppercase tracking-widest mb-2">Seat</p>
                        <p class="font-black text-3xl font-mono text-blue-400">@ViewBag.BoardingPass.SeatNumber</p>
                    </div>
                    <div>
                        <p class="text-sm text-slate-400 font-semibold uppercase tracking-widest mb-2">Gate</p>
                        <p class="font-black text-3xl font-mono text-yellow-400">@ViewBag.BoardingPass.Gate</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
