@{
    ViewData["Title"] = "Configuration Backup";
    Layout = "_LayoutSAMS";
}

<header class="border-l-4 pl-lg mb-xl" style="border-color:#3cd7ff;">
    <h1 class="font-headline-lg text-display-xl text-on-surface">Configuration Rollback</h1>
    <p class="font-body-sm text-on-surface-variant max-w-2xl">Memento Pattern — Captures object state for restoration without exposing internal structure.</p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-xl items-start">
    <section class="glass-card p-lg rounded-lg shadow-2xl space-y-lg border-t-2" style="border-top-color:#3cd7ff;">
        <h3 class="font-headline-md text-cyan-400">Flight Configurator (Originator)</h3>
        
        <form asp-action="MementoDemo" method="get" class="space-y-md">
            <div class="p-4 border border-white/10 rounded bg-white/5 space-y-4">
                <div>
                    <label class="font-label-caps text-on-surface-variant block mb-1">CURRENT GATE</label>
                    <input type="text" name="newGate" value="@ViewBag.CurrentGate" class="w-full bg-[#05070A] border border-white/20 rounded px-3 py-2 text-primary-container outline-none" />
                </div>
                <div>
                    <label class="font-label-caps text-on-surface-variant block mb-1">AIRCRAFT MODEL</label>
                    <input type="text" name="newModel" value="@ViewBag.CurrentModel" class="w-full bg-[#05070A] border border-white/20 rounded px-3 py-2 text-primary-container outline-none" />
                </div>
                <button type="submit" name="actionType" value="Update" class="w-full py-2 bg-cyan-600/20 text-cyan-400 border border-cyan-500/50 rounded hover:bg-cyan-500/30">APPLY CHANGES</button>
            </div>

            <div class="grid grid-cols-2 gap-md mt-6">
                <button type="submit" name="actionType" value="Save" class="py-3 bg-green-600/20 text-green-400 border border-green-500/50 rounded flex items-center justify-center gap-2 hover:bg-green-500/30">
                    <span class="material-symbols-outlined text-sm">save</span> CREATE BACKUP
                </button>
                <button type="submit" name="actionType" value="Undo" class="py-3 bg-amber-600/20 text-amber-400 border border-amber-500/50 rounded flex items-center justify-center gap-2 hover:bg-amber-500/30">
                    <span class="material-symbols-outlined text-sm">settings_backup_restore</span> RESTORE BACKUP
                </button>
            </div>
        </form>
    </section>

    <section class="bg-surface-container-low border border-white/10 rounded-lg shadow-2xl flex flex-col min-h-[300px]">
        <div class="bg-surface-container-high px-lg py-md border-b border-white/10 flex justify-between items-center">
            <h3 class="font-label-caps text-green-400 tracking-widest">INTERNAL AUDIT LOG</h3>
            <span class="material-symbols-outlined text-sm text-green-400">inventory_2</span>
        </div>
        <div class="p-lg flex-1 font-data-mono text-sm space-y-2 overflow-y-auto max-h-[300px] flex flex-col-reverse">
            @if (ViewBag.Logs != null && ViewBag.Logs.Count > 0)
            {
                var logs = (List<string>)ViewBag.Logs;
                for (int i = logs.Count - 1; i >= 0; i--)
                {
                    <div class="text-on-surface-variant border-b border-white/5 pb-1 mb-1">
                        @logs[i]
                    </div>
                }
            }
            else
            {
                <div class="text-slate-600 italic">Configure flights to see logs...</div>
            }
        </div>
    </section>
</div>
