@{
    ViewData["Title"] = "ATC Traffic Coordinator";
}

<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-cyan-100 text-cyan-800 text-xs font-bold mb-4 border border-cyan-200">
        <span class="material-symbols-outlined text-[14px]">hub</span>
        ATC MEDIATOR
    </div>
    <h1 class="text-3xl font-bold text-slate-800">ATC Traffic Coordinator</h1>
    <p class="text-slate-500 mt-1">Mediator Pattern — Aircraft communicate via the Control Tower, never directly with each other.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center gap-3">
            <span class="material-symbols-outlined text-cyan-600">settings_remote</span>
            <h3 class="font-bold text-slate-800 tracking-wide uppercase">Communication Triggers</h3>
        </div>
        
        <div class="p-6">
            <form action="/Airport/MediatorDemo" method="get" class="space-y-4">
                <button type="submit" name="actionType" value="Broadcast" class="w-full p-4 bg-white border border-red-200 rounded-xl flex items-center justify-between hover:bg-red-50 hover:border-red-300 transition shadow-sm group">
                    <div class="text-left">
                        <div class="font-bold text-red-700 text-sm tracking-wide">@(ViewBag.Flight1Name ?? "FLIGHT-1") BROADCASTS ISSUE</div>
                        <div class="text-xs mt-1 text-slate-500 font-mono">"Encountering severe turbulence at FL350."</div>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-red-100 text-red-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-[20px]">campaign</span>
                    </div>
                </button>
    
                <button type="submit" name="actionType" value="Landing" class="w-full p-4 bg-white border border-amber-200 rounded-xl flex items-center justify-between hover:bg-amber-50 hover:border-amber-300 transition shadow-sm group">
                    <div class="text-left">
                        <div class="font-bold text-amber-700 text-sm tracking-wide">@(ViewBag.Flight2Name ?? "FLIGHT-2") REQUESTS LANDING</div>
                        <div class="text-xs mt-1 text-slate-500 font-mono">"Requesting landing clearance on Runway 09."</div>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-[20px]">flight_land</span>
                    </div>
                </button>
    
                <button type="submit" name="actionType" value="Heli" class="w-full p-4 bg-white border border-emerald-200 rounded-xl flex items-center justify-between hover:bg-emerald-50 hover:border-emerald-300 transition shadow-sm group">
                    <div class="text-left">
                        <div class="font-bold text-emerald-700 text-sm tracking-wide">HELI-MEDEVAC ENTERING</div>
                        <div class="text-xs mt-1 text-slate-500 font-mono">"Entering airspace from South."</div>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-[20px]">toys</span>
                    </div>
                </button>
            </form>
        </div>
    </div>

    <div class="space-y-6">
        <!-- Tower Logs -->
        <div class="bg-slate-900 rounded-2xl shadow-lg border border-slate-700 overflow-hidden">
            <div class="bg-slate-800 px-4 py-3 border-b border-slate-700 flex justify-between items-center">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-cyan-400 text-[18px]">cell_tower</span>
                    <h3 class="text-xs font-bold text-cyan-400 uppercase tracking-widest">ATCTower Mediator</h3>
                </div>
                <span class="flex h-2.5 w-2.5 rounded-full bg-cyan-500 animate-pulse"></span>
            </div>
            <div class="p-5 font-mono text-xs space-y-2 text-cyan-100 min-h-[120px]">
                @if(ViewBag.TowerLogs != null) {
                    foreach(var log in ViewBag.TowerLogs) { 
                        <div class="flex gap-2">
                            <span class="text-cyan-600 font-bold">></span>
                            <span>@log</span>
                        </div>
                    }
                } else {
                    <div class="text-slate-600 italic">Tower is listening...</div>
                }
            </div>
        </div>

        <!-- Aircraft Logs -->
        <div class="grid grid-cols-2 gap-4">
            <div class="bg-slate-800 px-4 py-3 border-b border-slate-700 flex justify-between items-center mt-6 rounded-t-2xl">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-blue-400 text-[18px]">flight</span>
                    <h3 class="text-xs font-bold text-slate-300 uppercase tracking-widest">@(ViewBag.Flight1Name) Logs</h3>
                </div>
            </div>
            <div class="p-4 font-mono text-xs space-y-2 max-h-[150px] overflow-y-auto bg-slate-900 rounded-b-2xl border border-t-0 border-slate-700">
                @if (ViewBag.Flight1Logs != null)
                {
                    foreach (var log in ViewBag.Flight1Logs)
                    {
                        <div class="text-blue-300 border-l-2 border-blue-500/30 pl-2">@log</div>
                    }
                }
            </div>

            <!-- Flight 2 Logs -->
            <div class="bg-slate-800 px-4 py-3 border-b border-slate-700 flex justify-between items-center mt-6 rounded-t-2xl">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-purple-400 text-[18px]">flight</span>
                    <h3 class="text-xs font-bold text-slate-300 uppercase tracking-widest">@(ViewBag.Flight2Name) Logs</h3>
                </div>
            </div>
            <div class="p-4 font-mono text-xs space-y-2 max-h-[150px] overflow-y-auto bg-slate-900 rounded-b-2xl border border-t-0 border-slate-700">
                @if (ViewBag.Flight2Logs != null)
                {
                    foreach (var log in ViewBag.Flight2Logs)
                    {
                        <div class="text-purple-300 border-l-2 border-purple-500/30 pl-2">@log</div>
                    }
                }
            </div>
        </div>
    </div>
</div>
