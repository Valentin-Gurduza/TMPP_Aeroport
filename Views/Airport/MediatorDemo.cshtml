@{
    ViewData["Title"] = "ATC Mediator";
    Layout = "_LayoutSAMS";
}

<header class="border-l-4 pl-lg mb-xl" style="border-color:#3cd7ff;">
    <h1 class="font-headline-lg text-display-xl text-on-surface">ATC Traffic Coordinator</h1>
    <p class="font-body-sm text-on-surface-variant max-w-2xl">Mediator Pattern — Aircraft communicate via the Control Tower, never directly with each other.</p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-xl items-start">
    <section class="glass-card p-lg rounded-lg shadow-2xl space-y-lg border-t-2" style="border-top-color:#3cd7ff;">
        <h3 class="font-headline-md text-cyan-400">Triggers</h3>
        
        <form asp-action="MediatorDemo" method="get" class="grid grid-cols-1 gap-4">
            <button type="submit" name="actionType" value="Broadcast" class="p-4 bg-red-600/10 text-red-400 border border-red-500/30 rounded flex items-center justify-between hover:bg-red-500/20 text-left">
                <div>
                    <div class="font-label-caps font-bold">TAROM-101 BROADCASTS ISSUE</div>
                    <div class="text-xs mt-1 text-slate-400">"Encountering severe turbulence at FL350."</div>
                </div>
                <span class="material-symbols-outlined">campaign</span>
            </button>

            <button type="submit" name="actionType" value="Landing" class="p-4 bg-amber-600/10 text-amber-400 border border-amber-500/30 rounded flex items-center justify-between hover:bg-amber-500/20 text-left">
                <div>
                    <div class="font-label-caps font-bold">WIZZ-777 REQUESTS LANDING</div>
                    <div class="text-xs mt-1 text-slate-400">"Requesting landing clearance on Runway 09."</div>
                </div>
                <span class="material-symbols-outlined">flight_land</span>
            </button>

            <button type="submit" name="actionType" value="Heli" class="p-4 bg-green-600/10 text-green-400 border border-green-500/30 rounded flex items-center justify-between hover:bg-green-500/20 text-left">
                <div>
                    <div class="font-label-caps font-bold">HELI-MEDEVAC ENTERING</div>
                    <div class="text-xs mt-1 text-slate-400">"Entering airspace from South."</div>
                </div>
                <span class="material-symbols-outlined">toys</span>
            </button>
        </form>
    </section>

    <div class="space-y-md">
        <!-- Tower Logs -->
        <section class="bg-surface-container-low border border-cyan-500/30 rounded-lg shadow-2xl flex flex-col">
            <div class="bg-surface-container-high px-4 py-2 border-b border-white/10 flex justify-between items-center">
                <h3 class="font-label-caps text-cyan-400 tracking-widest text-xs">ATCTOWER MEDIATOR</h3>
                <span class="material-symbols-outlined text-sm text-cyan-400">radar</span>
            </div>
            <div class="p-4 font-data-mono text-xs space-y-1 text-cyan-200">
                @if(ViewBag.TowerLogs != null) {
                    foreach(var log in ViewBag.TowerLogs) { <div>@log</div> }
                }
            </div>
        </section>

        <!-- Aircraft Logs -->
        <div class="grid grid-cols-2 gap-4">
            <section class="bg-surface-container-low border border-white/10 rounded-lg shadow-2xl flex flex-col">
                <div class="bg-surface-container-high px-4 py-2 border-b border-white/10">
                    <h3 class="font-label-caps text-slate-300 tracking-widest text-xs">TAROM-101</h3>
                </div>
                <div class="p-4 font-data-mono text-[10px] space-y-1 text-slate-400">
                    @if(ViewBag.Flight1Logs != null) {
                        foreach(var log in ViewBag.Flight1Logs) { <div>@log</div> }
                    }
                </div>
            </section>
            
            <section class="bg-surface-container-low border border-white/10 rounded-lg shadow-2xl flex flex-col">
                <div class="bg-surface-container-high px-4 py-2 border-b border-white/10">
                    <h3 class="font-label-caps text-slate-300 tracking-widest text-xs">WIZZ-777</h3>
                </div>
                <div class="p-4 font-data-mono text-[10px] space-y-1 text-slate-400">
                    @if(ViewBag.Flight2Logs != null) {
                        foreach(var log in ViewBag.Flight2Logs) { <div>@log</div> }
                    }
                </div>
            </section>
        </div>
    </div>
</div>
