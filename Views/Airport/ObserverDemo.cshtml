@{
    ViewData["Title"] = "Flight Status Observer";
    Layout = "_LayoutSAMS";
}

<header class="border-l-4 pl-lg mb-xl" style="border-color:#3cd7ff;">
    <h1 class="font-headline-lg text-display-xl text-on-surface">Live Status Broadcaster</h1>
    <p class="font-body-sm text-on-surface-variant max-w-2xl">Observer Pattern — Flight status changes automatically notify all subscribed observers.</p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-xl items-start">
    <section class="glass-card p-lg rounded-lg shadow-2xl space-y-lg border-t-2" style="border-top-color:#3cd7ff;">
        <h3 class="font-headline-md text-cyan-400">Flight Controller (Subject)</h3>
        <form asp-action="ObserverDemoExecute" method="post" class="space-y-md">
            <div>
                <label class="font-label-caps text-on-surface-variant block mb-1">FLIGHT NUMBER</label>
                <input type="text" name="flightNumber" value="@(ViewBag.FlightNumber ?? "TAROM-301")" class="w-full bg-[#05070A] border border-white/20 rounded px-3 py-2 text-primary-container outline-none" readonly />
            </div>
            
            <div class="grid grid-cols-3 gap-2">
                <button type="submit" name="newStatus" value="BOARDING" class="py-2 bg-amber-600/20 text-amber-400 border border-amber-500/50 rounded hover:bg-amber-500/30">BOARDING</button>
                <button type="submit" name="newStatus" value="DELAYED" class="py-2 bg-red-600/20 text-red-400 border border-red-500/50 rounded hover:bg-red-500/30">DELAYED</button>
                <button type="submit" name="newStatus" value="DEPARTED" class="py-2 bg-green-600/20 text-green-400 border border-green-500/50 rounded hover:bg-green-500/30">DEPARTED</button>
            </div>
        </form>
    </section>

    <section class="bg-surface-container-low border border-white/10 rounded-lg shadow-2xl flex flex-col min-h-[300px]">
        <div class="bg-surface-container-high px-lg py-md border-b border-white/10 flex justify-between items-center">
            <h3 class="font-label-caps text-cyan-400 tracking-widest">OBSERVER NOTIFICATIONS LOG</h3>
            <span class="material-symbols-outlined text-sm text-cyan-400 animate-pulse">settings_input_antenna</span>
        </div>
        <div class="p-lg flex-1 font-data-mono text-sm space-y-2 overflow-y-auto max-h-[300px]">
            @if (ViewBag.Logs != null && ViewBag.Logs.Count > 0)
            {
                <div class="text-slate-500 mb-4">Subject updated state to: @ViewBag.NewStatus</div>
                @foreach(var log in ViewBag.Logs)
                {
                    <div class="flex items-start gap-2 text-cyan-300">
                        <span class="material-symbols-outlined text-xs mt-1">mark_email_unread</span>
                        <span>@log</span>
                    </div>
                }
            }
            else
            {
                <div class="text-slate-600 italic">Waiting for state change to trigger notifications...</div>
            }
        </div>
    </section>
</div>
