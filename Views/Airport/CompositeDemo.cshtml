@{
    ViewData["Title"] = "Cargo Hold Weight Calculator";
    Layout = "_LayoutSAMS";
}
<header>
    <h2 class="font-headline-lg text-headline-lg text-primary-container">Cargo Hold Weight Calculator</h2>
    <p class="font-body-sm text-outline uppercase tracking-wider mt-1">Composite Pattern — Recursive tree structure for uniform treatment of objects and containers</p>
</header>

<!-- Stats Bar -->
<div class="glass-card p-lg border border-white/5 relative overflow-hidden mt-xl">
    <div class="absolute top-0 right-0 w-64 h-full bg-gradient-to-l from-cyan-500/5 to-transparent pointer-events-none"></div>
    <div class="flex flex-col md:flex-row justify-between items-end gap-lg">
        <div class="space-y-xs">
            <span class="font-label-caps text-outline uppercase tracking-widest">TOTAL TAKEOFF WEIGHT</span>
            <div class="flex items-baseline gap-2">
                <span class="font-display-xl text-display-xl text-primary-container">@(ViewBag.TotalWeight ?? "88.7")</span>
                <span class="font-headline-md text-primary-container">kg</span>
            </div>
            <p class="font-data-mono text-xs text-secondary italic">Calculated by mainCargo.GetWeight() — one call to root node</p>
        </div>
        <div class="flex-1 max-w-2xl w-full space-y-sm">
            <div class="flex justify-between font-label-caps text-[10px] text-outline">
                <span>CAPACITY UTILIZATION</span>
                <span class="text-cyan-400">@(ViewBag.Utilization ?? "44.35")%</span>
            </div>
            <div class="h-2 w-full bg-slate-900 border border-white/10 overflow-hidden">
                <div class="h-full bg-gradient-to-r from-cyan-600 to-cyan-400 shadow-[0_0_10px_rgba(0,212,255,0.4)]" style="width: @(ViewBag.Utilization ?? "44.35")%"></div>
            </div>
            <div class="flex justify-between font-data-mono text-[10px] text-slate-500">
                <span>0 kg</span>
                <span>MAX LOAD: 200.0 kg</span>
            </div>
        </div>
    </div>
</div>

<!-- Dashboard -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-xl mt-xl">
    <!-- Tree View -->
    <div class="lg:col-span-7 space-y-md">
        <h3 class="font-label-caps text-on-surface-variant flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">account_tree</span>
            CARGO HOLD: CARGO-MAIN-737
        </h3>
        <div class="glass-card p-lg border border-white/5 divide-y divide-white/5">
            <!-- Root -->
            <div class="flex items-center justify-between py-3 hover:bg-white/5 px-2 transition-colors">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-cyan-400">inventory_2</span>
                    <div>
                        <p class="font-data-mono text-cyan-400">CARGO-MAIN-737</p>
                        <p class="text-[10px] text-slate-500 uppercase">Container Node • Own: 15.0kg</p>
                    </div>
                </div>
                <span class="font-data-mono text-cyan-400">@(ViewBag.TotalWeight ?? "88.7") kg</span>
            </div>
            <!-- Level 1: Container -->
            <div class="flex items-center justify-between py-3 pl-8 border-l border-white/10 hover:bg-white/5 px-2 ml-4 transition-colors">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-secondary">package_2</span>
                    <div>
                        <p class="font-data-mono text-secondary">POP-01</p>
                        <p class="text-[10px] text-slate-500 uppercase">Nested Container • Own: 15.0kg</p>
                    </div>
                </div>
                <span class="font-data-mono text-secondary">61.7 kg</span>
            </div>
            <!-- Level 2: Leaves -->
            <div class="flex items-center justify-between py-2 pl-16 border-l border-white/10 hover:bg-white/5 px-2 ml-8 transition-colors">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-slate-500 text-sm">luggage</span>
                    <div><p class="font-body-sm text-slate-300">Valiză Roșie</p><p class="text-[10px] text-slate-600 uppercase">Leaf Object</p></div>
                </div>
                <span class="font-data-mono text-slate-400 text-xs">23.5 kg</span>
            </div>
            <div class="flex items-center justify-between py-2 pl-16 border-l border-white/10 hover:bg-white/5 px-2 ml-8 transition-colors">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-slate-500 text-sm">backpack</span>
                    <div><p class="font-body-sm text-slate-300">Rucsac Laptop</p><p class="text-[10px] text-slate-600 uppercase">Leaf Object</p></div>
                </div>
                <span class="font-data-mono text-slate-400 text-xs">5.2 kg</span>
            </div>
            <div class="flex items-center justify-between py-2 pl-16 border-l border-white/10 hover:bg-white/5 px-2 ml-8 transition-colors">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-slate-500 text-sm">luggage</span>
                    <div><p class="font-body-sm text-slate-300">Valiză Neagră</p><p class="text-[10px] text-slate-600 uppercase">Leaf Object</p></div>
                </div>
                <span class="font-data-mono text-slate-400 text-xs">18.0 kg</span>
            </div>
            <!-- Level 1: Leaf -->
            <div class="flex items-center justify-between py-3 pl-8 border-l border-white/10 hover:bg-white/5 px-2 ml-4 transition-colors">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-slate-500 text-sm">sports_golf</span>
                    <div><p class="font-body-sm text-slate-300">Geantă Golf</p><p class="text-[10px] text-slate-600 uppercase">Leaf Object</p></div>
                </div>
                <span class="font-data-mono text-slate-400 text-xs">12.0 kg</span>
            </div>
        </div>
    </div>

    <!-- Weight Breakdown -->
    <div class="lg:col-span-5 space-y-md">
        <h3 class="font-label-caps text-on-surface-variant flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">calculate</span>
            RECURSIVE BREAKDOWN
        </h3>
        <div class="glass-card p-md border-l-2 border-l-cyan-400">
            <h4 class="font-label-caps text-[10px] text-cyan-400 mb-1">Container CARGO-MAIN-737</h4>
            <div class="flex items-center justify-between text-body-sm">
                <span class="text-slate-400">Self Weight + Children Sum</span>
                <span class="font-data-mono text-primary-container">15kg + 73.7kg = 88.7kg</span>
            </div>
        </div>
        <div class="glass-card p-md border-l-2 border-l-secondary">
            <h4 class="font-label-caps text-[10px] text-secondary mb-1">Container POP-01</h4>
            <div class="flex items-center justify-between text-body-sm">
                <span class="text-slate-400">Self Weight + 3 Items</span>
                <span class="font-data-mono text-secondary">15kg + 46.7kg = 61.7kg</span>
            </div>
        </div>
        <div class="glass-card p-md border border-dashed border-white/20 bg-white/5">
            <div class="flex gap-4">
                <span class="material-symbols-outlined text-slate-500">info</span>
                <div>
                    <h4 class="font-label-caps text-[10px] text-slate-400 mb-1 uppercase">Pattern Logic</h4>
                    <p class="font-body-sm text-slate-400 leading-snug">
                        Leaf nodes act as the base case for recursion. Containers iterate children, asking each for their weight,
                        unaware if the child is a single item or another container.
                    </p>
                </div>
            </div>
        </div>
        <!-- Add cargo form -->
        <a asp-controller="Airport" asp-action="CompositeDemo" class="block w-full bg-primary-container text-on-primary-fixed font-label-caps py-3 tracking-widest text-center hover:brightness-110 transition-all mt-4">
            RECALCULATE COMPOSITE WEIGHT
        </a>
    </div>
</div>

<!-- Execution Log Footer -->
<footer class="mt-xl">
    <div class="bg-slate-950 border border-white/10 p-lg relative">
        <div class="absolute top-0 right-0 p-2 bg-white/5 text-[10px] font-data-mono text-slate-500">CONTROLLER_LOG_737</div>
        <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-cyan-400" style="font-variation-settings: 'FILL' 1;">terminal</span>
            <div class="space-y-sm">
                <h4 class="font-label-caps text-xs text-on-surface-variant uppercase tracking-widest">Execution Environment</h4>
                <p class="font-data-mono text-body-sm text-cyan-300 leading-relaxed bg-cyan-950/20 p-md border-l border-cyan-400/50">
                    The Controller called <span class="text-white">mainCargo.GetWeight()</span> ONCE.
                    No foreach loops, no if-checks in the client code. Composite handled recursive calculation automatically by delegating responsibility to child nodes.
                </p>
            </div>
        </div>
    </div>
</footer>

<!-- Status HUDs -->
<div class="fixed bottom-6 right-6 flex flex-col gap-2 z-50">
    <div class="glass-card px-4 py-2 border border-cyan-500/30 flex items-center gap-3">
        <div class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></div>
        <span class="font-label-caps text-[10px] text-cyan-400 uppercase tracking-widest">System Health: Nominal</span>
    </div>
    <div class="glass-card px-4 py-2 border border-white/10 flex items-center gap-3">
        <span class="font-label-caps text-[10px] text-slate-500 uppercase tracking-widest">Node Depth: 3</span>
    </div>
</div>
