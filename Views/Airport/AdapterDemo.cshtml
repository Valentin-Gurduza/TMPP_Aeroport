@{
    ViewData["Title"] = "Global Weather Station";
}

<!-- Page Header -->
<header class="mb-12">
    <h1 class="font-headline-lg text-display-xl text-on-surface tracking-tight mb-2">Global Weather Station</h1>
    <div class="flex items-center gap-3">
        <div class="w-12 h-[2px] bg-primary-container"></div>
        <p class="font-body-lg text-primary uppercase tracking-widest text-sm">Adapter Pattern — Kelvin → Celsius conversion via LegacyWeatherSystem</p>
    </div>
</header>

<div class="grid grid-cols-12 gap-gutter">
    <!-- LEFT COLUMN: SEARCH -->
    <section class="col-span-12 lg:col-span-4 flex flex-col gap-gutter">
        <div class="glass-card p-8 flex flex-col gap-6">
            <div class="flex items-center gap-3 border-b border-white/5 pb-4">
                <span class="material-symbols-outlined text-primary">travel_explore</span>
                <h3 class="font-headline-md text-on-surface">Station Lookup</h3>
            </div>
            <div class="flex flex-col gap-2">
                <label class="font-label-caps text-slate-400 text-[10px]">IATA Airport Code</label>
                <div class="relative">
                    <input class="w-full bg-[#05070A] border-b border-outline-variant py-4 pl-4 pr-12 text-on-surface font-headline-md focus:border-primary-container outline-none transition-all placeholder:text-slate-700"
                           placeholder="e.g. OTP, LHR, JFK" type="text" />
                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-500">search</span>
                </div>
            </div>
            <a asp-controller="Airport" asp-action="AdapterDemo" class="w-full bg-primary-container text-on-primary-fixed py-4 font-headline-md tracking-widest hover:brightness-110 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                GET WEATHER
                <span class="material-symbols-outlined text-[18px]">bolt</span>
            </a>
            <div class="mt-4 flex items-center gap-3 py-3 px-4 bg-white/5 border-l-2 border-primary-container">
                <span class="material-symbols-outlined text-[16px] text-slate-400">api</span>
                <p class="font-body-sm text-slate-400 italic">🔌 Legacy API active — converting Kelvin units via WeatherAdapter</p>
            </div>
        </div>
    </section>

    <!-- RIGHT COLUMN: WEATHER DISPLAY -->
    <section class="col-span-12 lg:col-span-8">
        <div class="glass-card p-10 h-full flex flex-col relative overflow-hidden">
            <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary/5 rounded-full blur-[100px]"></div>
            <div class="flex justify-between items-start mb-12">
                <div class="z-10">
                    <p class="text-primary font-headline-md tracking-tight mb-1">OTP — Henri Coandă International, Bucharest</p>
                    <p class="font-label-caps text-slate-500">TIMESTAMP: @DateTime.Now.ToString("yyyy.MM.dd // HH:mm:ssZ")</p>
                </div>
                <div class="p-3 bg-white/5 border border-white/10">
                    <span class="material-symbols-outlined text-primary text-4xl" style="font-variation-settings: 'FILL' 1;">partly_cloudy_day</span>
                </div>
            </div>
            <div class="flex items-baseline gap-4 mb-12 z-10">
                <span class="text-[120px] font-headline-lg leading-none tracking-tighter text-primary">@ViewBag.Temperature</span>
                <span class="text-5xl font-headline-md text-on-surface">°C</span>
            </div>
            <div class="flex flex-wrap gap-4 mb-12 z-10">
                <div class="bg-[#05070A] border border-white/10 px-5 py-3 flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">wb_sunny</span>
                    <span class="font-data-mono uppercase text-xs">Partly Cloudy</span>
                </div>
                <div class="bg-[#05070A] border border-white/10 px-5 py-3 flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">humidity_mid</span>
                    <span class="font-data-mono uppercase text-xs">Humidity: 68%</span>
                </div>
                <div class="bg-[#05070A] border border-white/10 px-5 py-3 flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">air</span>
                    <span class="font-data-mono uppercase text-xs">Wind: 12 km/h</span>
                </div>
            </div>
            <div class="w-full h-[1px] bg-gradient-to-r from-primary-container/40 via-white/5 to-transparent mb-12"></div>
            <!-- Adapter Trace Box -->
            <div class="mt-auto bg-[#05070A] border border-white/10 p-6 font-data-mono relative group">
                <div class="absolute -top-3 left-4 bg-[#05070A] px-2 text-[10px] text-slate-500 border border-white/10">ADAPTER TRACE LOG</div>
                <div class="space-y-3">
                    <div class="flex items-center gap-4">
                        <span class="text-slate-600 text-[10px]">01</span>
                        <p class="text-slate-400">LegacyWeatherSystem.GetTemperatureKelvin('OTP') <span class="text-primary">→ 298.15K</span></p>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="text-slate-600 text-[10px]">02</span>
                        <p class="text-amber-500/80">WeatherAdapter converts: 298.15 - 273.15 = <span class="text-amber-400 font-bold">25.0°C</span></p>
                    </div>
                    <div class="flex items-center gap-4">
                        <span class="text-slate-600 text-[10px]">03</span>
                        <p class="text-emerald-500/80">IAirportWeatherService returns: <span class="text-emerald-400">25.0°C ✓</span></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- BOTTOM UML SECTION -->
    <section class="col-span-12 mt-4">
        <div class="glass-card p-8">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h3 class="font-headline-md text-on-surface">Adapter Design Pattern Architecture</h3>
                    <p class="font-body-sm text-slate-400">Decoupling modern UI requirements from legacy Kelvin-based systems.</p>
                </div>
                <span class="material-symbols-outlined text-primary">schema</span>
            </div>
            <div class="flex flex-col md:flex-row items-center justify-center gap-8 py-8 px-4">
                <div class="w-48 h-24 border border-primary/40 bg-primary/5 flex flex-col items-center justify-center p-4 text-center">
                    <p class="font-label-caps text-[10px] text-primary mb-1">Client</p>
                    <p class="font-data-mono text-xs">AirportController</p>
                </div>
                <span class="material-symbols-outlined text-on-surface rotate-90 md:rotate-0">arrow_forward</span>
                <div class="w-56 h-32 border-2 border-primary bg-primary/10 flex flex-col items-center justify-center p-4 text-center relative">
                    <div class="absolute -top-3 bg-primary text-black px-2 py-0.5 font-label-caps text-[10px]">INTERFACE</div>
                    <p class="font-data-mono text-xs font-bold">IAirportWeatherService</p>
                    <div class="w-full h-[1px] bg-primary/30 my-2"></div>
                    <p class="font-data-mono text-[10px] text-slate-400">GetCelsius(code)</p>
                </div>
                <div class="flex flex-col items-center">
                    <span class="material-symbols-outlined text-on-surface rotate-90 md:rotate-0">arrow_back</span>
                    <span class="text-[10px] font-label-caps text-slate-500 mt-2">IMPLEMENTS</span>
                </div>
                <div class="w-48 h-24 border border-primary/40 bg-white/5 flex flex-col items-center justify-center p-4 text-center relative">
                    <div class="absolute -top-3 bg-white/10 border border-white/20 text-slate-300 px-2 py-0.5 font-label-caps text-[10px]">ADAPTER</div>
                    <p class="font-data-mono text-xs">WeatherAdapter</p>
                </div>
                <span class="material-symbols-outlined text-on-surface rotate-90 md:rotate-0">arrow_forward</span>
                <div class="w-56 h-32 border border-slate-500/50 bg-slate-900 flex flex-col items-center justify-center p-4 text-center relative grayscale opacity-70">
                    <div class="absolute -top-3 bg-slate-700 text-slate-300 px-2 py-0.5 font-label-caps text-[10px]">LEGACY SYSTEM</div>
                    <p class="font-data-mono text-xs">LegacyWeatherSystem</p>
                    <div class="w-full h-[1px] bg-slate-700 my-2"></div>
                    <p class="font-data-mono text-[10px] text-slate-500">GetTempKelvin(code)</p>
                </div>
            </div>
        </div>
    </section>
</div>
