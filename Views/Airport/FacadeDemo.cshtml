@{
    ViewData["Title"] = "Tower Departure Control";
    Layout = "_LayoutSAMS";
}
<header class="border-l-4 pl-lg mb-xl" style="border-color:#FFB300;">
    <h1 class="font-headline-lg text-display-xl text-on-surface">Tower Departure Control</h1>
    <p class="font-body-sm text-on-surface-variant max-w-2xl">Facade Pattern — Single interface orchestrating ATC, Crew, and Baggage subsystems.</p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-xl items-start">
    <!-- LEFT: Departure Form -->
    <section class="glass-card p-lg rounded-lg shadow-2xl space-y-lg border-t-2" style="border-top-color:#FFB300;">
        <div class="flex items-center gap-md">
            <span class="material-symbols-outlined" style="color:#FFB300;">input</span>
            <h3 class="font-headline-md" style="color:#FFB300;">DEPARTURE AUTHORIZATION</h3>
        </div>
        <div class="space-y-md">
            <div>
                <label class="font-label-caps text-on-surface-variant block mb-1">FLIGHT NUMBER</label>
                <input class="w-full bg-[#05070A] border-b border-white/20 outline-none font-data-mono text-lg py-2" style="color:#FFB300;" readonly value="TAROM-301" />
            </div>
            <div>
                <label class="font-label-caps text-on-surface-variant block mb-1">RUNWAY</label>
                <input class="w-full bg-[#05070A] border-b border-white/20 outline-none font-data-mono text-lg py-2" style="color:#FFB300;" readonly value="08R" />
            </div>
        </div>
        <a asp-controller="Airport" asp-action="FacadeDemo" class="w-full py-4 bg-gradient-to-r from-orange-600 to-red-700 text-white font-headline-md rounded-lg flex items-center justify-center gap-2 hover:brightness-110 transition-all">
            <span class="material-symbols-outlined">flight_takeoff</span> 🛫 AUTHORIZE DEPARTURE
        </a>
        <div class="flex items-start gap-sm bg-error-container/20 p-md border border-error/20 rounded">
            <span class="material-symbols-outlined text-error text-sm">warning</span>
            <p class="text-error font-body-sm italic">⚠ Coordinates 3 critical subsystems via FlightDepartureFacade.</p>
        </div>
    </section>

    <!-- RIGHT: Execution Log -->
    <section class="bg-surface-container-low border border-white/10 rounded-lg overflow-hidden shadow-2xl flex flex-col min-h-[420px]">
        <div class="bg-surface-container-high px-lg py-md border-b border-white/10 flex justify-between items-center">
            <div class="flex items-center gap-sm">
                <span class="material-symbols-outlined text-cyan-400 text-sm">terminal</span>
                <h3 class="font-label-caps text-on-surface tracking-widest">DEPARTURE SEQUENCE LOG</h3>
            </div>
            <div class="flex gap-2">
                <div class="w-2 h-2 rounded-full bg-red-500/50"></div>
                <div class="w-2 h-2 rounded-full bg-amber-500/50"></div>
                <div class="w-2 h-2 rounded-full bg-green-500/50"></div>
            </div>
        </div>
        <div class="p-lg flex-1 font-data-mono text-sm space-y-lg">
            @if (ViewBag.FacadeResult != null)
            {
                <div class="flex items-center gap-md"><span class="material-symbols-outlined text-green-400">check_circle</span><span class="text-on-surface-variant">✅ BaggageLoadingService.IsCargoLoaded()</span></div>
                <div class="flex items-center gap-md"><span class="material-symbols-outlined text-green-400">check_circle</span><span class="text-on-surface-variant">✅ CrewManagementService.IsCrewReady()</span></div>
                <div class="flex items-center gap-md"><span class="material-symbols-outlined text-green-400">check_circle</span><span class="text-on-surface-variant">✅ ATCService.RequestTakeoffClearance('08R')</span></div>
                <div class="flex items-center gap-md border-l-2 border-cyan-400 pl-lg py-sm bg-cyan-400/5">
                    <span class="material-symbols-outlined text-cyan-400 animate-pulse">flight_takeoff</span>
                    <span class="text-cyan-400 font-bold">🛫 TAROM-301 DEPARTED — Clearance Granted!</span>
                </div>
            }
            else
            {
                <div class="flex items-center gap-md opacity-30"><span class="material-symbols-outlined text-slate-500">radio_button_unchecked</span><span class="text-on-surface-variant">BaggageLoadingService.IsCargoLoaded()</span></div>
                <div class="flex items-center gap-md opacity-30"><span class="material-symbols-outlined text-slate-500">radio_button_unchecked</span><span class="text-on-surface-variant">CrewManagementService.IsCrewReady()</span></div>
                <div class="flex items-center gap-md opacity-30"><span class="material-symbols-outlined text-slate-500">radio_button_unchecked</span><span class="text-on-surface-variant">ATCService.RequestTakeoffClearance('08R')</span></div>
                <div class="flex items-center gap-md opacity-20"><span class="material-symbols-outlined text-slate-500">flight_takeoff</span><span class="text-slate-500">Waiting for authorization...</span></div>
            }
        </div>
        @if (ViewBag.FacadeResult != null)
        {
            <div class="bg-green-600/20 p-md border-t border-green-500/30 flex items-center gap-md">
                <span class="material-symbols-outlined text-green-400">check_circle</span>
                <span class="font-data-mono text-xs text-green-300">FlightDepartureFacade.AuthoriseDeparture() → SUCCESS</span>
            </div>
        }
    </section>
</div>

<footer class="mt-xl glass-card p-lg rounded-lg border-l-4 border-cyan-400">
    <h4 class="font-headline-md text-cyan-400 uppercase">System Architecture Insight</h4>
    <p class="font-body-md text-on-surface mt-2 max-w-4xl">
        The Controller called <span class="font-data-mono" style="color:#FFB300;">ONE</span> method. The Facade handled 3 complex subsystems internally.
        This is the <span class="text-cyan-400 font-bold">Facade Pattern</span>: providing a unified interface to a set of interfaces in a subsystem.
    </p>
</footer>
