@{
    ViewData["Title"] = "Tower Departure Control";
}

<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-100 text-amber-800 text-xs font-bold mb-4 border border-amber-200">
        <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
        RESTRICTED AREA
    </div>
    <h1 class="text-3xl font-bold text-slate-800">Tower Departure Control</h1>
    <p class="text-slate-500 mt-1">Facade Pattern — Single interface orchestrating ATC, Crew, and Baggage subsystems.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
    <!-- LEFT: Departure Form -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-slate-50 px-6 py-5 border-b border-slate-200 flex items-center gap-4">
            <div class="w-12 h-12 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl">flight_takeoff</span>
            </div>
            <div>
                <h3 class="text-lg font-bold text-slate-800">Departure Authorization</h3>
                <p class="text-sm text-slate-500">Initiate takeoff sequence</p>
            </div>
        </div>
        
        <div class="p-6">
            <form action="/Airport/FacadeDemoExecute" method="post" class="space-y-6">
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Flight Number</label>
                        <select name="flightNumber" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 transition outline-none bg-white font-mono text-slate-700">
                            <option value="TAROM-301">TAROM-301 (Bucharest - London)</option>
                            <option value="WIZZ-882">WIZZ-882 (Bucharest - Rome)</option>
                            <option value="LH-1652">LH-1652 (Bucharest - Munich)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Runway</label>
                        <select name="runway" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-200 transition outline-none bg-white font-mono text-slate-700">
                            <option value="08R">Runway 08R (Primary)</option>
                            <option value="08L">Runway 08L (Secondary)</option>
                            <option value="26L">Runway 26L (Heavy Cargo)</option>
                        </select>
                    </div>
                </div>
                
                <button type="submit" class="w-full py-4 bg-amber-500 hover:bg-amber-600 active:bg-amber-700 text-white rounded-xl font-bold tracking-wide transition shadow-lg shadow-amber-500/30 flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">send</span>
                    AUTHORIZE DEPARTURE
                </button>
                
                <div class="flex items-start gap-3 bg-blue-50 p-4 rounded-xl border border-blue-100">
                    <span class="material-symbols-outlined text-blue-500 text-[20px]">info</span>
                    <p class="text-blue-700 text-sm">Controller calls a single method on <code>FlightDepartureFacade</code> which internally coordinates Baggage, Crew, and ATC.</p>
                </div>
            </form>
        </div>
    </div>

    <!-- RIGHT: Execution Log -->
    <div class="bg-slate-900 rounded-2xl shadow-xl border border-slate-700 overflow-hidden flex flex-col min-h-[420px]">
        <div class="bg-slate-800 px-6 py-4 border-b border-slate-700 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-400 text-[18px]">terminal</span>
                <h3 class="text-xs font-bold text-slate-300 uppercase tracking-widest">Departure Sequence Log</h3>
            </div>
            <div class="flex gap-2">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-amber-500"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
            </div>
        </div>
        
        <div class="p-6 flex-1 font-mono text-sm space-y-4">
            @if (ViewBag.FlightLog != null)
            {
                var logs = (List<string>)ViewBag.FlightLog;
                foreach(var log in logs)
                {
                    if (log.Contains("SUCCESS") || log.Contains("Clearance granted"))
                    {
                        <div class="flex items-start gap-3 text-emerald-400">
                            <span class="material-symbols-outlined text-[18px]">check_circle</span>
                            <span>@log</span>
                        </div>
                    }
                    else if (log.Contains("Checking") || log.Contains("Requesting"))
                    {
                        <div class="flex items-start gap-3 text-slate-400">
                            <span class="material-symbols-outlined text-[18px]">pending</span>
                            <span>@log</span>
                        </div>
                    }
                    else
                    {
                        <div class="flex items-start gap-3 text-amber-400">
                            <span class="material-symbols-outlined text-[18px]">arrow_right</span>
                            <span>@log</span>
                        </div>
                    }
                }
                
                <div class="mt-8 p-4 bg-emerald-900/30 border border-emerald-500/30 rounded-lg text-emerald-400 flex items-center gap-3">
                    <span class="material-symbols-outlined animate-pulse">flight_takeoff</span>
                    <strong>@ViewBag.FlightNumber DEPARTED SUCCESSFULLY</strong>
                </div>
            }
            else
            {
                <div class="text-slate-500 italic flex items-center justify-center h-full flex-col gap-4">
                    <span class="material-symbols-outlined text-4xl opacity-50">radar</span>
                    Awaiting authorization command...
                </div>
            }
        </div>
    </div>
</div>
