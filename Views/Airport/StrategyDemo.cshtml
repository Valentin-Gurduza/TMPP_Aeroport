@{
    ViewData["Title"] = "Dynamic Ticket Pricing";
    Layout = "_LayoutSAMS";
}

<header class="border-l-4 pl-lg mb-xl" style="border-color:#3cd7ff;">
    <h1 class="font-headline-lg text-display-xl text-on-surface">Dynamic Pricing Engine</h1>
    <p class="font-body-sm text-on-surface-variant max-w-2xl">Strategy Pattern — Decouples pricing algorithms from the ticket context.</p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-xl items-start">
    <section class="glass-card p-lg rounded-lg shadow-2xl space-y-lg">
        <h3 class="font-headline-md text-cyan-400 border-b border-white/10 pb-sm">Select Pricing Strategy</h3>
        
        <form asp-action="StrategyDemo" method="get" class="space-y-md">
            <div>
                <label class="font-label-caps text-on-surface-variant block mb-1">BASE PRICE (USD)</label>
                <input type="number" name="basePrice" value="@ViewBag.BasePrice" class="w-full bg-[#05070A] border border-white/20 rounded px-3 py-2 text-primary-container focus:border-cyan-400 outline-none transition-colors" />
            </div>
            
            <div>
                <label class="font-label-caps text-on-surface-variant block mb-1">ALGORITHM</label>
                <select name="strategyType" class="w-full bg-[#05070A] border border-white/20 rounded px-3 py-2 text-primary-container focus:border-cyan-400 outline-none transition-colors">
                    @if(ViewBag.SelectedStrategy == "regular") { <option value="regular" selected>Regular Pricing (1x)</option> } else { <option value="regular">Regular Pricing (1x)</option> }
                    @if(ViewBag.SelectedStrategy == "vip") { <option value="vip" selected>VIP Discount (0.8x)</option> } else { <option value="vip">VIP Discount (0.8x)</option> }
                    @if(ViewBag.SelectedStrategy == "lastminute") { <option value="lastminute" selected>Last Minute Surge (1.5x)</option> } else { <option value="lastminute">Last Minute Surge (1.5x)</option> }
                </select>
            </div>

            <button type="submit" class="w-full py-3 bg-cyan-600/20 border border-cyan-500/50 text-cyan-400 font-headline-md rounded hover:bg-cyan-500/30 transition-all">
                CALCULATE PRICE
            </button>
        </form>
    </section>

    <section class="glass-card p-lg rounded-lg shadow-2xl text-center flex flex-col justify-center min-h-[300px]">
        <span class="material-symbols-outlined text-amber-500 text-6xl mb-4">sell</span>
        <h3 class="font-label-caps text-on-surface-variant mb-2">CALCULATED TICKET PRICE</h3>
        <div class="font-display-xl text-5xl text-primary-container glow-cyan">
            $@(((double)ViewBag.FinalPrice).ToString("0.00"))
        </div>
        <p class="text-slate-400 text-sm mt-4">Calculated using: <span class="font-bold text-amber-400">@ViewBag.SelectedStrategy.ToString().ToUpper()</span> Strategy</p>
    </section>
</div>
