@{
    ViewData["Title"] = "Dynamic Ticket Pricing";
}

<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-100 text-indigo-800 text-xs font-bold mb-4 border border-indigo-200">
        <span class="material-symbols-outlined text-[14px] text-indigo-600">calculate</span>
        DYNAMIC PRICING ENGINE
    </div>
    <h1 class="text-3xl font-bold text-slate-800">Dynamic Ticket Pricing</h1>
    <p class="text-slate-500 mt-1">Strategy Pattern — Decouples pricing algorithms from the ticket context.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-indigo-50 px-6 py-4 border-b border-indigo-100 flex items-center gap-3">
            <span class="material-symbols-outlined text-indigo-600">settings</span>
            <h3 class="font-bold text-slate-800 tracking-wide">ALGORITHM SELECTION</h3>
        </div>
        
        <div class="p-6">
            <form action="/Airport/StrategyDemo" method="get" class="space-y-6">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Base Price (USD)</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400 font-bold">$</span>
                        <input type="number" name="basePrice" value="@ViewBag.BasePrice" class="w-full pl-8 pr-4 py-3 rounded-lg border border-slate-300 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition outline-none font-mono text-slate-700 font-bold text-lg" required />
                    </div>
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Pricing Strategy</label>
                    <div class="grid gap-3">
                        <label class="relative flex items-start p-4 cursor-pointer rounded-xl border @(ViewBag.SelectedStrategy == "regular" ? "border-indigo-500 bg-indigo-50" : "border-slate-200 bg-white hover:bg-slate-50") transition">
                            <div class="flex items-center h-5">
                                <input name="strategyType" type="radio" value="regular" class="w-4 h-4 text-indigo-600 border-slate-300 focus:ring-indigo-500" @(ViewBag.SelectedStrategy == "regular" ? "checked" : "")>
                            </div>
                            <div class="ml-3 flex-1 flex justify-between">
                                <div class="text-sm">
                                    <span class="font-medium text-slate-900 block">Regular Pricing</span>
                                    <span class="text-slate-500">Standard rate applies</span>
                                </div>
                                <span class="text-sm font-bold text-indigo-600">1x</span>
                            </div>
                        </label>
                        
                        <label class="relative flex items-start p-4 cursor-pointer rounded-xl border @(ViewBag.SelectedStrategy == "vip" ? "border-indigo-500 bg-indigo-50" : "border-slate-200 bg-white hover:bg-slate-50") transition">
                            <div class="flex items-center h-5">
                                <input name="strategyType" type="radio" value="vip" class="w-4 h-4 text-indigo-600 border-slate-300 focus:ring-indigo-500" @(ViewBag.SelectedStrategy == "vip" ? "checked" : "")>
                            </div>
                            <div class="ml-3 flex-1 flex justify-between">
                                <div class="text-sm">
                                    <span class="font-medium text-slate-900 block">VIP Discount</span>
                                    <span class="text-slate-500">Loyalty member rate</span>
                                </div>
                                <span class="text-sm font-bold text-emerald-600">0.8x</span>
                            </div>
                        </label>
                        
                        <label class="relative flex items-start p-4 cursor-pointer rounded-xl border @(ViewBag.SelectedStrategy == "lastminute" ? "border-indigo-500 bg-indigo-50" : "border-slate-200 bg-white hover:bg-slate-50") transition">
                            <div class="flex items-center h-5">
                                <input name="strategyType" type="radio" value="lastminute" class="w-4 h-4 text-indigo-600 border-slate-300 focus:ring-indigo-500" @(ViewBag.SelectedStrategy == "lastminute" ? "checked" : "")>
                            </div>
                            <div class="ml-3 flex-1 flex justify-between">
                                <div class="text-sm">
                                    <span class="font-medium text-slate-900 block">Last Minute Surge</span>
                                    <span class="text-slate-500">High demand penalty</span>
                                </div>
                                <span class="text-sm font-bold text-red-600">1.5x</span>
                            </div>
                        </label>
                    </div>
                </div>
    
                <button type="submit" class="w-full py-4 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white rounded-xl font-bold tracking-wide transition shadow-lg shadow-indigo-600/30 flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">play_circle</span>
                    COMPUTE FINAL PRICE
                </button>
            </form>
        </div>
    </div>

    <div class="bg-gradient-to-br from-slate-800 to-slate-900 rounded-2xl shadow-xl border border-slate-700 text-center flex flex-col justify-center min-h-[400px] relative overflow-hidden">
        <span class="material-symbols-outlined absolute -right-4 -top-4 text-[150px] opacity-10 text-white">sell</span>
        
        <div class="relative z-10">
            <div class="w-20 h-20 bg-indigo-500/20 rounded-full flex items-center justify-center mx-auto mb-6 border border-indigo-500/30 shadow-[0_0_30px_rgba(99,102,241,0.2)]">
                <span class="material-symbols-outlined text-indigo-400 text-4xl">sell</span>
            </div>
            
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Calculated Ticket Price</h3>
            
            <div class="text-6xl font-black text-white tracking-tighter mb-4 drop-shadow-[0_0_15px_rgba(255,255,255,0.2)]">
                $@(((double)ViewBag.FinalPrice).ToString("0.00"))
            </div>
            
            <div class="inline-flex items-center gap-2 bg-black/30 border border-white/10 px-4 py-2 rounded-full text-sm text-slate-300">
                <span>Calculated using</span>
                <span class="font-bold text-indigo-400">@ViewBag.SelectedStrategy.ToString().ToUpper()</span>
                <span>Strategy</span>
            </div>
        </div>
    </div>
</div>
