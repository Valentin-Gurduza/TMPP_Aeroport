            <span class="material-symbols-outlined text-cyan-400 text-3xl group-hover:scale-110 transition-transform">event_note</span>
            <span class="font-['Space_Grotesk'] text-[10px] text-slate-500 border border-slate-700 px-2 py-0.5 rounded">LAB 3</span>
        </div>
        <div class="mt-4">
            <h3 class="font-headline-md text-on-surface group-hover:text-cyan-400 transition-colors">Itinerary Planner</h3>
            <p class="text-xs font-['Space_Grotesk'] text-slate-400 uppercase tracking-widest mt-1">Builder Pattern</p>
        </div>
    </a>

    <!-- Card 3: Prototype -->
