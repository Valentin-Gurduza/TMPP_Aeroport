<!-- Live Airspace Section -->
<div class="mt-xl grid grid-cols-1 lg:grid-cols-3 gap-lg">
    <div class="lg:col-span-2 glass-card h-[300px] relative overflow-hidden flex items-center justify-center bg-black/40">
        <div class="absolute inset-0 radar-grid opacity-30"></div>
        <div class="absolute inset-0 flex items-center justify-center">
            <div class="absolute w-[450px] h-[450px] radar-sweep opacity-30 animate-[spin_4s_linear_infinite]"></div>
        </div>
        <div class="relative z-10 flex flex-col items-center text-center p-xl">
            <span class="material-symbols-outlined text-cyan-500 text-6xl mb-4 animate-pulse">radar</span>
            <h2 class="text-headline-lg font-headline-lg text-primary-container">Live Airspace Monitoring</h2>
            <p class="text-body-md text-on-surface-variant max-w-md mt-4">Real-time telemetry and flight path prediction active. Proxy and Flyweight patterns managing data flow across the terminal cluster.</p>
        </div>
    </div>

    <div class="glass-card p-lg flex flex-col">
        <h3 class="font-headline-md text-primary-container mb-md border-b border-white/10 pb-sm">Pattern Health Indicators</h3>
        <div class="space-y-md">
            <div>
                <div class="flex justify-between items-center mb-1">
                    <span class="text-body-sm font-['Space_Grotesk'] uppercase text-slate-400">Singleton Instance</span>
                    <span class="text-cyan-400 font-bold text-xs tracking-widest">ACTIVE [0x01]</span>
                </div>
                <div class="w-full bg-white/5 h-1 rounded-full overflow-hidden">
                    <div class="bg-cyan-500 h-full w-[98%] shadow-[0_0_10px_rgba(0,212,255,0.8)]"></div>
                </div>
            </div>
            <div>
                <div class="flex justify-between items-center mb-1">
                    <span class="text-body-sm font-['Space_Grotesk'] uppercase text-slate-400">Flyweight Cache</span>
                    <span class="text-cyan-400 font-bold text-xs tracking-widest">2 MODELS / 50K BLIPS</span>
                </div>
                <div class="w-full bg-white/5 h-1 rounded-full overflow-hidden">
                    <div class="bg-cyan-500 h-full w-[100%] shadow-[0_0_10px_rgba(0,212,255,0.8)]"></div>
                </div>
            </div>
            <div>
                <div class="flex justify-between items-center mb-1">
                    <span class="text-body-sm font-['Space_Grotesk'] uppercase text-slate-400">Proxy Security</span>
                    <span class="text-cyan-400 font-bold text-xs tracking-widest">2.4ms NOMINAL</span>
                </div>
                <div class="w-full bg-white/5 h-1 rounded-full overflow-hidden">
                    <div class="bg-cyan-500 h-full w-[85%] shadow-[0_0_10px_rgba(0,212,255,0.8)]"></div>
                </div>
            </div>
        </div>
        <div class="mt-auto pt-lg">
            <a asp-controller="Airport" asp-action="SingletonDemo" class="block w-full py-3 bg-primary-container text-on-primary-container font-['Space_Grotesk'] font-bold text-xs tracking-widest uppercase text-center hover:shadow-[0_0_20px_rgba(0,212,255,0.4)] transition-all rounded">
                View System Logs (Singleton)
            </a>
        </div>
    </div>
</div>
