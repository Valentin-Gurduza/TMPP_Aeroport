            <span class="material-symbols-outlined text-cyan-400 text-3xl group-hover:scale-110 transition-transform">content_copy</span>
            <span class="font-['Space_Grotesk'] text-[10px] text-slate-500 border border-slate-700 px-2 py-0.5 rounded">LAB 3</span>
