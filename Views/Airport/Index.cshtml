@{
    ViewData["Title"] = "Control Center";
    Layout = "_LayoutSAMS";
}

<!-- Header HUD -->
<div class="mb-xl flex justify-between items-end">
    <div>
        <h1 class="font-display-xl text-display-xl text-primary-container tracking-tight">Control Center</h1>
        <div class="flex items-center gap-2 mt-2">
            <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
            <p class="font-body-md text-on-surface-variant opacity-80">Design Patterns: Lab 2-5 Active</p>
        </div>
    </div>
    <div class="flex gap-sm">
        <div class="glass-card px-4 py-2 flex items-center gap-3">
            <span class="text-xs font-['Space_Grotesk'] text-slate-400 uppercase tracking-tighter">System Status</span>
            <span class="px-2 py-0.5 rounded-full bg-cyan-500/10 text-cyan-400 text-[10px] font-bold border border-cyan-500/30">ONLINE</span>
        </div>
        <div class="glass-card px-4 py-2 flex items-center gap-3">
            <span class="text-xs font-['Space_Grotesk'] text-slate-400 uppercase tracking-tighter">Latency</span>
            <span class="font-['Space_Grotesk'] text-[10px] text-cyan-400">14MS</span>
        </div>
    </div>
</div>

<!-- Module Cards Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-md">

    <!-- Card 1: Check-In -->
    <a asp-controller="Airport" asp-action="CheckIn" class="glass-card p-6 flex flex-col justify-between group cursor-pointer min-h-[180px] no-underline">
        <div class="flex justify-between items-start">
            <span class="material-symbols-outlined text-cyan-400 text-3xl group-hover:scale-110 transition-transform">how_to_reg</span>
            <span class="font-['Space_Grotesk'] text-[10px] text-slate-500 border border-slate-700 px-2 py-0.5 rounded">LAB 2</span>
        </div>
        <div class="mt-4">
            <h3 class="font-headline-md text-on-surface group-hover:text-cyan-400 transition-colors">Check-In Terminal</h3>
            <p class="text-xs font-['Space_Grotesk'] text-slate-400 uppercase tracking-widest mt-1">Abstract Factory</p>
        </div>
    </a>

    <!-- Card 2: Itinerary Builder -->
    <a asp-controller="Airport" asp-action="BuilderDemo" class="glass-card p-6 flex flex-col justify-between group cursor-pointer min-h-[180px] no-underline">
