@using TMPP_Aeroport.Domain.Entities
@model dynamic

@{
    ViewData["Title"] = "Smart Airport Dashboard";
}

<div class="text-center">
    <h1 class="display-4">Smart Airport Management</h1>
    <p>Laborator 1: Implementare OOP & SOLID</p>
</div>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12 text-center d-flex justify-content-center gap-2 flex-wrap">
            <a href="@Url.Action("CheckIn", "Airport")" class="btn btn-outline-success">
                🧳 Lab 2: Check-In (Abstract Factory)
            </a>
            <a href="@Url.Action("BuilderDemo", "Airport")" class="btn btn-primary">
                🎫 Lab 3: Flight Itinerary (Builder)
            </a>
            <a href="@Url.Action("PrototypeDemo", "Airport")" class="btn btn-warning text-dark">
                ✈️ Lab 3: Clone Flights (Prototype)
            </a>
            <a href="@Url.Action("SingletonDemo", "Airport")" class="btn btn-dark">
                📋 Lab 3: System Logs (Singleton)
            </a>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-12 text-center d-flex justify-content-center gap-2 flex-wrap">
            <a href="@Url.Action("AdapterDemo", "Airport")" class="btn btn-info">
                🌤️ Lab 4: Vremea (Adapter)
            </a>
            <a href="@Url.Action("CompositeDemo", "Airport")" class="btn btn-secondary">
                📦 Lab 4: Sistem Bagaje (Composite)
            </a>
            <a href="@Url.Action("FacadeDemo", "Airport")" class="btn btn-danger text-white">
                🛫 Lab 4: Controale Decolare (Facade)
            </a>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-12 text-center d-flex justify-content-center gap-2 flex-wrap">
            <a href="@Url.Action("FlyweightDemo", "Airport")" class="btn btn-outline-primary">
                🪶 Lab 5: Radar (Flyweight)
            </a>
            <a href="@Url.Action("DecoratorDemo", "Airport")" class="btn btn-primary">
                🔔 Lab 5: Notificări (Decorator)
            </a>
            <a href="@Url.Action("BridgeDemo", "Airport")" class="btn btn-warning text-dark">
                📺 Lab 5: Afișaje (Bridge)
            </a>
            <a href="@Url.Action("ProxyDemo", "Airport")" class="btn btn-danger">
                🛡️ Lab 5: Securitate Pistă (Proxy)
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <h3>Zboruri (SRP: Doar datele despre zbor)</h3>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Nr Zbor</th>
                        <th>Origine</th>
                        <th>Destinație</th>
                        <th>Plecare</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Flight flight in Model.Flights)
                    {
                        <tr>
                            <td>@flight.FlightNumber</td>
                            <td>@flight.Origin</td>
                            <td>@flight.Destination</td>
                            <td>@flight.DepartureTime.ToString("g")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="col-md-6">
            <h3>Flotă Aeriană (Polimorfism)</h3>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Model</th>
                        <th>Nr. Înreg.</th>
                        <th>Tip</th>
                        <th>Detalii</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (Aircraft aircraft in Model.Aircrafts)
                    {
                        <tr>
                            <td>@aircraft.Model</td>
                            <td>@aircraft.RegistrationNumber</td>
                            <td>@aircraft.GetAircraftType()</td>
                            <td>
                                @if (aircraft is PassengerPlane pp)
                                {
                                    <span>Cap: @pp.PassengerCapacity pax</span>
                                }
                                else if (aircraft is CargoPlane cp)
                                {
                                    <span>Max Load: @cp.MaxCargoWeightKg kg</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
