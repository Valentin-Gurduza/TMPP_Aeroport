@{
    ViewData["Title"] = "Flight Schedule Cloner";
    Layout = "_LayoutSAMS";
}
<header class="mb-xl">
    <h1 class="font-headline-lg text-display-xl text-on-surface">Flight Schedule Cloner</h1>
    <p class="font-body-md text-on-surface-variant mt-1">Prototype Pattern — Cloning <span class="text-cyan-400 font-data-mono">FlightSchedule</span> objects via <span class="text-cyan-400 font-data-mono">IClonable.Clone()</span></p>
</header>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-xl">
    <!-- Original Flight -->
    <section>
        <h3 class="font-label-caps text-slate-400 mb-md flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-cyan-400">source</span>
            ORIGINAL FLIGHT SCHEDULE
        </h3>
        <div class="glass-card p-lg border-l-4 border-cyan-400 space-y-md">
            <div class="grid grid-cols-2 gap-md">
                <div>
                    <p class="text-[10px] font-label-caps text-slate-500">FLIGHT ID</p>
                    <p class="font-data-mono text-white text-lg">@(ViewBag.OriginalFlight?.FlightId ?? "RO-302")</p>
                </div>
                <div>
                    <p class="text-[10px] font-label-caps text-slate-500">DESTINATION</p>
                    <p class="font-data-mono text-white text-lg">@(ViewBag.OriginalFlight?.Destination ?? "LONDON LHR")</p>
                </div>
                <div>
                    <p class="text-[10px] font-label-caps text-slate-500">DEPARTURE</p>
                    <p class="font-data-mono text-cyan-400">@(ViewBag.OriginalFlight?.DepartureTime ?? "09:15")</p>
                </div>
                <div>
                    <p class="text-[10px] font-label-caps text-slate-500">AIRCRAFT</p>
                    <p class="font-data-mono text-cyan-400">@(ViewBag.OriginalFlight?.Aircraft ?? "Boeing 737-800")</p>
                </div>
            </div>
            <div class="font-data-mono text-[10px] text-slate-500 bg-black/30 p-3 rounded border border-white/5">
                Memory Address: 0x@(ViewBag.OriginalFlight?.ObjectId ?? "1A2B3C4D")
            </div>
        </div>
        <div class="mt-lg">
            <a asp-controller="Airport" asp-action="PrototypeDemo" class="w-full py-4 bg-primary-container text-on-primary-fixed font-headline-md flex items-center justify-center gap-2 hover:brightness-110 transition-all">
                <span class="material-symbols-outlined">content_copy</span>
                CLONE FLIGHT SCHEDULE
            </a>
        </div>
    </section>

    <!-- Cloned Flight -->
    <section>
        <h3 class="font-label-caps text-slate-400 mb-md flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-green-400">file_copy</span>
            CLONED FLIGHT SCHEDULE
        </h3>
        @if (ViewBag.ClonedFlight != null)
        {
            <div class="glass-card p-lg border-l-4 border-green-400 space-y-md">
                <div class="grid grid-cols-2 gap-md">
                    <div>
                        <p class="text-[10px] font-label-caps text-slate-500">FLIGHT ID</p>
                        <p class="font-data-mono text-white text-lg">@ViewBag.ClonedFlight.FlightId</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-label-caps text-slate-500">DESTINATION</p>
                        <p class="font-data-mono text-white text-lg">@ViewBag.ClonedFlight.Destination</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-label-caps text-slate-500">DEPARTURE</p>
                        <p class="font-data-mono text-green-400">@ViewBag.ClonedFlight.DepartureTime</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-label-caps text-slate-500">AIRCRAFT</p>
                        <p class="font-data-mono text-green-400">@ViewBag.ClonedFlight.Aircraft</p>
                    </div>
                </div>
                <div class="font-data-mono text-[10px] text-slate-500 bg-black/30 p-3 rounded border border-white/5">
                    Memory Address: 0x@ViewBag.ClonedFlight.ObjectId <span class="text-orange-400 ml-4">← NEW OBJECT (Deep Copy)</span>
                </div>
            </div>
        }
        else
        {
            <div class="glass-card p-lg border border-dashed border-white/20 flex flex-col items-center justify-center h-48 text-center opacity-40">
                <span class="material-symbols-outlined text-slate-500 text-5xl mb-3">content_copy</span>
                <p class="font-body-sm text-slate-500">Click CLONE FLIGHT SCHEDULE to create a deep copy</p>
            </div>
        }
    </section>
</div>

<!-- Prototype Explanation -->
<div class="mt-xl glass-card p-lg border border-white/10">
    <h3 class="font-headline-md text-cyan-400 mb-md">Prototype Pattern: Why Deep Copy Matters</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-lg">
        <div class="space-y-sm">
            <div class="w-8 h-8 rounded-full bg-cyan-400/20 border border-cyan-400/30 flex items-center justify-center">
                <span class="material-symbols-outlined text-cyan-400 text-sm">call_split</span>
            </div>
            <h4 class="font-headline-md text-sm text-on-surface">IFlightSchedule.Clone()</h4>
            <p class="font-body-sm text-slate-400">The interface declares a Clone() method that all concrete schedules must implement.</p>
        </div>
        <div class="space-y-sm">
            <div class="w-8 h-8 rounded-full bg-orange-400/20 border border-orange-400/30 flex items-center justify-center">
                <span class="material-symbols-outlined text-orange-400 text-sm">memory</span>
            </div>
            <h4 class="font-headline-md text-sm text-on-surface">New Memory Address</h4>
            <p class="font-body-sm text-slate-400">Each clone has a different address — modifying it won't affect the original object.</p>
        </div>
        <div class="space-y-sm">
            <div class="w-8 h-8 rounded-full bg-green-400/20 border border-green-400/30 flex items-center justify-center">
                <span class="material-symbols-outlined text-green-400 text-sm">speed</span>
            </div>
            <h4 class="font-headline-md text-sm text-on-surface">Performance Benefit</h4>
            <p class="font-body-sm text-slate-400">Cloning avoids expensive initialization, reusing existing validated state as a template.</p>
        </div>
    </div>
</div>
