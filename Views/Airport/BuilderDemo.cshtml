@{
    ViewData["Title"] = "Itinerary Planner";
}

<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold mb-4 border border-blue-200">
        <span class="material-symbols-outlined text-[14px]">map</span>
        ITINERARY PLANNER
    </div>
    <h1 class="text-3xl font-bold text-slate-800">Flight Itinerary Planner</h1>
    <p class="text-slate-500 mt-1">Builder Pattern — Constructing complex <span class="font-mono bg-slate-100 text-blue-600 px-2 py-0.5 rounded text-sm">FlightItinerary</span> objects step-by-step via director</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
    <!-- Builder Form -->
    <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center gap-3">
            <span class="material-symbols-outlined text-blue-600">build</span>
            <h3 class="font-bold text-slate-800 tracking-wide uppercase">Build Itinerary</h3>
        </div>
        
        <div class="p-6">
            <form action="/Airport/BuilderDemo" method="get" class="space-y-5">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Passenger Name</label>
                    <input name="passengerName" type="text" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" value="@(ViewBag.PassengerName ?? "Ion Ionescu")" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Departure</label>
                    <input name="departure" type="text" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" value="@(ViewBag.Departure ?? "OTP - Bucharest")" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Destination</label>
                    <input name="destination" type="text" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" value="@(ViewBag.Destination ?? "CDG - Paris")" />
                </div>
                
                <div class="pt-4 border-t border-slate-200 space-y-3">
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <div class="relative flex items-center">
                            <input type="checkbox" checked class="w-5 h-5 border-slate-300 rounded text-blue-600 focus:ring-blue-500" />
                        </div>
                        <span class="text-sm font-medium text-slate-700 group-hover:text-blue-600 transition">Include Hotel Transfer</span>
                    </label>
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <div class="relative flex items-center">
                            <input type="checkbox" class="w-5 h-5 border-slate-300 rounded text-blue-600 focus:ring-blue-500" />
                        </div>
                        <span class="text-sm font-medium text-slate-700 group-hover:text-blue-600 transition">Include Airport Lounge</span>
                    </label>
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <div class="relative flex items-center">
                            <input type="checkbox" checked class="w-5 h-5 border-slate-300 rounded text-blue-600 focus:ring-blue-500" />
                        </div>
                        <span class="text-sm font-medium text-slate-700 group-hover:text-blue-600 transition">Include Meal Plan</span>
                    </label>
                </div>
                
                <button type="submit" class="w-full mt-4 py-3.5 bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white rounded-xl font-bold tracking-wide transition shadow-lg shadow-blue-600/30 flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">construction</span>
                    BUILD ITINERARY
                </button>
            </form>
        </div>
    </div>

    <!-- Result / Steps Display -->
    <div class="lg:col-span-3 space-y-6">
        <!-- Generated Itinerary Card -->
        <div class="bg-gradient-to-r from-blue-600 to-indigo-700 rounded-2xl p-6 shadow-lg shadow-blue-900/20 text-white relative overflow-hidden">
            <span class="material-symbols-outlined absolute -right-4 -bottom-4 text-[120px] opacity-10">map</span>
            <div class="flex items-center justify-between mb-6 relative z-10 border-b border-white/20 pb-4">
                <h3 class="font-bold text-lg">Generated Itinerary</h3>
                <span class="font-mono text-xs bg-white/20 border border-white/30 px-3 py-1 rounded-full text-white backdrop-blur-sm shadow-inner">ID: 0x@(new Random().Next(1000, 9999))</span>
            </div>
            
            <div class="grid grid-cols-2 gap-6 relative z-10">
                <div class="space-y-4">
                    <div class="flex gap-3 bg-black/10 p-3 rounded-xl border border-white/10">
                        <span class="material-symbols-outlined text-blue-200">person</span>
                        <div>
                            <p class="text-[10px] text-blue-200 font-bold uppercase tracking-wider">Passenger</p>
                            <p class="font-bold">@(ViewBag.PassengerName ?? "Ion Ionescu")</p>
                        </div>
                    </div>
                    <div class="flex gap-3 bg-black/10 p-3 rounded-xl border border-white/10">
                        <span class="material-symbols-outlined text-blue-200">flight_takeoff</span>
                        <div>
                            <p class="text-[10px] text-blue-200 font-bold uppercase tracking-wider">Route</p>
                            <p class="font-bold">@(ViewBag.Departure ?? "OTP") &rarr; @(ViewBag.Destination ?? "CDG")</p>
                        </div>
                    </div>
                </div>
                <div class="space-y-4">
                    <div class="flex gap-3 bg-emerald-500/20 p-3 rounded-xl border border-emerald-500/30">
                        <span class="material-symbols-outlined text-emerald-300">hotel</span>
                        <div>
                            <p class="text-[10px] text-emerald-200 font-bold uppercase tracking-wider">Hotel Transfer</p>
                            <p class="font-bold text-emerald-300 text-sm">INCLUDED ✓</p>
                        </div>
                    </div>
                    <div class="flex gap-3 bg-emerald-500/20 p-3 rounded-xl border border-emerald-500/30">
                        <span class="material-symbols-outlined text-emerald-300">restaurant</span>
                        <div>
                            <p class="text-[10px] text-emerald-200 font-bold uppercase tracking-wider">Meal Plan</p>
                            <p class="font-bold text-emerald-300 text-sm">INCLUDED ✓</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Builder Steps -->
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200">
            <div class="flex items-center gap-3 mb-6">
                <span class="material-symbols-outlined text-blue-600">schema</span>
                <h3 class="font-bold text-slate-800">Construction Steps (Director Pattern)</h3>
            </div>
            
            <div class="space-y-3 font-mono text-sm">
                @if (ViewBag.BuilderSteps != null)
                {
                    int step = 1;
                    foreach (var s in (List<string>)ViewBag.BuilderSteps)
                    {
                        <div class="flex items-center gap-4 p-3 bg-slate-50 border border-slate-200 rounded-lg shadow-sm">
                            <span class="text-blue-600 font-bold w-6 text-center">@step.</span>
                            <span class="text-slate-700 flex-1">@s</span>
                            <span class="material-symbols-outlined text-emerald-500 text-[18px]">check_circle</span>
                        </div>
                        step++;
                    }
                }
                else
                {
                    <div class="flex items-center gap-4 p-3 bg-slate-50 border border-slate-200 rounded-lg shadow-sm">
                        <span class="text-blue-600 font-bold w-6 text-center">1.</span>
                        <span class="text-slate-700 flex-1">builder.SetPassenger("Ion Ionescu")</span>
                        <span class="material-symbols-outlined text-emerald-500 text-[18px]">check_circle</span>
                    </div>
                    <div class="flex items-center gap-4 p-3 bg-slate-50 border border-slate-200 rounded-lg shadow-sm">
                        <span class="text-blue-600 font-bold w-6 text-center">2.</span>
                        <span class="text-slate-700 flex-1">builder.SetRoute("OTP", "CDG")</span>
                        <span class="material-symbols-outlined text-emerald-500 text-[18px]">check_circle</span>
                    </div>
                    <div class="flex items-center gap-4 p-3 bg-slate-50 border border-slate-200 rounded-lg shadow-sm">
                        <span class="text-blue-600 font-bold w-6 text-center">3.</span>
                        <span class="text-slate-700 flex-1">builder.AddHotelTransfer()</span>
                        <span class="material-symbols-outlined text-emerald-500 text-[18px]">check_circle</span>
                    </div>
                    <div class="flex items-center gap-4 p-3 bg-slate-50 border border-slate-200 rounded-lg shadow-sm">
                        <span class="text-blue-600 font-bold w-6 text-center">4.</span>
                        <span class="text-slate-700 flex-1">builder.AddMealPlan()</span>
                        <span class="material-symbols-outlined text-emerald-500 text-[18px]">check_circle</span>
                    </div>
                    <div class="flex items-center gap-4 p-4 mt-4 border border-emerald-200 bg-emerald-50 rounded-lg shadow-sm">
                        <span class="material-symbols-outlined text-emerald-600 animate-pulse text-[20px]">construction</span>
                        <span class="text-emerald-700 font-bold">director.Construct() &rarr; FlightItinerary Generated ✓</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
