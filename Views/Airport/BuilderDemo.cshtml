@model TMPP_Aeroport.Domain.Builder.FlightItinerary

@{
    ViewData["Title"] = "Demonstrație: Builder Pattern";
}

<div class="container mt-5">
    <h2 class="mb-4 text-primary">🎫 Construire Itinerar (Builder Pattern)</h2>
    
    <div class="alert alert-info">
        <strong>Cum funcționează?</strong> Obiectul <code>FlightItinerary</code> are o mulțime de atribute. În loc să folosim un constructor imens greu de citit, am folosit un <code>ItineraryDirector</code> și un <code>IItineraryBuilder</code> pentru a construi treptat obiectul final, respectând reguli specifice pentru clasa Economy sau Business.
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <form method="get" action="@Url.Action("BuilderDemo", "Airport")" class="d-flex align-items-center gap-3">
                <label class="fw-bold">Alege varianta:</label>
                <select name="type" class="form-select w-auto">
                    <option value="Economy" selected="@(Model.TicketType == "Economy" ? "selected" : null)">Clasa Economy</option>
                    <option value="Business" selected="@(Model.TicketType == "Business Class" ? "selected" : null)">Business Class</option>
                </select>
                <input type="text" name="passengerName" value="@Model.PassengerName" class="form-control w-auto" placeholder="Nume Pasager" />
                <button type="submit" class="btn btn-primary">Construiește Itinerar</button>
            </form>
        </div>
    </div>

    <!-- Afișarea Produsului Complex (Complex Product) -->
    <div class="card shadow">
        <div class="card-header bg-@(Model.TicketType == "Economy" ? "secondary text-white" : "warning text-dark")">
            <h4 class="mb-0">Itinerar Generat: @Model.PassengerName</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <ul class="list-group">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Tip Bilet
                            <span class="badge bg-primary rounded-pill">@Model.TicketType</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Loc Atribuit
                            <span class="badge bg-info text-dark rounded-pill">@Model.SeatAssigned</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Bagaje Cală
                            <span class="badge bg-success rounded-pill">@Model.CheckedBags</span>
                        </li>
                    </ul>
                </div>
                <div class="col-md-6">
                     <ul class="list-group">
                        <li class="list-group-item">
                            <strong>Meniu:</strong> @(Model.Meals.Count > 0 ? string.Join(", ", Model.Meals) : "Fără")
                        </li>
                        <li class="list-group-item text-@(Model.HasPriorityBoarding ? "success bg-success-subtle" : "danger bg-danger-subtle")">
                            <strong>Priority Boarding:</strong> @(Model.HasPriorityBoarding ? "Inclus" : "Neinclus")
                        </li>
                        <li class="list-group-item text-@(Model.HasLoungeAccess ? "success bg-success-subtle" : "danger bg-danger-subtle")">
                            <strong>Lounge Access:</strong> @(Model.HasLoungeAccess ? "Inclus" : "Neinclus")
                        </li>
                     </ul>
                </div>
            </div>
            
            <div class="mt-4 p-3 bg-light border rounded">
                <h5>Text Summary (Generated by Builder):</h5>
                <pre class="mb-0">@Model.GetItinerarySummary()</pre>
            </div>
        </div>
    </div>
</div>
