@model List<TMPP_Aeroport.Domain.Builder.FlightItinerary>
@{
    ViewData["Title"] = "Itinerary Planner";
}

<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold mb-4 border border-blue-200">
        <span class="material-symbols-outlined text-[14px]">map</span>
        ITINERARY PLANNER & PROTOTYPE
    </div>
    <h1 class="text-3xl font-bold text-slate-800">Flight Itinerary Planner</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-6 p-4 bg-emerald-100 border border-emerald-300 text-emerald-800 rounded-xl flex items-start gap-3 shadow-sm animate-fadeIn">
        <span class="material-symbols-outlined text-emerald-600 mt-0.5 text-[24px]">check_circle</span>
        <div>
            <p class="font-bold text-emerald-950">Package Ticket Booked Successfully!</p>
            <p class="text-sm text-emerald-800 mt-0.5">@TempData["SuccessMessage"]</p>
            <div class="mt-3">
                <a asp-controller="Tickets" asp-action="MyTickets" class="inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1.5 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition">
                    <span class="material-symbols-outlined text-[14px]">confirmation_number</span> View My Tickets
                </a>
            </div>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="mb-6 p-4 bg-red-100 border border-red-300 text-red-800 rounded-xl flex items-center gap-3 shadow-sm animate-fadeIn">
        <span class="material-symbols-outlined text-red-600 text-[24px]">error</span>
        <div>
            <p class="font-bold">Error Booking Ticket</p>
            <p class="text-sm">@TempData["Error"]</p>
        </div>
    </div>
}

<div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
    <!-- Builder Form -->
    <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center gap-3">
            <span class="material-symbols-outlined text-blue-600">build</span>
            <h3 class="font-bold text-slate-800 tracking-wide uppercase">Configure Package</h3>
        </div>
        
        <div class="p-6">
            <form action="/Airport/BuilderDemo" method="get" class="space-y-5">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Passenger Name</label>
                    <input name="passengerName" type="text" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none" value="@(Model?.FirstOrDefault()?.PassengerName ?? "Ion Ionescu")" required />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Select Active Flight</label>
                    <select name="flightId" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none">
                        @if (ViewBag.Flights != null)
                        {
                            foreach (var f in (List<TMPP_Aeroport.Models.Flight>)ViewBag.Flights)
                            {
                                <option value="@f.Id" selected="@(ViewBag.SelectedFlightId == f.Id)">@f.FlightNumber to @f.Destination (@f.DepartureTime.ToString("dd MMM HH:mm"))</option>
                            }
                        }
                        else
                        {
                            <option value="">No active flights available</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Ticket Class (Director Type)</label>
                    <select name="packageType" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none">
                        <option value="economy" selected="@(ViewBag.PackageType == "economy")">Economy Package (Standard perks)</option>
                        <option value="business" selected="@(ViewBag.PackageType == "business")">Business Package (VIP perks)</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Action Type</label>
                    <select name="actionType" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none">
                        <option value="full" selected="@(ViewBag.ActionType == "full")">Standard Booking</option>
                        <option value="no_baggage" selected="@(ViewBag.ActionType == "no_baggage")">No Baggage Itinerary</option>
                        <option value="group" selected="@(ViewBag.ActionType == "group")">Group Booking (Clone Prototype)</option>
                    </select>
                </div>
                
                <div class="pt-4 border-t border-slate-200 space-y-3">
                    <p class="text-xs text-slate-500 leading-relaxed">
                        <span class="font-bold text-slate-700">How Prototype Works:</span> Group booking clones the base complex object instantly using <code>ICloneable</code> without calling the complex Builder construction again!
                    </p>
                </div>
                
                <button type="submit" class="w-full mt-4 py-3.5 bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white rounded-xl font-bold tracking-wide transition shadow-lg shadow-blue-600/30 flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">construction</span>
                    PREVIEW ITINERARY
                </button>
            </form>
        </div>
    </div>

    <!-- Result / Steps Display -->
    <div class="lg:col-span-3 space-y-6">
        @if (Model != null)
        {
            @foreach (var itinerary in Model)
            {
                <!-- Generated Itinerary Card -->
                <div class="bg-gradient-to-r from-blue-600 to-indigo-700 rounded-2xl p-6 shadow-lg shadow-blue-900/20 text-white relative overflow-hidden">
                    <span class="material-symbols-outlined absolute -right-4 -bottom-4 text-[120px] opacity-10">map</span>
                    <div class="flex items-center justify-between mb-6 relative z-10 border-b border-white/20 pb-4">
                        <div>
                            <h3 class="font-bold text-lg">Travel Package Card (@(itinerary.TicketType.Contains("Business") ? "Business Class" : "Economy"))</h3>
                            <p class="text-xs text-blue-200 mt-0.5">Route: @ViewBag.Destination</p>
                        </div>
                        <span class="font-mono text-xs bg-white/20 border border-white/30 px-3 py-1 rounded-full text-white backdrop-blur-sm shadow-inner">STATUS: READY TO ISSUE</span>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative z-10 mb-6">
                        <div class="space-y-4">
                            <div class="flex gap-3 bg-black/10 p-3 rounded-xl border border-white/10">
                                <span class="material-symbols-outlined text-blue-200">person</span>
                                <div>
                                    <p class="text-[10px] text-blue-200 font-bold uppercase tracking-wider">Passenger Name</p>
                                    <p class="font-bold">@itinerary.PassengerName</p>
                                </div>
                            </div>
                            <div class="flex gap-3 bg-black/10 p-3 rounded-xl border border-white/10">
                                <span class="material-symbols-outlined text-blue-200">event_seat</span>
                                <div>
                                    <p class="text-[10px] text-blue-200 font-bold uppercase tracking-wider">Seat & Checked Bags</p>
                                    <p class="font-bold text-sm">@itinerary.SeatAssigned</p>
                                    <p class="text-xs text-blue-200">Allowance: @itinerary.CheckedBags Checked Bags</p>
                                </div>
                            </div>
                        </div>
                        <div class="space-y-4">
                            <div class="flex gap-3 @(itinerary.HasPriorityBoarding ? "bg-emerald-500/20 border-emerald-500/30" : "bg-slate-500/20 border-slate-500/30") p-3 rounded-xl border">
                                <span class="material-symbols-outlined @(itinerary.HasPriorityBoarding ? "text-emerald-300" : "text-slate-400")">speed</span>
                                <div>
                                    <p class="text-[10px] @(itinerary.HasPriorityBoarding ? "text-emerald-200" : "text-slate-400") font-bold uppercase tracking-wider">Priority Boarding</p>
                                    <p class="font-bold @(itinerary.HasPriorityBoarding ? "text-emerald-300" : "text-slate-400") text-sm">@(itinerary.HasPriorityBoarding ? "INCLUDED ✓" : "NOT INCLUDED ✗")</p>
                                </div>
                            </div>
                            <div class="flex gap-3 @(itinerary.Meals.Any() ? "bg-emerald-500/20 border-emerald-500/30" : "bg-slate-500/20 border-slate-500/30") p-3 rounded-xl border">
                                <span class="material-symbols-outlined @(itinerary.Meals.Any() ? "text-emerald-300" : "text-slate-400")">restaurant</span>
                                <div>
                                    <p class="text-[10px] @(itinerary.Meals.Any() ? "text-emerald-200" : "text-slate-400") font-bold uppercase tracking-wider">Meal Plan</p>
                                    <p class="font-bold @(itinerary.Meals.Any() ? "text-emerald-300" : "text-slate-400") text-sm">@(itinerary.Meals.Any() ? string.Join(", ", itinerary.Meals) : "NOT INCLUDED ✗")</p>
                                </div>
                            </div>
                            <div class="flex gap-3 @(itinerary.HasLoungeAccess ? "bg-amber-500/20 border-amber-500/30" : "bg-slate-500/20 border-slate-500/30") p-3 rounded-xl border">
                                <span class="material-symbols-outlined @(itinerary.HasLoungeAccess ? "text-amber-300" : "text-slate-400")">weekend</span>
                                <div>
                                    <p class="text-[10px] @(itinerary.HasLoungeAccess ? "text-amber-200" : "text-slate-400") font-bold uppercase tracking-wider">Lounge Access</p>
                                    <p class="font-bold @(itinerary.HasLoungeAccess ? "text-amber-300" : "text-slate-400") text-sm">@(itinerary.HasLoungeAccess ? "INCLUDED ✓" : "NOT INCLUDED ✗")</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="relative z-10 pt-4 border-t border-white/20 flex flex-col sm:flex-row items-center justify-between gap-4">
                        <div>
                            <span class="text-xs text-blue-200 block uppercase tracking-wider font-bold">Class Pricing</span>
                            <span class="text-3xl font-black">@(itinerary.TicketType.Contains("Business") ? "€450" : "€150")</span>
                        </div>
                    </div>
                </div>
            }
            <div class="mt-4 text-right">
                <form action="/Airport/BookItinerary" method="post" class="inline-block">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="packageType" value="@ViewBag.PackageType" />
                    <input type="hidden" name="actionType" value="@ViewBag.ActionType" />
                    <input type="hidden" name="flightId" value="@ViewBag.SelectedFlightId" />
                    <input type="hidden" name="passengerName" value="@ViewBag.PassengerName" />
                    <button type="submit" class="px-6 py-3.5 bg-emerald-600 text-white font-bold rounded-xl shadow-lg hover:bg-emerald-700 transition active:scale-95 flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">shopping_cart</span>
                        <span>BOOK ALL PACKAGES</span>
                    </button>
                </form>
            </div>
        }

        <!-- Builder Steps -->
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200">
            <div class="flex items-center gap-3 mb-6">
                <span class="material-symbols-outlined text-blue-600">schema</span>
                <h3 class="font-bold text-slate-800">Construction Steps (Director & Builder Flow)</h3>
            </div>
            
            <div class="space-y-3 font-mono text-sm">
                @if (ViewBag.BuilderSteps != null)
                {
                    int step = 1;
                    foreach (var s in (List<string>)ViewBag.BuilderSteps)
                    {
                        <div class="flex items-start gap-4 p-3 bg-slate-50 border border-slate-200 rounded-lg shadow-sm">
                            <span class="text-blue-600 font-bold w-6 text-center">@step.</span>
                            <span class="text-slate-700 flex-1 whitespace-pre-wrap">@s</span>
                            <span class="material-symbols-outlined text-emerald-500 text-[18px] mt-0.5">check_circle</span>
                        </div>
                        step++;
                    }
                    <div class="flex items-center gap-4 p-4 mt-4 border border-emerald-200 bg-emerald-50 rounded-lg shadow-sm">
                        <span class="material-symbols-outlined text-emerald-600 animate-pulse text-[20px]">construction</span>
                        <span class="text-emerald-700 font-bold flex-1">director.Construct() completed successfully &rarr; FlightItinerary Created!</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
