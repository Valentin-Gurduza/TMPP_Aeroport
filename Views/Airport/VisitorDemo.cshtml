@{
    ViewData["Title"] = "Data Export Visitor";
}

<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-100 text-indigo-800 text-xs font-bold mb-4 border border-indigo-200">
        <span class="material-symbols-outlined text-[14px]">export_notes</span>
        DATA EXPORT UTILITY
    </div>
    <h1 class="text-3xl font-bold text-slate-800">Data Export Utility</h1>
    <p class="text-slate-500 mt-1">Visitor Pattern — Extends functionality of diverse class structures without altering their code.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-indigo-50 px-6 py-4 border-b border-indigo-100 flex items-center gap-3">
            <span class="material-symbols-outlined text-indigo-600">move_up</span>
            <h3 class="font-bold text-slate-800 tracking-wide uppercase">Export Mixed Collection</h3>
        </div>
        
        <div class="p-6">
            <p class="text-sm text-slate-500 mb-6">The internal collection contains: <code class="bg-slate-100 text-indigo-600 px-1 py-0.5 rounded">TerminalElement</code>, <code class="bg-slate-100 text-indigo-600 px-1 py-0.5 rounded">AircraftElement</code>, and <code class="bg-slate-100 text-indigo-600 px-1 py-0.5 rounded">FlightElement</code>. Select a Visitor to traverse them.</p>

            <form action="/Airport/VisitorDemo" method="get" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <button type="submit" name="format" value="json" class="p-6 bg-white border-2 @(ViewBag.Format == "json" ? "border-emerald-500 shadow-md shadow-emerald-500/20 bg-emerald-50/50" : "border-slate-200") rounded-xl flex flex-col items-center hover:border-emerald-400 hover:bg-emerald-50 transition group">
                    <div class="w-16 h-16 rounded-full @(ViewBag.Format == "json" ? "bg-emerald-100 text-emerald-600" : "bg-slate-100 text-slate-400 group-hover:bg-emerald-100 group-hover:text-emerald-500") flex items-center justify-center mb-3 transition-colors">
                        <span class="material-symbols-outlined text-3xl">data_object</span>
                    </div>
                    <span class="font-bold text-sm @(ViewBag.Format == "json" ? "text-emerald-700" : "text-slate-600 group-hover:text-emerald-600") transition-colors">JSON EXPORT VISITOR</span>
                </button>
    
                <button type="submit" name="format" value="xml" class="p-6 bg-white border-2 @(ViewBag.Format == "xml" ? "border-amber-500 shadow-md shadow-amber-500/20 bg-amber-50/50" : "border-slate-200") rounded-xl flex flex-col items-center hover:border-amber-400 hover:bg-amber-50 transition group">
                    <div class="w-16 h-16 rounded-full @(ViewBag.Format == "xml" ? "bg-amber-100 text-amber-600" : "bg-slate-100 text-slate-400 group-hover:bg-amber-100 group-hover:text-amber-500") flex items-center justify-center mb-3 transition-colors">
                        <span class="material-symbols-outlined text-3xl">code</span>
                    </div>
                    <span class="font-bold text-sm @(ViewBag.Format == "xml" ? "text-amber-700" : "text-slate-600 group-hover:text-amber-600") transition-colors">XML EXPORT VISITOR</span>
                </button>
            </form>
        </div>
    </div>

    <div class="bg-slate-900 rounded-2xl shadow-xl border border-slate-700 flex flex-col min-h-[400px] overflow-hidden">
        <div class="bg-slate-800 px-6 py-4 border-b border-slate-700 flex justify-between items-center">
            <h3 class="font-bold text-sm tracking-widest uppercase @(ViewBag.Format == "json" ? "text-emerald-400" : "text-amber-400")">
                Generated @ViewBag.Format?.ToString().ToUpper() Output
            </h3>
            <div class="flex items-center gap-4">
                @if (ViewBag.ExportData != null)
                {
                    <a href="/Airport/DownloadVisitorData?format=@ViewBag.Format" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold transition">
                        <span class="material-symbols-outlined text-[16px]">download</span>
                        DOWNLOAD
                    </a>
                }
                <span class="material-symbols-outlined text-[18px] @(ViewBag.Format == "json" ? "text-emerald-400" : "text-amber-400")">output</span>
            </div>
        </div>
        
        <div class="p-6 flex-1 font-mono text-sm space-y-2 overflow-y-auto max-h-[400px]">
            @if (ViewBag.ExportData != null)
            {
                <div class="text-slate-300 p-4 bg-black/40 rounded-lg border border-white/10 font-mono text-sm whitespace-pre-wrap leading-relaxed shadow-inner">
                    @foreach (var line in ViewBag.ExportData)
                    {
@line<br/>
                    }
                </div>
            }
            else
            {
                <div class="text-slate-500 italic flex items-center justify-center h-full flex-col gap-4">
                    <span class="material-symbols-outlined text-4xl opacity-50">description</span>
                    Awaiting export generation...
                </div>
            }
        </div>
    </div>
</div>
