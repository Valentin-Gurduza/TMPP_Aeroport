@{
    ViewData["Title"] = "Security Clearance Terminal";
}

<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-100 text-red-800 text-xs font-bold mb-4 border border-red-200">
        <span class="material-symbols-outlined text-[14px]">shield</span>
        SECURITY CONTROL
    </div>
    <h1 class="text-3xl font-bold text-slate-800">Security Clearance Terminal</h1>
    <p class="text-slate-500 mt-1">Proxy Pattern — Protection Proxy controlling access to <span class="font-mono bg-slate-100 text-blue-600 px-2 py-0.5 rounded text-sm">RunwayControlService</span>.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
    <!-- LEFT: Access Control -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-red-50 px-6 py-4 border-b border-red-100 flex items-center gap-3">
            <span class="material-symbols-outlined text-red-600">warning</span>
            <span class="font-bold text-red-800 text-sm tracking-wide uppercase">Restricted Runway Control System</span>
        </div>
        
        <div class="p-6">
            <form action="/Airport/ProxyDemoExecute" method="post" class="space-y-6">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Simulate Authenticated Role</label>
                    <select name="role" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-red-500 focus:ring-2 focus:ring-red-200 transition outline-none bg-white font-mono text-slate-700">
                        <option value="BaggageHandler" selected="@(ViewBag.RoleAttempted == "BaggageHandler" ? "selected" : null)">Baggage Handler (No Clearance)</option>
                        <option value="Passenger" selected="@(ViewBag.RoleAttempted == "Passenger" ? "selected" : null)">Passenger (No Clearance)</option>
                        <option value="ATC_Manager" selected="@(ViewBag.RoleAttempted == "ATC_Manager" ? "selected" : null)">ATC Manager (Authorized)</option>
                    </select>
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Target Flight</label>
                    <select name="flightNumber" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-red-500 focus:ring-2 focus:ring-red-200 transition outline-none bg-white font-mono text-slate-700">
                        @if (ViewBag.Flights != null)
                        {
                            foreach (var flight in ViewBag.Flights)
                            {
                                <option value="@flight.FlightNumber">@flight.FlightNumber (@flight.Destination) - @flight.Status</option>
                            }
                        }
                    </select>
                </div>
                
                <hr class="border-slate-200" />
                
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-4">Command Execution</label>
                    <div class="grid grid-cols-1 gap-4">
                        <button type="submit" name="actionType" value="clearance" class="w-full py-4 bg-slate-800 hover:bg-slate-900 text-white rounded-xl font-bold tracking-wide transition shadow-md flex justify-center items-center gap-2">
                            <span class="material-symbols-outlined text-[20px]">flight_takeoff</span>
                            GRANT TAKEOFF CLEARANCE
                        </button>
                        <button type="submit" name="actionType" value="lock" class="w-full py-4 bg-red-600 hover:bg-red-700 text-white rounded-xl font-bold tracking-wide transition shadow-lg shadow-red-600/30 flex justify-center items-center gap-2">
                            <span class="material-symbols-outlined text-[20px]">block</span>
                            EMERGENCY LOCK RUNWAY
                        </button>
                    </div>
                </div>
                
                <div class="mt-4 p-4 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-500 italic">
                    All commands are intercepted by <span class="font-mono text-slate-700 font-semibold">RunwayControlProxy</span> before reaching <span class="font-mono text-slate-700 font-semibold">RunwayControlService</span>.
                </div>
            </form>
        </div>
        
        <!-- Telemetry Chips -->
        <div class="bg-slate-50 px-6 py-4 border-t border-slate-200 flex flex-wrap gap-4">
            <div class="bg-white border border-slate-200 px-3 py-1.5 rounded-md flex items-center gap-2 shadow-sm">
                <span class="text-[10px] font-bold text-slate-400 uppercase">Sys_Status</span>
                <span class="flex h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
                <span class="font-mono text-emerald-600 text-xs font-bold">ACTIVE_PROXY</span>
            </div>
            <div class="bg-white border border-slate-200 px-3 py-1.5 rounded-md flex items-center gap-2 shadow-sm">
                <span class="text-[10px] font-bold text-slate-400 uppercase">Sec_Level</span>
                <span class="font-mono text-red-600 text-xs font-bold">CRITICAL</span>
            </div>
        </div>
    </div>

    <!-- RIGHT: Response Terminal -->
    <div class="bg-slate-900 rounded-2xl shadow-xl border border-slate-700 overflow-hidden flex flex-col min-h-[500px]">
        <div class="bg-slate-800 px-6 py-4 border-b border-slate-700 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-emerald-400 text-[18px]">terminal</span>
                <h3 class="text-xs font-bold text-slate-300 uppercase tracking-widest">Proxy Response</h3>
            </div>
            <div class="flex gap-2">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-amber-500"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-emerald-500"></div>
            </div>
        </div>
        
        <div class="flex-grow flex flex-col items-center justify-center p-8 text-center relative overflow-hidden">
            @if (ViewBag.RoleAttempted != null)
            {
                if (ViewBag.Result.Contains("Access Denied"))
                {
                    <div class="w-24 h-24 rounded-full bg-red-500/10 border border-red-500/30 flex items-center justify-center mb-6 relative z-10">
                        <span class="material-symbols-outlined text-red-500 text-5xl">shield</span>
                    </div>
                    <h2 class="text-2xl font-bold text-red-500 mb-2 relative z-10">ACCESS DENIED</h2>
                    <p class="text-slate-400 mb-8 max-w-sm relative z-10">RunwayControlProxy blocked this request due to insufficient clearance levels.</p>
                    
                    <div class="w-full bg-black/40 rounded-lg p-4 text-left font-mono text-sm border border-white/5 relative z-10">
                        <div class="flex gap-3 mb-2">
                            <span class="text-slate-500">[SYS]</span>
                            <span class="text-blue-400">[PROXY]</span>
                            <span class="text-slate-300">HasAccess() &rarr; <span class="text-red-400">false</span> for role: @ViewBag.RoleAttempted</span>
                        </div>
                        <div class="flex gap-3">
                            <span class="text-slate-500">[SYS]</span>
                            <span class="text-red-500">[PROXY BLOCK]</span>
                            <span class="text-slate-300">Request intercepted. Real subject not instantiated.</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="w-24 h-24 rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center mb-6 relative z-10">
                        <span class="material-symbols-outlined text-emerald-400 text-5xl">verified</span>
                    </div>
                    <h2 class="text-2xl font-bold text-emerald-400 mb-2 relative z-10">COMMAND ACCEPTED</h2>
                    <p class="text-slate-400 mb-8 max-w-sm relative z-10">RunwayControlProxy validated the request and forwarded to RunwayControlService.</p>
                    
                    <div class="w-full bg-black/40 rounded-lg p-4 text-left font-mono text-sm border border-white/5 relative z-10">
                        <div class="flex gap-3 mb-2">
                            <span class="text-slate-500">[SYS]</span>
                            <span class="text-blue-400">[PROXY]</span>
                            <span class="text-slate-300">HasAccess() &rarr; <span class="text-emerald-400">true</span> for role: @ViewBag.RoleAttempted</span>
                        </div>
                        <div class="flex gap-3">
                            <span class="text-slate-500">[SYS]</span>
                            <span class="text-emerald-400">[DELEGATED]</span>
                            <span class="text-slate-300">@ViewBag.Result</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-slate-500 italic flex items-center justify-center h-full flex-col gap-4">
                    <span class="material-symbols-outlined text-4xl opacity-50">security</span>
                    Awaiting authorization request...
                </div>
            }
        </div>
    </div>
</div>
