@model TMPP_Aeroport.Models.Aircraft
@{
    ViewData["Title"] = "Edit Aircraft";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6 flex items-center gap-4">
        <a asp-action="Index" class="text-slate-400 hover:text-slate-600 transition">
            <span class="material-symbols-rounded text-2xl">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-200">Edit Aircraft</h1>
            <p class="text-sm text-slate-500">Modify details for @Model.RegistrationCode.</p>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 dark:text-slate-200 rounded-xl shadow-sm border border-slate-200 p-6">
        <form asp-action="Edit" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="p-3 bg-red-50 text-red-600 rounded-lg text-sm mb-4"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="grid grid-cols-2 gap-5">
                <div>
                    <label asp-for="RegistrationCode" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Registration Code</label>
                    <input asp-for="RegistrationCode" class="w-full px-3 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200 focus:dark:border-blue-500" />
                    <span asp-validation-for="RegistrationCode" class="text-xs text-red-500 mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Model" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Aircraft Model</label>
                    <input asp-for="Model" class="w-full px-3 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200 focus:dark:border-blue-500" />
                    <span asp-validation-for="Model" class="text-xs text-red-500 mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-5">
                <div>
                    <label asp-for="Capacity" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Seating Capacity</label>
                    <input asp-for="Capacity" type="number" class="w-full px-3 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200 focus:dark:border-blue-500" />
                    <span asp-validation-for="Capacity" class="text-xs text-red-500 mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Airline" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Airline Operator</label>
                    <input asp-for="Airline" class="w-full px-3 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200 focus:dark:border-blue-500" />
                    <span asp-validation-for="Airline" class="text-xs text-red-500 mt-1 block"></span>
                </div>
            </div>

            <div class="pt-4 border-t border-slate-100 flex justify-end gap-3">
                <a asp-action="Index" class="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg text-sm font-semibold transition">Cancel</a>
                <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-semibold transition">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
