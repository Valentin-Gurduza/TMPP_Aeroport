@model TMPP_Aeroport.Models.Flight
@{
    ViewData["Title"] = "Update Flight Status";
}

<div class="max-w-xl mx-auto">
    <div class="mb-6 flex items-center gap-4">
        <a asp-action="Index" class="text-slate-400 hover:text-slate-600 transition">
            <span class="material-symbols-rounded text-2xl">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-200">Update ATC Status</h1>
            <p class="text-sm text-slate-500">Flight @Model.FlightNumber to @Model.Destination</p>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 dark:text-slate-200 rounded-xl shadow-sm border border-slate-200 p-8 text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-50 text-blue-600 rounded-full mb-6">
            <span class="material-symbols-rounded text-3xl">radar</span>
        </div>
        
        <h3 class="text-lg font-bold text-slate-800 dark:text-slate-200 mb-2">@Model.FlightNumber</h3>
        <p class="text-slate-500 mb-8">@Model.Aircraft?.RegistrationCode • @Model.DepartureTime.ToString("dd MMM HH:mm")</p>

        <form asp-action="EditStatus" method="post">
            <input type="hidden" asp-for="Id" />
            
            <div class="grid grid-cols-1 gap-3 max-w-xs mx-auto mb-8">
                @{
                    var statuses = new[] { "Scheduled", "Boarding", "Airborne", "Landed", "Cancelled" };
                }
                @foreach (var s in statuses)
                {
                    <div class="relative">
                        <input type="radio" name="status" value="@s" id="status_@s" class="peer sr-only" @(Model.Status == s ? "checked" : "")>
                        <label for="status_@s" class="flex cursor-pointer rounded-lg border bg-white dark:bg-slate-800 p-4 shadow-sm focus:outline-none transition-all peer-checked:border-blue-500 peer-checked:ring-1 peer-checked:ring-blue-500 peer-checked:bg-blue-50 dark:peer-checked:bg-blue-900/30 border-slate-300 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700 items-center justify-between pr-12">
                            <span class="block text-sm font-medium text-slate-900 dark:text-slate-100 uppercase tracking-widest">@s</span>
                        </label>
                        <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 material-symbols-rounded text-blue-500 invisible peer-checked:visible transition-all">check_circle</span>
                    </div>
                }
            </div>

            <div class="pt-6 border-t border-slate-100">
                <button type="submit" class="w-full py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-bold tracking-widest uppercase text-sm transition shadow-sm">
                    BROADCAST UPDATE
                </button>
            </div>
        </form>
    </div>
</div>
