@model TMPP_Aeroport.Models.Flight
@{
    ViewData["Title"] = "Schedule Flight";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6 flex items-center gap-4">
        <a asp-action="Index" class="text-slate-400 hover:text-slate-600 transition">
            <span class="material-symbols-outlined text-2xl">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Schedule New Flight</h1>
            <p class="text-sm text-slate-500">Add a new flight to the ATC board.</p>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <form asp-action="Create" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="p-3 bg-red-50 text-red-600 rounded-lg text-sm mb-4"></div>
            
            <div class="grid grid-cols-2 gap-5">
                <div>
                    <label asp-for="FlightNumber" class="block text-sm font-medium text-slate-700 mb-1">Flight Number</label>
                    <input asp-for="FlightNumber" class="w-full px-3 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" placeholder="e.g. RO-302" />
                    <span asp-validation-for="FlightNumber" class="text-xs text-red-500 mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Destination" class="block text-sm font-medium text-slate-700 mb-1">Destination</label>
                    <input asp-for="Destination" class="w-full px-3 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" placeholder="e.g. London LHR" />
                    <span asp-validation-for="Destination" class="text-xs text-red-500 mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-5">
                <div>
                    <label asp-for="DepartureTime" class="block text-sm font-medium text-slate-700 mb-1">Departure Time</label>
                    <input asp-for="DepartureTime" type="datetime-local" class="w-full px-3 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                    <span asp-validation-for="DepartureTime" class="text-xs text-red-500 mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="AircraftId" class="block text-sm font-medium text-slate-700 mb-1">Assigned Aircraft</label>
                    <select asp-for="AircraftId" class="w-full px-3 py-2 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" asp-items="ViewBag.AircraftId">
                        <option value="">-- Select Aircraft --</option>
                    </select>
                    <span asp-validation-for="AircraftId" class="text-xs text-red-500 mt-1 block"></span>
                </div>
            </div>
            
            <input type="hidden" asp-for="Status" value="Scheduled" />

            <div class="pt-4 border-t border-slate-100 flex justify-end gap-3">
                <a asp-action="Index" class="px-4 py-2 text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg text-sm font-semibold transition">Cancel</a>
                <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-semibold transition flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">event_available</span>
                    Schedule Flight
                </button>
            </div>
        </form>
    </div>
</div>
