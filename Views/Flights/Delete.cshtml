@model TMPP_Aeroport.Models.Flight

@{
    ViewData["Title"] = "Delete Flight";
}

<div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-800 dark:text-slate-200">Delete Flight</h1>
    <p class="text-slate-500 mt-1">Are you sure you want to delete this flight?</p>
</div>

<div class="bg-white dark:bg-slate-900 dark:text-slate-200 rounded-xl shadow-sm border border-slate-200 overflow-hidden max-w-2xl">
    <div class="p-6">
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-6">
            <div>
                <dt class="text-sm font-medium text-slate-500">Flight Number</dt>
                <dd class="mt-1 text-sm text-slate-900 font-semibold">@Model.FlightNumber</dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-slate-500">Status</dt>
                <dd class="mt-1 text-sm text-slate-900">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-800 dark:text-slate-200">
                        @Model.Status
                    </span>
                </dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-slate-500">Origin</dt>
                <dd class="mt-1 text-sm text-slate-900">@Model.Origin</dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-slate-500">Destination</dt>
                <dd class="mt-1 text-sm text-slate-900">@Model.Destination</dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-slate-500">Departure Time</dt>
                <dd class="mt-1 text-sm text-slate-900">@Model.DepartureTime.ToString("g")</dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-slate-500">Aircraft</dt>
                <dd class="mt-1 text-sm text-slate-900">
                    @(Model.Aircraft != null ? $"{Model.Aircraft.Model} ({Model.Aircraft.RegistrationCode})" : "N/A")
                </dd>
            </div>
        </dl>

        <form asp-action="Delete" class="mt-8 flex items-center gap-4">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-lg text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                Delete
            </button>
            <a asp-action="Index" class="inline-flex justify-center py-2 px-4 border border-slate-300 shadow-sm text-sm font-medium rounded-lg text-slate-700 bg-white dark:bg-slate-900 dark:text-slate-200 hover:bg-slate-50 dark:hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                Cancel
            </a>
        </form>
    </div>
</div>
