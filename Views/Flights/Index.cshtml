@model TMPP_Aeroport.Models.PaginatedList<TMPP_Aeroport.Models.Flight>
@{
    ViewData["Title"] = "Flight Departures";
}

<div class="flex justify-between items-center mb-6">
    <div>
        <h1 class="text-3xl font-display font-bold text-slate-800 dark:text-white">Flight Departures Board</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Live monitoring of all scheduled and active flights.</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("ATC_Manager"))
    {
        <a asp-action="Create" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition-all flex items-center gap-2 shadow-lg shadow-blue-500/30 hover:shadow-blue-500/50 transform hover:-translate-y-0.5">
            <span class="material-symbols-rounded text-[20px]">flight_takeoff</span>
            Schedule Flight
        </a>
    }
</div>

<div class="glass-card rounded-2xl overflow-hidden flex flex-col mb-6">
    <div class="p-0 overflow-x-auto flex-1">
        <table class="w-full text-left text-sm border-collapse">
            <thead class="bg-slate-50/50 dark:bg-slate-800/20 border-b border-slate-200/60 dark:border-slate-700/60 text-slate-500 dark:text-slate-400 uppercase text-[11px] font-bold tracking-widest">
                <tr>
                    <th class="px-6 py-4">Time</th>
                    <th class="px-6 py-4">Flight</th>
                    <th class="px-6 py-4">Destination</th>
                    <th class="px-6 py-4">Aircraft</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800/50 font-mono" id="flightsTableBody">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center text-slate-500 dark:text-slate-400 font-sans">
                            <span class="material-symbols-rounded text-4xl block mb-2 opacity-50">flight_off</span>
                            No flights scheduled.
                        </td>
                    </tr>
                }
                @foreach (var item in Model.OrderBy(f => f.DepartureTime))
                {
                    string statusColor = item.Status switch {
                        "Scheduled" => "text-blue-600 bg-blue-50 dark:text-blue-400 dark:bg-blue-500/10 ring-blue-500/20",
                        "Boarding" => "text-amber-600 bg-amber-50 dark:text-amber-400 dark:bg-amber-500/10 ring-amber-500/20 animate-pulse",
                        "Airborne" => "text-emerald-600 bg-emerald-50 dark:text-emerald-400 dark:bg-emerald-500/10 ring-emerald-500/20",
                        "Landed" => "text-slate-600 bg-slate-100 dark:text-slate-400 dark:bg-slate-500/10 ring-slate-500/20",
                        "Cancelled" => "text-red-600 bg-red-50 dark:text-red-400 dark:bg-red-500/10 ring-red-500/20",
                        _ => "text-slate-600 bg-slate-50 dark:text-slate-400 dark:bg-slate-500/10 ring-slate-500/20"
                    };

                    <tr class="hover:bg-slate-50 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-800/30 transition-colors">
                        <td class="px-6 py-4 text-amber-600 dark:text-amber-500 font-bold whitespace-nowrap">@item.DepartureTime.ToString("dd MMM yyyy, HH:mm")</td>
                        <td class="px-6 py-4 font-bold tracking-wider text-slate-800 dark:text-slate-200">@item.FlightNumber</td>
                        <td class="px-6 py-4 text-slate-700 dark:text-slate-300 uppercase tracking-wider font-sans font-medium">@item.Destination</td>
                        <td class="px-6 py-4 text-slate-500 dark:text-slate-400 text-xs">@item.Aircraft?.RegistrationCode</td>
                        <td class="px-6 py-4" id="status-@item.Id">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[11px] font-bold uppercase tracking-wider ring-1 @statusColor">
                                @item.Status
                            </span>
                        </td>
                        <td class="px-6 py-4 text-right space-x-2">
                            @if (User.IsInRole("Admin") || User.IsInRole("ATC_Manager"))
                            {
                                <a asp-action="EditStatus" asp-route-id="@item.Id" class="inline-flex items-center justify-center bg-white dark:bg-slate-800 hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-lg px-3 py-1.5 transition text-xs font-sans font-medium border border-slate-200 dark:border-slate-700 shadow-sm" title="Update Status">
                                    <span class="material-symbols-rounded text-[16px] mr-1">update</span> ATC
                                </a>
                            }
                            @if (User.IsInRole("Passenger") && item.Status == "Scheduled")
                            {
                                <a asp-controller="Tickets" asp-action="Buy" asp-route-id="@item.Id" class="inline-flex items-center justify-center bg-blue-50 hover:bg-blue-100 text-blue-700 dark:bg-blue-600/20 dark:text-blue-400 border border-blue-200 dark:border-blue-500/30 dark:hover:bg-blue-600/40 rounded-lg px-3 py-1.5 transition text-xs font-sans font-semibold shadow-sm">
                                    Book Ticket
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    var prevDisabled = !Model.HasPreviousPage ? "opacity-50 cursor-not-allowed pointer-events-none" : "hover:bg-slate-100 dark:hover:bg-slate-800";
    var nextDisabled = !Model.HasNextPage ? "opacity-50 cursor-not-allowed pointer-events-none" : "hover:bg-slate-100 dark:hover:bg-slate-800";
}

<div class="flex justify-between items-center glass-card rounded-xl px-6 py-4">
    <div class="text-sm font-medium text-slate-500 dark:text-slate-400">
        Page <span class="font-bold text-slate-800 dark:text-slate-200">@Model.PageIndex</span> of <span class="font-bold text-slate-800 dark:text-slate-200">@Model.TotalPages</span>
    </div>
    <div class="flex gap-2">
        <a asp-action="Index"
           asp-route-pageNumber="@(Model.PageIndex - 1)"
           class="px-4 py-2 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 rounded-lg transition border border-slate-200 dark:border-slate-700 font-medium text-sm @prevDisabled shadow-sm">
            Previous
        </a>
        <a asp-action="Index"
           asp-route-pageNumber="@(Model.PageIndex + 1)"
           class="px-4 py-2 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 rounded-lg transition border border-slate-200 dark:border-slate-700 font-medium text-sm @nextDisabled shadow-sm">
            Next
        </a>
    </div>
</div>

@section Scripts {
    <script>
        // Use globalConnection from Layout — no duplicate SignalR import needed
        const statusColorMap = {
            'Scheduled':  'text-blue-600 bg-blue-50 dark:text-blue-400 dark:bg-blue-500/10 ring-blue-500/20',
            'Boarding':   'text-amber-600 bg-amber-50 dark:text-amber-400 dark:bg-amber-500/10 ring-amber-500/20 animate-pulse',
            'Airborne':   'text-emerald-600 bg-emerald-50 dark:text-emerald-400 dark:bg-emerald-500/10 ring-emerald-500/20',
            'Landed':     'text-slate-600 bg-slate-100 dark:text-slate-400 dark:bg-slate-500/10 ring-slate-500/20',
            'Cancelled':  'text-red-600 bg-red-50 dark:text-red-400 dark:bg-red-500/10 ring-red-500/20',
        };

        function applyFlightUpdate(flightId, newStatus) {
            const cell = document.getElementById('status-' + flightId);
            if (!cell) return; // flight not on this page — ignore
            const badge = cell.querySelector('span');
            if (!badge) return;
            // Reset all colour classes
            badge.className = 'inline-flex items-center px-2.5 py-1 rounded-md text-[11px] font-bold uppercase tracking-wider ring-1';
            const colours = statusColorMap[newStatus] || 'text-slate-600 bg-slate-50 dark:text-slate-400 dark:bg-slate-500/10 ring-slate-500/20';
            colours.split(' ').forEach(cls => { if (cls) badge.classList.add(cls); });
            badge.textContent = newStatus;
        }

        // Wire up after SignalR is ready — poll until globalConnection exists
        function wireFlightUpdates() {
            if (window.globalConnection) {
                window.globalConnection.on('FlightStateChanged', function (data) {
                    applyFlightUpdate(data.flightId, data.newStatus);
                });
            } else {
                setTimeout(wireFlightUpdates, 300);
            }
        }
        wireFlightUpdates();
    </script>
}
