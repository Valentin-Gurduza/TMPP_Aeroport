@model TMPP_Aeroport.Models.PaginatedList<TMPP_Aeroport.Models.Flight>
@{
    ViewData["Title"] = "Flight Departures";
}

<div class="flex justify-between items-center mb-6">
    <div>
        <h1 class="text-2xl font-bold text-slate-800">Flight Departures Board</h1>
        <p class="text-sm text-slate-500">Live monitoring of all scheduled and active flights.</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("ATC_Manager"))
    {
        <a asp-action="Create" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition flex items-center gap-2 shadow-sm">
            <span class="material-symbols-outlined text-[18px]">flight_takeoff</span>
            Schedule Flight
        </a>
    }
</div>

<div class="bg-slate-900 rounded-xl shadow-xl overflow-hidden border border-slate-700">
    <table class="w-full text-left text-sm">
        <thead class="bg-slate-950 text-slate-400 border-b border-slate-800 uppercase text-xs font-semibold tracking-widest">
            <tr>
                <th class="px-6 py-4">Time</th>
                <th class="px-6 py-4">Flight</th>
                <th class="px-6 py-4">Destination</th>
                <th class="px-6 py-4">Aircraft</th>
                <th class="px-6 py-4">Status</th>
                <th class="px-6 py-4 text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-800 font-mono" id="flightsTableBody">
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="px-6 py-12 text-center text-slate-500 font-sans">
                        <span class="material-symbols-outlined text-4xl block mb-2 opacity-50">flight_off</span>
                        No flights scheduled.
                    </td>
                </tr>
            }
            @foreach (var item in Model.OrderBy(f => f.DepartureTime))
            {
                string statusColor = item.Status switch {
                    "Scheduled" => "text-blue-400",
                    "Boarding" => "text-amber-400 animate-pulse",
                    "Airborne" => "text-emerald-400",
                    "Landed" => "text-slate-400",
                    "Cancelled" => "text-red-500",
                    _ => "text-white"
                };

                <tr class="hover:bg-slate-800/50 transition">
                    <td class="px-6 py-4 text-amber-500">@item.DepartureTime.ToString("HH:mm")</td>
                    <td class="px-6 py-4 text-white font-bold tracking-wider">@item.FlightNumber</td>
                    <td class="px-6 py-4 text-white uppercase tracking-wider">@item.Destination</td>
                    <td class="px-6 py-4 text-slate-400 text-xs">@item.Aircraft?.RegistrationCode</td>
                    <td class="px-6 py-4 font-bold tracking-widest uppercase @statusColor" id="status-@item.Id">
                        @item.Status
                    </td>
                    <td class="px-6 py-4 text-right">
                        @if (User.IsInRole("Admin") || User.IsInRole("ATC_Manager"))
                        {
                            <a asp-action="EditStatus" asp-route-id="@item.Id" class="inline-flex items-center justify-center bg-slate-800 hover:bg-slate-700 text-slate-300 rounded px-3 py-1.5 transition text-xs font-sans tracking-normal border border-slate-700 hover:border-slate-500" title="Update Status">
                                <span class="material-symbols-outlined text-[14px] mr-1">update</span> ATC
                            </a>
                        }
                        @if (User.IsInRole("Passenger") && item.Status == "Scheduled")
                        {
                            <a asp-controller="Tickets" asp-action="Buy" asp-route-flightId="@item.Id" class="inline-flex items-center justify-center bg-blue-600/20 text-blue-400 border border-blue-500/30 hover:bg-blue-600/40 rounded px-3 py-1.5 transition text-xs font-sans tracking-normal ml-2">
                                Book Ticket
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled opacity-50 cursor-not-allowed" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled opacity-50 cursor-not-allowed" : "";
}

<div class="mt-6 flex justify-between items-center">
    <div class="text-sm text-slate-400">
        Page @Model.PageIndex of @Model.TotalPages
    </div>
    <div class="flex gap-2">
        <a asp-action="Index"
           asp-route-pageNumber="@(Model.PageIndex - 1)"
           class="px-4 py-2 bg-slate-800 text-slate-300 rounded hover:bg-slate-700 transition @prevDisabled">
            Previous
        </a>
        <a asp-action="Index"
           asp-route-pageNumber="@(Model.PageIndex + 1)"
           class="px-4 py-2 bg-slate-800 text-slate-300 rounded hover:bg-slate-700 transition @nextDisabled">
            Next
        </a>
    </div>
</div>

@section Scripts {
    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/flightHub")
            .build();

        connection.on("ReceiveFlightUpdate", function (flightId, newStatus) {
            console.log("Real-time update received for flight ID: " + flightId + " - Status: " + newStatus);
            
            // Gasim elementul TD corespunzator acelui zbor
            const statusCell = document.getElementById("status-" + flightId);
            if (statusCell) {
                // Modificam textul
                statusCell.innerText = newStatus;
                
                // Actualizam culorile pe baza noului status
                statusCell.className = "px-6 py-4 font-bold tracking-widest uppercase transition-colors duration-500 ";
                
                if (newStatus === "Scheduled") statusCell.className += "text-blue-400";
                else if (newStatus === "Boarding") statusCell.className += "text-amber-400 animate-pulse";
                else if (newStatus === "Airborne") statusCell.className += "text-emerald-400";
                else if (newStatus === "Landed") statusCell.className += "text-slate-400";
                else if (newStatus === "Cancelled") statusCell.className += "text-red-500";
                
                // Efect vizual de blitz pe intregul rand pentru a atrage atentia
                const row = statusCell.parentElement;
                const oldBg = row.className;
                row.className = "bg-blue-900/40 transition-colors duration-1000";
                setTimeout(() => {
                    row.className = oldBg;
                }, 1000);
            }
        });

        connection.start().then(function () {
            console.log("Connected to FIDS Live Updates via SignalR!");
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}
