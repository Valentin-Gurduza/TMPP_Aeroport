@using Microsoft.AspNetCore.Identity
@using TMPP_Aeroport.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="flex items-center justify-between w-full">
        <div class="flex flex-col">
            <span class="text-sm font-medium text-slate-700 truncate max-w-[120px]">@User.Identity?.Name</span>
            <span class="text-xs text-slate-500">Admin</span>
        </div>
        <form class="inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Airport", new { area = "" })">
            <button type="submit" class="text-slate-400 hover:text-red-500 transition-colors" title="Logout">
                <span class="material-symbols-outlined text-[18px]">logout</span>
            </button>
        </form>
    </div>
}
else
{
    <div class="flex flex-col gap-1 w-full">
        <a asp-area="Identity" asp-page="/Account/Login" class="text-xs font-medium text-primary-600 hover:text-primary-700">Log In</a>
        <a asp-area="Identity" asp-page="/Account/Register" class="text-xs text-slate-500 hover:text-slate-700">Register</a>
    </div>
}
