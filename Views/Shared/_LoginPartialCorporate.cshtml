@using Microsoft.AspNetCore.Identity
@using TMPP_Aeroport.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    var roles = currentUser != null ? await UserManager.GetRolesAsync(currentUser) : new List<string>();
    var roleLabel = roles.FirstOrDefault() ?? "User";

    <div class="flex items-center justify-between w-full min-w-0">
        <div class="flex flex-col min-w-0">
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200 truncate leading-tight">@User.Identity?.Name</span>
            <span class="text-[10px] text-slate-400 dark:text-slate-500 font-medium leading-tight mt-0.5">@roleLabel</span>
        </div>
        <form class="inline ml-2 flex-shrink-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Airport", new { area = "" })">
            <button type="submit" class="text-slate-400 hover:text-red-500 dark:hover:text-red-400 transition-colors" title="Logout">
                <span class="material-symbols-rounded" style="font-size:18px; font-variation-settings:'FILL' 1,'wght' 400,'GRAD' 0,'opsz' 24;">logout</span>
            </button>
        </form>
    </div>
}
else
{
    <div class="flex flex-col gap-1 w-full">
        <a asp-area="Identity" asp-page="/Account/Login" class="text-xs font-semibold text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors">Log In</a>
        <a asp-area="Identity" asp-page="/Account/Register" class="text-xs text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">Register</a>
    </div>
}
