        </a>
        <a asp-controller="Airport" asp-action="CheckIn" class="flex flex-col items-center justify-center p-3 rounded-lg @(ViewContext.RouteData.Values["action"]?.ToString() == "CheckIn" ? "bg-cyan-500/10 text-cyan-400 border-r-2 border-cyan-400" : "text-slate-500 opacity-60 hover:bg-white/5 hover:opacity-100") transition-all">
