<!-- TopAppBar -->
<header class="fixed top-0 left-20 right-0 h-14 z-50 flex justify-between items-center px-6 bg-slate-950/80 backdrop-blur-lg border-b border-white/10 shadow-[0_4px_30px_rgba(0,0,0,0.5)]">
    <div class="flex items-center gap-4">
        <span class="text-cyan-500 font-black tracking-tighter text-xl font-['Space_Grotesk']">AirportLogger</span>
        <div class="h-4 w-px bg-white/20"></div>
        <span class="font-['Space_Grotesk'] text-xs tracking-widest uppercase text-cyan-400">Smart Airport Management System v1.0</span>
    </div>
    <div class="flex-1 max-w-2xl mx-12 ticker-wrap border-x border-white/5 bg-black/20 py-1">
        <div id="airport-ticker" class="ticker font-['Space_Grotesk'] text-[10px] tracking-wider text-cyan-500/80 uppercase">
            AirportLogger [Singleton]: System Integrity: Nominal | Control Center Ready
        </div>
    </div>
    <div class="flex items-center gap-4 text-slate-500">
        <span class="font-['Space_Grotesk'] text-[10px] tracking-widest uppercase">v4.8.2-ALPHA</span>
        <div class="flex gap-2">
            <span class="material-symbols-outlined text-sm hover:text-cyan-300 transition-all cursor-pointer">notifications_active</span>
            <span class="material-symbols-outlined text-sm hover:text-cyan-300 transition-all cursor-pointer">terminal</span>
        </div>
    </div>
</header>

<!-- Main Content -->
<main class="ml-20 mt-14 min-h-screen p-margin">
    @RenderBody()
</main>

@await RenderSectionAsync("Scripts", required: false)

<script>
    function fetchLogs() {
        fetch('/Airport/GetLogs')
            .then(response => response.json())
            .then(logs => {
                if (logs && logs.length > 0) {
                    const tickerText = logs.join(' | ');
                    document.getElementById('airport-ticker').innerText = "AirportLogger [Singleton]: " + tickerText;
                }
            })
            .catch(error => console.error('Error fetching logs:', error));
    }
    
    // Fetch logs every 10 seconds
    setInterval(fetchLogs, 10000);
    // Initial fetch
    fetchLogs();
</script>
</body>
</html>
