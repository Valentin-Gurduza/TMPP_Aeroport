<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Airport Management</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            900: '#1e3a8a',
                        },
                        surface: '#ffffff',
                        background: '#f8fafc',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .sidebar-link { transition: all 0.2s; }
        .sidebar-link:hover { background-color: #eff6ff; color: #2563eb; }
        .sidebar-link.active { background-color: #eff6ff; color: #2563eb; border-right: 3px solid #2563eb; }
        
        /* Overriding some dark classes from previous views */
        .glass-card, .glass-panel { 
            background: #ffffff !important; 
            border: 1px solid #e2e8f0 !important; 
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06) !important; 
            color: #1e293b !important;
        }
        .text-cyan-400, .text-cyan-500 { color: #2563eb !important; }
        .glow-cyan { text-shadow: none !important; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="text-slate-800 antialiased h-screen flex overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-slate-200 flex flex-col h-full flex-shrink-0 z-20">
        <div class="h-16 flex items-center px-6 border-b border-slate-200">
            <span class="material-symbols-outlined text-primary-600 mr-2">flight_takeoff</span>
            <span class="font-bold text-lg text-slate-900 tracking-tight">SAMS Enterprise</span>
        </div>
        
        <div class="p-4 flex-1 overflow-y-auto">
            <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2 mt-4 px-3">Main</div>
            <nav class="space-y-1">
                <a asp-controller="Airport" asp-action="Index" class="sidebar-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-slate-700 @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <span class="material-symbols-outlined mr-3 text-[20px]">dashboard</span> Dashboard
                </a>
                <a asp-controller="Airport" asp-action="CheckIn" class="sidebar-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-slate-700 @(ViewContext.RouteData.Values["action"]?.ToString() == "CheckIn" ? "active" : "")">
                    <span class="material-symbols-outlined mr-3 text-[20px]">how_to_reg</span> Check-In
                </a>
            </nav>

            <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2 mt-6 px-3">Passenger</div>
            <nav class="space-y-1">
                <a asp-controller="Tickets" asp-action="MyTickets" class="sidebar-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-slate-700 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tickets" ? "active" : "")">
                    <span class="material-symbols-outlined mr-3 text-[20px]">confirmation_number</span> My Tickets
                </a>
            </nav>

            <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2 mt-6 px-3">Operations</div>
            <nav class="space-y-1">
                <a asp-controller="Flights" asp-action="Index" class="sidebar-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-slate-700 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Flights" ? "active" : "")">
                    <span class="material-symbols-outlined mr-3 text-[20px]">flight_takeoff</span> Live FIDS Board
                </a>
                <a asp-controller="Airport" asp-action="FacadeDemo" class="sidebar-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-slate-700 @(ViewContext.RouteData.Values["action"]?.ToString() == "FacadeDemo" ? "active" : "")">
                    <span class="material-symbols-outlined mr-3 text-[20px]">settings_input_antenna</span> ATC Tower
                </a>
                <a asp-controller="Airport" asp-action="MediatorDemo" class="sidebar-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-slate-700 @(ViewContext.RouteData.Values["action"]?.ToString() == "MediatorDemo" ? "active" : "")">
                    <span class="material-symbols-outlined mr-3 text-[20px]">hub</span> Air Traffic
                </a>
                <a asp-controller="Airport" asp-action="BridgeDemo" class="sidebar-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-slate-700 @(ViewContext.RouteData.Values["action"]?.ToString() == "BridgeDemo" ? "active" : "")">
                    <span class="material-symbols-outlined mr-3 text-[20px]">tv</span> Hardware Displays
                </a>
            </nav>
            
            <div class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2 mt-6 px-3">Management</div>
            <nav class="space-y-1">
                <a asp-controller="Airport" asp-action="BuilderDemo" class="sidebar-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-slate-700 @(ViewContext.RouteData.Values["action"]?.ToString() == "BuilderDemo" ? "active" : "")">
                    <span class="material-symbols-outlined mr-3 text-[20px]">event_note</span> Itineraries
                </a>
                <a asp-controller="Airport" asp-action="VisitorDemo" class="sidebar-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-slate-700 @(ViewContext.RouteData.Values["action"]?.ToString() == "VisitorDemo" ? "active" : "")">
                    <span class="material-symbols-outlined mr-3 text-[20px]">transfer_within_a_station</span> Export Data
                </a>
                <a asp-controller="Fleet" asp-action="Index" class="sidebar-link flex items-center px-3 py-2 text-sm font-medium rounded-md text-slate-700 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Fleet" ? "active" : "")">
                    <span class="material-symbols-outlined mr-3 text-[20px]">flight</span> Fleet
                </a>
            </nav>
        </div>
        
        <div class="p-4 border-t border-slate-200">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <div class="h-8 w-8 rounded-full bg-primary-100 flex items-center justify-center text-primary-700 font-bold">
                        A
                    </div>
                </div>
                <div class="ml-3 w-full">
                    <partial name="_LoginPartialCorporate" />
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Wrapper -->
    <div class="flex-1 flex flex-col min-w-0 bg-background">
        <!-- Top Header -->
        <header class="bg-white border-b border-slate-200 h-16 flex items-center justify-between px-6 z-10 shadow-sm">
            <div class="flex items-center">
                <h1 class="text-xl font-semibold text-slate-800">@ViewData["Title"]</h1>
            </div>
            <div class="flex items-center space-x-4">
                <button class="text-slate-400 hover:text-slate-500">
                    <span class="material-symbols-outlined">search</span>
                </button>
                <button class="text-slate-400 hover:text-slate-500 relative">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute top-0 right-0 block h-2 w-2 rounded-full bg-red-500 ring-2 ring-white"></span>
                </button>
            </div>
        </header>

        <!-- Main Content Area -->
        <main class="flex-1 overflow-y-auto p-6">
            <div class="max-w-7xl mx-auto">
                @RenderBody()
            </div>
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
