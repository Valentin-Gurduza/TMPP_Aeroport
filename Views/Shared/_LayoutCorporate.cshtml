<!DOCTYPE html>
<html lang="en" x-data="{ darkMode: localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches) }" :class="{ 'dark': darkMode }" x-init="$watch('darkMode', val => localStorage.setItem('theme', val ? 'dark' : 'light'))">
<head>
    <script>
        // Prevent FOUC (Flash of Unstyled Content) for Dark Mode
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Smart Airport Management System (SAMS) Enterprise Dashboard. Manage flights, fleet, passengers, and security control." />
    <meta name="author" content="Valentin / SAMS Dev Team" />
    <title>@ViewData["Title"] - SAMS Enterprise</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>✈️</text></svg>">
    
    <!-- Core Scripts (head) -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

    <!-- Fonts & Icon Styles -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,1,0" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: { 50: '#eff6ff', 100: '#dbeafe', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8', 900: '#1e3a8a' },
                        sams: { dark: '#0B1121', panel: '#151E32', border: '#1E293B', glow: '#0ea5e9' }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <style>
        /* === BASE === */
        body { font-family: 'Inter', sans-serif; }
        .font-display { font-family: 'Outfit', sans-serif; }
        .material-symbols-rounded {
            font-family: 'Material Symbols Rounded';
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            font-style: normal;
            line-height: 1;
            display: inline-block;
            white-space: nowrap;
            word-wrap: normal;
            direction: ltr;
            vertical-align: middle;
        }

        /* === GLASS PANELS (Light & Dark) === */
        .glass-panel {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(226, 232, 240, 0.6);
        }
        .dark .glass-panel {
            background: rgba(15, 23, 42, 0.80);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(30, 41, 59, 0.8);
        }

        /* === GLASS CARDS (content cards) === */
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            border: 1px solid rgba(226, 232, 240, 0.8);
            color: #1e293b;
            box-shadow: 0 1px 3px 0 rgba(0,0,0,0.07), 0 1px 2px -1px rgba(0,0,0,0.07);
        }
        .dark .glass-card {
            background: rgba(21, 30, 50, 0.90);
            border: 1px solid rgba(30, 41, 59, 0.8);
            color: #f1f5f9;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.3);
        }

        /* === SIDEBAR NAV LINKS === */
        .nav-group-title {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: #94a3b8;
            padding: 0 12px;
            margin-top: 24px;
            margin-bottom: 4px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .dark .nav-group-title { color: #475569; }
        .nav-group-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }
        .dark .nav-group-title::after { background: #1e293b; }

        .sidebar-link {
            display: flex;
            align-items: center;
            padding: 8px 12px;
            border-radius: 10px;
            font-size: 13.5px;
            font-weight: 500;
            color: #475569;
            text-decoration: none;
            transition: all 0.15s ease-in-out;
            margin-bottom: 2px;
            gap: 10px;
            position: relative;
        }
        .dark .sidebar-link { color: #94a3b8; }
        .sidebar-link:hover {
            background: #eff6ff;
            color: #2563eb;
        }
        .dark .sidebar-link:hover {
            background: rgba(30, 41, 59, 0.6);
            color: #60a5fa;
        }
        .sidebar-link.active {
            background: #eff6ff;
            color: #1d4ed8;
            font-weight: 600;
            box-shadow: 0 1px 2px rgba(37,99,235,0.08);
            border-left: 3px solid #2563eb;
            padding-left: 9px;
        }
        .dark .sidebar-link.active {
            background: rgba(37, 99, 235, 0.12);
            color: #60a5fa;
            border-left-color: #3b82f6;
        }
        .sidebar-link .sidebar-icon {
            font-size: 20px;
            transition: transform 0.15s;
            flex-shrink: 0;
        }
        .sidebar-link:hover .sidebar-icon { transform: scale(1.1); }
        .sidebar-link.active .sidebar-icon { color: #2563eb; }
        .dark .sidebar-link.active .sidebar-icon { color: #60a5fa; }

        /* === SCROLLBAR === */
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        .dark ::-webkit-scrollbar-thumb { background: #334155; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        /* === TOASTR === */
        #toast-container > div {
            opacity: 1 !important;
            border-radius: 12px !important;
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.25) !important;
            font-family: 'Inter', sans-serif !important;
        }

        /* === ANIMATIONS === */
        @@keyframes slideIn {
            from { opacity: 0; transform: translateY(-8px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .animate-slide-in { animation: slideIn 0.25s ease-out; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
    <!-- Turbo Drive for SPA-like navigation -->
    <script src="https://unpkg.com/@@hotwired/turbo@8.0.4/dist/turbo.es2017-umd.js"></script>
    <style>
        .turbo-progress-bar {
            height: 3px;
            background-color: #3b82f6;
        }
    </style>
    <!-- FOUC Prevention Script -->
    <script>
        if (localStorage.getItem('darkMode') === 'true' || 
            (!('darkMode' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>
</head>
<body class="text-slate-800 bg-slate-100 dark:text-slate-200 dark:bg-sams-dark antialiased h-screen flex overflow-hidden transition-colors duration-300">

    <!-- ===================== SIDEBAR ===================== -->
    <aside class="w-64 glass-panel flex flex-col h-full flex-shrink-0 z-20 shadow-xl" style="border-right-width:1px;">
        
        <!-- Logo -->
        <div class="h-[68px] flex items-center px-5 border-b border-slate-200/60 dark:border-sams-border flex-shrink-0">
            <div class="flex items-center justify-center w-9 h-9 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-600 shadow-lg shadow-blue-500/30 text-white mr-3 flex-shrink-0">
                <span class="material-symbols-rounded" style="font-size:20px;">flight_takeoff</span>
            </div>
            <div>
                <span class="font-display font-bold text-[17px] text-slate-900 dark:text-white tracking-tight leading-none block">SAMS</span>
                <span class="text-[9px] text-slate-400 dark:text-slate-500 font-bold tracking-widest uppercase block mt-0.5">Enterprise Core</span>
            </div>
        </div>

        <!-- Navigation scroll area -->
        <div id="sidebar-scroll-area" class="flex-1 overflow-y-auto px-3 py-3">

            <!-- MAIN -->
            <div class="nav-group-title" style="margin-top:4px;">Terminal</div>
            <nav>
                <a asp-controller="Airport" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Airport" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">dashboard</span> Dashboard
                </a>

            </nav>

            <div class="nav-group-title">Passenger</div>
            <nav>
                <a asp-controller="Tickets" asp-action="MyTickets" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "MyTickets" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">confirmation_number</span> My Tickets
                </a>
                <a asp-controller="Tickets" asp-action="Book" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Book" || ViewContext.RouteData.Values["action"]?.ToString() == "Buy" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">travel_explore</span> Book Flights
                </a>

            </nav>

            <!-- ATC -->
            <div class="nav-group-title">ATC (Air Traffic)</div>
            <nav>
                <a asp-controller="ATC" asp-action="Radar" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Radar" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">radar</span>
                    Live Radar
                    <span class="ml-auto flex h-2 w-2 relative flex-shrink-0">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                    </span>
                </a>
                <a asp-controller="ATC" asp-action="ATCTower" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ATCTower" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">settings_input_antenna</span>
                    ATC Tower
                    <span id="atctower-notif-dot" class="ml-auto w-2 h-2 rounded-full bg-orange-500 hidden animate-pulse flex-shrink-0"></span>
                </a>
                <a asp-controller="ATC" asp-action="Alerts" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Alerts" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">notifications</span>
                    Global Alerts
                    <span id="alerts-notif-dot" class="ml-auto w-2 h-2 rounded-full bg-orange-500 hidden animate-pulse flex-shrink-0"></span>
                </a>
                <a asp-controller="ATC" asp-action="RunwayLights" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "RunwayLights" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">lightbulb</span> Runway Lights
                </a>
            </nav>

            <!-- GROUND OPS -->
            <div class="nav-group-title">Ground Ops</div>
            <nav>
                <a asp-controller="Flights" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Flights" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">flight_takeoff</span> Live FIDS Board
                </a>
                <a asp-controller="GroundOps" asp-action="PreFlightChecks" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "PreFlightChecks" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">checklist</span> Pre-Flight SOP
                </a>

                <a asp-controller="GroundOps" asp-action="GateAssignments" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "GateAssignments" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">storefront</span> Gate Manager
                </a>
                <a asp-controller="GroundOps" asp-action="CargoManifest" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "CargoManifest" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">luggage</span> Cargo Manifest
                </a>
                <a asp-controller="GroundOps" asp-action="BaggageRouting" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "BaggageRouting" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">conveyor_belt</span> Baggage BHS
                </a>
                <a asp-controller="GroundOps" asp-action="GroundVehicles" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "GroundVehicles" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">airport_shuttle</span> GSE Fleet
                </a>
            </nav>

            <!-- SECURITY -->
            <div class="nav-group-title">Security</div>
            <nav>
                <a asp-controller="Security" asp-action="Checkpoint" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Checkpoint" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">policy</span>
                    Security Scanners
                    <span id="security-notif-dot" class="ml-auto w-2 h-2 rounded-full bg-red-600 hidden animate-pulse flex-shrink-0"></span>
                </a>
            </nav>

            <!-- MANAGEMENT -->
            <div class="nav-group-title">Management</div>
            <nav>
                <a asp-controller="Management" asp-action="FlightScheduler" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "FlightScheduler" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">event</span> Flight Scheduler
                </a>
                <a asp-controller="Management" asp-action="AuditLogs" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "AuditLogs" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">history</span> Transaction Audit
                </a>
                <a asp-controller="Management" asp-action="Analytics" class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Analytics" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">policy</span> Regulatory Export
                </a>
                <a asp-controller="Fleet" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Fleet" ? "active" : "")">
                    <span class="material-symbols-rounded sidebar-icon">flight</span> Fleet
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")">
                        <span class="material-symbols-rounded sidebar-icon">manage_accounts</span> User Mgmt
                    </a>
                }
            </nav>

        </div>

        <!-- User Profile Footer -->
        <div class="flex-shrink-0 p-3 border-t border-slate-200/60 dark:border-sams-border bg-slate-50/60 dark:bg-slate-900/40">
            <div class="flex items-center gap-3">
                @{
                    var initial = "U";
                    if (User.Identity?.IsAuthenticated == true && !string.IsNullOrEmpty(User.Identity.Name))
                        initial = User.Identity.Name.Substring(0, 1).ToUpper();
                }
                <div class="h-8 w-8 rounded-full bg-gradient-to-tr from-blue-500 to-indigo-500 flex items-center justify-center text-white font-bold text-sm flex-shrink-0 shadow-sm">
                    @initial
                </div>
                <div class="flex-1 min-w-0">
                    <partial name="_LoginPartialCorporate" />
                </div>
            </div>
        </div>
    </aside>

    <!-- ===================== MAIN WRAPPER ===================== -->
    <div class="flex-1 flex flex-col min-w-0 relative">

        <!-- Ambient glow (dark mode only) -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[250px] bg-blue-600/8 dark:bg-blue-600/10 rounded-full blur-[120px] pointer-events-none -z-10"></div>

        <!-- ===== TOP HEADER ===== -->
        <header class="glass-panel h-[68px] border-b border-slate-200/60 dark:border-sams-border flex items-center justify-between px-6 z-10 sticky top-0 flex-shrink-0" style="border-left:0;border-right:0;border-top:0;">
            <div class="flex items-center">
                <h1 class="text-xl font-display font-semibold text-slate-800 dark:text-white tracking-tight">@ViewData["Title"]</h1>
            </div>
            <div class="flex items-center gap-3">

                <!-- Notifications Bell -->
                <div class="relative" id="notif-dropdown-wrapper">
                    <button onclick="toggleNotifDropdown(event)" class="relative flex items-center justify-center h-9 w-9 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors shadow-sm">
                        <span class="material-symbols-rounded" style="font-size:20px;">notifications</span>
                        <span id="notif-badge" class="absolute -top-1 -right-1 h-4 w-4 bg-red-500 text-white text-[9px] font-bold flex items-center justify-center rounded-full hidden">0</span>
                    </button>
                    <!-- Dropdown -->
                    <div id="notif-dropdown" class="hidden absolute right-0 mt-2 w-80 bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-slate-200 dark:border-slate-700 z-50 overflow-hidden flex flex-col max-h-[400px]">
                        <div class="bg-slate-50 dark:bg-slate-700/50 px-4 py-3 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center">
                            <span class="font-bold text-sm text-slate-700 dark:text-slate-200">Notifications</span>
                            <button class="text-xs text-blue-600 dark:text-blue-400 font-semibold hover:underline" onclick="clearNotifs(event)">Clear all</button>
                        </div>
                        <div id="notif-list" class="flex-1 overflow-y-auto">
                            <div class="p-4 text-center text-slate-400 text-sm italic" id="empty-notifs">No notifications yet.</div>
                        </div>
                    </div>
                </div>

                <!-- Divider -->
                <div class="w-px h-7 bg-slate-200 dark:bg-slate-700"></div>

                <!-- Weather Widget -->
                <div class="flex items-center bg-white/70 dark:bg-slate-800/60 px-3 py-1.5 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm" id="weather-widget">
                    <span class="material-symbols-rounded text-amber-500 mr-2" id="weather-icon" style="font-size:18px;">wb_sunny</span>
                    <div class="flex flex-col leading-none">
                        <span class="text-[9px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-0.5">Weather</span>
                        <span id="weather-label" class="text-xs font-bold text-slate-700 dark:text-slate-200">Clear</span>
                    </div>
                </div>

                <!-- Virtual Clock & Global Speed Controls -->
                <div class="flex items-center bg-white/70 dark:bg-slate-800/60 pl-3 pr-1 py-1.5 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm gap-3">
                    <div class="flex items-center">
                        <span class="material-symbols-rounded text-blue-500 mr-2 animate-[spin_4s_linear_infinite]" style="font-size:18px;">radar</span>
                        <div class="flex flex-col leading-none">
                            <span class="text-[9px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-0.5">
                                SYS TIME <span id="clock-speed" class="text-blue-500 dark:text-blue-400">1x</span>
                            </span>
                            <span id="virtual-clock" class="text-xs font-bold font-mono text-slate-700 dark:text-slate-200" style="font-variant-numeric: tabular-nums;">Syncing...</span>
                        </div>
                    </div>
                    <div class="w-px h-6 bg-slate-200 dark:bg-slate-700 mx-1"></div>
                    <div class="flex gap-1" id="global-speed-controls">
                        <button class="global-speed-btn px-2 py-1 rounded-lg text-[10px] font-bold text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-700 transition" data-speed="1">1x</button>
                        <button class="global-speed-btn px-2 py-1 rounded-lg text-[10px] font-bold text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-700 transition" data-speed="20">20x</button>
                        <button class="global-speed-btn px-2 py-1 rounded-lg text-[10px] font-bold text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-700 transition" data-speed="50">50x</button>
                        <button class="global-speed-btn px-2 py-1 rounded-lg text-[10px] font-bold text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-700 transition" data-speed="100">100x</button>
                    </div>
                </div>

                <!-- Divider -->
                <div class="w-px h-7 bg-slate-200 dark:bg-slate-700"></div>

                <!-- Dark/Light Mode Toggle -->
                <button @@click="darkMode = !darkMode" class="flex items-center justify-center h-9 w-9 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors shadow-sm" title="Toggle theme">
                    <span class="material-symbols-rounded" x-show="!darkMode" style="font-size:19px;">dark_mode</span>
                    <span class="material-symbols-rounded" x-show="darkMode" style="font-size:19px; display:none;">light_mode</span>
                </button>
            </div>
        </header>

        <!-- ===== MAIN CONTENT ===== -->
        <main class="flex-1 overflow-y-auto p-6 relative z-0">
            <div class="max-w-7xl mx-auto">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="mb-6 rounded-2xl bg-emerald-50 dark:bg-emerald-900/20 p-4 border border-emerald-200 dark:border-emerald-800/40 flex items-start shadow-sm animate-slide-in">
                        <div class="flex-shrink-0 bg-emerald-100 dark:bg-emerald-800/40 p-1.5 rounded-lg">
                            <span class="material-symbols-rounded text-emerald-600 dark:text-emerald-400" style="font-size:20px;">check_circle</span>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-bold text-emerald-800 dark:text-emerald-400">Transaction Successful</h3>
                            <div class="mt-1 text-sm text-emerald-700 dark:text-emerald-500 font-medium">
                                @TempData["SuccessMessage"]
                            </div>
                        </div>
                    </div>
                }
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- ===================== SCRIPTS ===================== -->
    <script>
        // --- Toastr Config ---
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "5000",
        };

        // --- Notification State (Preserved across Turbo navigations) ---
        window.notifCount = window.notifCount || 0;
        window.notifs = window.notifs || JSON.parse(localStorage.getItem('sams_notifs') || '[]');

        window.toggleNotifDropdown = function(e) {
            e.stopPropagation();
            document.getElementById('notif-dropdown').classList.toggle('hidden');
        }

        window.clearNotifs = function(e) {
            if (e) e.stopPropagation();
            window.notifCount = 0;
            window.notifs = [];
            localStorage.setItem('sams_notifs', JSON.stringify(window.notifs));
            const badge = document.getElementById('notif-badge');
            if (badge) { badge.classList.add('hidden'); badge.innerText = "0"; }
            document.getElementById('notif-list').innerHTML = '<div class="p-4 text-center text-slate-400 text-sm italic" id="empty-notifs">No notifications yet.</div>';
            
            const alertDot = document.getElementById('alerts-notif-dot');
            if (alertDot) alertDot.classList.add('hidden');
            const secDot = document.getElementById('security-notif-dot');
            if (secDot) secDot.classList.add('hidden');
        }

        window.renderNotifItem = function(title, msg, type) {
            const emptyMsg = document.getElementById('empty-notifs');
            if (emptyMsg) emptyMsg.remove();
            const list = document.getElementById('notif-list');
            if (!list) return; // Prevent errors if DOM element is missing
            
            const item = document.createElement('div');
            item.className = "p-3 border-b border-slate-100 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800 transition cursor-pointer";
            
            let icon = type === 'security' ? '<span class="material-symbols-rounded text-red-500 mr-2 text-lg">gpp_bad</span>' :
                       type === 'flight' ? '<span class="material-symbols-rounded text-blue-500 mr-2 text-lg">flight_takeoff</span>' :
                       '<span class="material-symbols-rounded text-slate-500 mr-2 text-lg">notifications</span>';
            
            item.innerHTML = `
                <div class="flex items-start">
                    ${icon}
                    <div>
                        <h4 class="text-xs font-bold text-slate-800 dark:text-white">${title}</h4>
                        <p class="text-[10px] text-slate-500 mt-1 leading-tight">${msg}</p>
                    </div>
                </div>
            `;
            list.prepend(item);
        }

        window.addNotificationItem = function(title, msg, type) {
            window.renderNotifItem(title, msg, type);
            window.notifs.push({ title, msg, type, time: new Date().getTime() });
            if (window.notifs.length > 50) window.notifs.shift(); // keep last 50
            localStorage.setItem('sams_notifs', JSON.stringify(window.notifs));
        }

        // Always render saved notifs on the current DOM immediately
        window.notifs.forEach(n => window.renderNotifItem(n.title, n.msg, n.type));
        if (window.notifCount > 0) {
            const badge = document.getElementById('notif-badge');
            if (badge) { badge.innerText = window.notifCount; badge.classList.remove('hidden'); }
        }

        function initSidebarScroll() {
            const sidebarScroll = document.getElementById('sidebar-scroll-area');
            if (sidebarScroll) {
                const scrollPos = sessionStorage.getItem('sidebarScrollPos');
                if (scrollPos) sidebarScroll.scrollTop = parseInt(scrollPos, 10);
                
                // On Turbo before-cache or beforeunload
                document.addEventListener('turbo:before-cache', function () {
                    sessionStorage.setItem('sidebarScrollPos', sidebarScroll.scrollTop);
                }, { once: true });
            }
        }
        
        // Execute immediately for the current view
        initSidebarScroll();


        // --- Global Singleton Initialization (Run ONCE per tab) ---
        if (!window._samsAppInitialized) {
            window._samsAppInitialized = true;

            document.addEventListener("turbo:load", initSidebarScroll);

            // Handle speed control clicks globally
            document.addEventListener('click', function(e) {
                const btn = e.target.closest('.global-speed-btn');
                if (btn) {
                    const speed = parseInt(btn.getAttribute('data-speed'));
                    if (window.globalConnection && window.globalConnection.state === signalR.HubConnectionState.Connected) {
                        window.globalConnection.invoke("SetSpeedMultiplier", speed)
                            .then(() => toastr.success(`Simulation speed set to ${speed}x`, "Time Sync"))
                            .catch(err => console.error(err.toString()));
                    } else {
                        toastr.error("Cannot change speed, disconnected from server.", "Error");
                    }
                }
            });

            // Handle global clicks outside dropdown
            document.addEventListener('click', function(e) {
                const drop = document.getElementById('notif-dropdown');
                if (drop && !drop.classList.contains('hidden') && !e.target.closest('#notif-dropdown') && !e.target.closest('#notif-bell-btn')) {
                    drop.classList.add('hidden');
                }
            });

            // --- SignalR ---
            window.globalConnection = new signalR.HubConnectionBuilder()
                .withUrl("/flightHub")
                .build();

            window.globalConnection.on("TimeUpdate", function (data) {
                const clock = document.getElementById("virtual-clock");
                const speed = document.getElementById("clock-speed");
                if (clock) clock.innerText = data.virtualTime;
                if (speed) speed.innerText = data.speed + "x";
                
                // Sync speed button states
                document.querySelectorAll('.global-speed-btn').forEach(btn => {
                    const s = parseInt(btn.getAttribute('data-speed'));
                    if (s === data.speed) {
                        btn.classList.add('bg-blue-500', 'text-white');
                        btn.classList.remove('text-slate-500', 'hover:bg-slate-100', 'dark:hover:bg-slate-700');
                    } else {
                        btn.classList.remove('bg-blue-500', 'text-white');
                        btn.classList.add('text-slate-500', 'hover:bg-slate-100', 'dark:hover:bg-slate-700');
                    }
                });

                if (data.weatherType) {
                    const lbl = document.getElementById("weather-label");
                    const ico = document.getElementById("weather-icon");
                    const widget = document.getElementById("weather-widget");
                    if (lbl) lbl.innerText = data.weatherType;
                    if (ico) {
                        if (data.weatherType === "Storm") { ico.innerText = "thunderstorm"; if (widget) { widget.style.borderColor = "#ef4444"; widget.style.backgroundColor = "rgba(254,242,242,0.7)"; } }
                        else if (data.weatherType === "Fog") { ico.innerText = "foggy"; if (widget) { widget.style.borderColor = "#f59e0b"; widget.style.backgroundColor = "rgba(255,251,235,0.7)"; } }
                        else { ico.innerText = "wb_sunny"; if (widget) { widget.style.borderColor = ""; widget.style.backgroundColor = ""; } }
                    }
                }
            });

            window.globalConnection.on("WeatherChanged", function (data) {
                if (data.type === "Storm") {
                    toastr.error("⛈️ Weather Alert: " + data.description, "WEATHER SYSTEM");
                }
                const dot = document.getElementById('atctower-notif-dot');
                if (dot) dot.classList.remove('hidden');
                addNotificationItem("Weather Changed", data.description, "flight");
            });

            window.globalConnection.on("BoardingProgress", function (data) {
                if (data.boarded === data.total) {
                    // Quiet notification instead of toastr spam
                    window.addNotificationItem("Boarding Complete", data.flightNumber + " boarding finished.", "flight");
                }
            });

            window.globalConnection.on("FlightStateChanged", function (data) {
                let msg = "Flight <b class='font-mono'>" + data.flightNumber + "</b> status: <span class='opacity-75'>" + data.oldStatus + "</span> &rarr; <b>" + data.newStatus + "</b>";
                if (data.newStatus && data.newStatus.includes("EMERGENCY")) {
                    toastr.error("🚨 ATC ALERT!<br/>" + msg, "EMERGENCY");
                }
                // Quietly add to the notification list without spamming toastr popups
                window.notifCount++;
                const badge = document.getElementById("notif-badge");
                if (badge) { badge.innerText = window.notifCount; badge.classList.remove("hidden"); badge.classList.add("animate-bounce"); setTimeout(() => badge.classList.remove("animate-bounce"), 1000); }
                window.addNotificationItem("Flight Update", "Flight " + data.flightNumber + " → " + data.newStatus, "flight");
                const alertDot = document.getElementById('alerts-notif-dot');
                if (alertDot) alertDot.classList.remove('hidden');
            });

            window.globalConnection.on("SecurityAlert", function (data) {
                if (data.level === "Critical") {
                    toastr.error("🚨 CHECKPOINT " + data.checkpointId + ":<br/>" + data.message, "SECURITY - " + data.level);
                }
                window.notifCount++;
                const badge = document.getElementById("notif-badge");
                if (badge) { badge.innerText = window.notifCount; badge.classList.remove("hidden"); }
                window.addNotificationItem("Security Alert [" + data.level + "]", "CP: " + data.checkpointId + " - " + data.message, "security");
                const secDot = document.getElementById('security-notif-dot');
                if (secDot) secDot.classList.remove('hidden');
            });

            window.globalConnection.start().catch(err => console.error(err.toString()));
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
