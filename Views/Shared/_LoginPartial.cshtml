@using Microsoft.AspNetCore.Identity
@using TMPP_Aeroport.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="flex items-center gap-4 text-slate-500 font-['Space_Grotesk'] text-[11px] tracking-widest uppercase">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="flex items-center gap-2">
            <span class="text-cyan-400">@User.Identity?.Name</span>
        </li>
        <li>
            <form class="inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Airport", new { area = "" })">
                <button type="submit" class="hover:text-cyan-300 transition-all cursor-pointer bg-transparent border-none uppercase tracking-widest text-[11px]">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li>
            <a class="hover:text-cyan-300 transition-all cursor-pointer" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li>
            <a class="hover:text-cyan-300 transition-all cursor-pointer bg-cyan-500/20 text-cyan-300 px-3 py-1 rounded" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>
