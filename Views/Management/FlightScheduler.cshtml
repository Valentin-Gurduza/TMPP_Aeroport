@model IEnumerable<TMPP_Aeroport.Models.Flight>
@{
    ViewData["Title"] = "Flight Scheduler";
    Layout = "~/Views/Shared/_LayoutCorporate.cshtml";
    
    var sampleBoardingPass = ViewBag.SampleBoardingPass as TMPP_Aeroport.Domain.AbstractFactory.BoardingPass;
    var sampleBaggageTag = ViewBag.SampleBaggageTag as TMPP_Aeroport.Domain.AbstractFactory.BaggageTag;
}

<div class="max-w-6xl mx-auto space-y-8 animate-fade-in-up">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-800 dark:text-slate-200 tracking-tight flex items-center">
                <span class="material-symbols-rounded mr-3 text-4xl text-blue-600">event</span>
                Flight Scheduler
            </h1>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left: Clone Flight (Prototype) -->
        <div class="lg:col-span-2 bg-white dark:bg-slate-900 dark:text-slate-200 border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
            <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 border-b border-slate-200 px-6 py-4 flex items-center justify-between">
                <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200 flex items-center">
                    <span class="material-symbols-rounded mr-2 text-blue-600">content_copy</span>
                    Recurrent Flight Scheduling
                </h2>
                <div class="flex items-center gap-4">
                    <button type="button" onclick="delayAllFlights()" class="px-3 py-1 bg-red-50 text-red-700 border border-red-200 rounded-lg text-xs font-bold shadow-sm hover:bg-red-100 transition flex items-center" title="Delay All +2h">
                        <span class="material-symbols-rounded text-[16px] mr-1">schedule</span> Delay All +2h
                    </button>
                </div>
            </div>
            
            <div class="p-0 overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 text-xs uppercase tracking-wider font-bold">
                            <th class="p-4 border-b border-slate-200 dark:border-slate-700">Flight</th>
                            <th class="p-4 border-b border-slate-200 dark:border-slate-700">Route</th>
                            <th class="p-4 border-b border-slate-200 dark:border-slate-700">Status</th>
                            <th class="p-4 border-b border-slate-200 dark:border-slate-700 text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800 text-sm font-medium text-slate-700 dark:text-slate-300">
                        @foreach (var f in Model)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800 dark:bg-slate-900 transition">
                                <td class="p-4">
                                    <div class="flex items-center">
                                        <span class="material-symbols-rounded text-slate-400 mr-2 text-base">flight</span>
                                        <span class="font-bold text-slate-800 dark:text-slate-200">@f.FlightNumber</span>
                                    </div>
                                </td>
                                <td class="p-4">@f.Origin → @f.Destination</td>
                                <td class="p-4">
                                    <span class="px-2 py-1 rounded-md text-xs font-bold bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400">Scheduled</span>
                                </td>
                                <td class="p-4 text-right flex items-center justify-end gap-2">
                                    <!-- Edit & Undo Modal Trigger -->
                                    <button type="button" onclick="openEditModal(@f.Id, '@f.Gate', '@f.DepartureTime.ToString("yyyy-MM-ddTHH:mm")')" class="inline-flex items-center px-3 py-1.5 bg-amber-50 text-amber-700 border border-amber-200 rounded-lg hover:bg-amber-100 transition text-xs font-bold shadow-sm">
                                        <span class="material-symbols-rounded text-sm mr-1">edit</span> Edit
                                    </button>
                                    <!-- Clone Modal Trigger -->
                                    <button type="button" onclick="cloneFlight(@f.Id)" class="inline-flex items-center px-3 py-1.5 bg-green-50 text-green-700 border border-green-200 rounded-lg hover:bg-green-100 transition text-xs font-bold shadow-sm" title="Clone (Prototype)">
                                        <span class="material-symbols-rounded text-sm mr-1">content_copy</span> Clone
                                    </button>
                                    <button type="button" onclick="undoFlight(@f.Id)" class="inline-flex items-center px-3 py-1.5 bg-slate-100 text-slate-700 dark:text-slate-300 border border-slate-300 rounded-lg hover:bg-slate-200 transition text-xs font-bold shadow-sm" title="Undo">
                                        <span class="material-symbols-rounded text-sm">undo</span>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination Controls -->
            @{
                var paginatedList = Model as TMPP_Aeroport.Models.PaginatedList<TMPP_Aeroport.Models.Flight>;
                var prevDisabled = (paginatedList == null || !paginatedList.HasPreviousPage) ? "opacity-50 cursor-not-allowed pointer-events-none" : "";
                var nextDisabled = (paginatedList == null || !paginatedList.HasNextPage) ? "opacity-50 cursor-not-allowed pointer-events-none" : "";
            }
            <div class="bg-slate-50 dark:bg-slate-800 border-t border-slate-200 dark:border-slate-700 px-6 py-3 flex items-center justify-between">
                <span class="text-sm text-slate-600 dark:text-slate-400">
                    Page <span class="font-bold">@(paginatedList?.PageIndex ?? 1)</span> of <span class="font-bold">@(paginatedList?.TotalPages ?? 1)</span>
                </span>
                <div class="flex items-center gap-2">
                    <a asp-action="FlightScheduler"
                       asp-route-pageNumber="@((paginatedList?.PageIndex ?? 1) - 1)"
                       class="px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg text-sm font-medium bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition @prevDisabled">
                        Previous
                    </a>
                    <a asp-action="FlightScheduler"
                       asp-route-pageNumber="@((paginatedList?.PageIndex ?? 1) + 1)"
                       class="px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg text-sm font-medium bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition @nextDisabled">
                        Next
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>



<!-- Edit Flight Modal -->
<div id="edit-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-slate-900 bg-opacity-75 transition-opacity backdrop-blur-sm" aria-hidden="true" onclick="closeEditModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div class="inline-block align-bottom bg-white dark:bg-slate-900 dark:text-slate-200 rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-md sm:w-full">
            <div class="bg-white dark:bg-slate-900 dark:text-slate-200 px-6 pt-5 pb-6">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-amber-100 sm:mx-0 sm:h-10 sm:w-10">
                        <span class="material-symbols-rounded text-amber-600">edit</span>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-lg leading-6 font-bold text-slate-900" id="modal-title">Edit Flight</h3>
                        <div class="mt-4 space-y-4">
                            <input type="hidden" id="edit-flight-id" />
                            <div>
                                <label class="block text-xs font-semibold text-slate-500 uppercase">Gate</label>
                                <input type="text" id="edit-gate" class="w-full mt-1 px-3 py-2 border rounded-lg focus:ring-amber-500 focus:border-amber-500 dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200 focus:dark:border-blue-500" />
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-500 uppercase">Departure Time</label>
                                <input type="datetime-local" id="edit-time" class="w-full mt-1 px-3 py-2 border rounded-lg focus:ring-amber-500 focus:border-amber-500 dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200 focus:dark:border-blue-500" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                <button type="button" onclick="saveEdit()" class="w-full inline-flex justify-center rounded-lg border border-transparent shadow-sm px-4 py-2 bg-amber-600 text-base font-medium text-white hover:bg-amber-700 focus:outline-none sm:ml-3 sm:w-auto sm:text-sm">
                    Save Changes
                </button>
                <button type="button" onclick="closeEditModal()" class="mt-3 w-full inline-flex justify-center rounded-lg border border-slate-300 shadow-sm px-4 py-2 bg-white dark:bg-slate-900 dark:text-slate-200 text-base font-medium text-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 focus:outline-none sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditModal(id, gate, time) {
            document.getElementById('edit-flight-id').value = id;
            document.getElementById('edit-gate').value = gate;
            document.getElementById('edit-time').value = time;
            document.getElementById('edit-modal').classList.remove('hidden');
        }

        function closeEditModal() {
            document.getElementById('edit-modal').classList.add('hidden');
        }

        async function saveEdit() {
            const id = document.getElementById('edit-flight-id').value;
            const gate = document.getElementById('edit-gate').value;
            const time = document.getElementById('edit-time').value;

            try {
                const formData = new FormData();
                formData.append('flightId', id);
                formData.append('newGate', gate);
                formData.append('newTime', time);

                const response = await fetch('/Management/EditFlightConfig', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();
                
                if (data.success) {
                    toastr.success(data.message);
                    closeEditModal();
                    closeEditModal();
                    // Optional: refresh data using fetch or turbo, for now just show toast
                } else {
                    toastr.error("Failed to edit flight.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function undoFlight(id) {
            try {
                const formData = new FormData();
                formData.append('flightId', id);

                const response = await fetch('/Management/UndoFlightConfig', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();
                
                if (data.success) {
                    toastr.success(data.message);
                    // Optional: refresh data using fetch or turbo, for now just show toast
                } else {
                    toastr.warning(data.message);
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function cloneFlight(id) {
            try {
                const response = await fetch('/Management/CloneFlight', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ id: id })
                });
                const data = await response.json();
                
                if (data.success) {
                    toastr.success(data.message);
                    setTimeout(() => location.reload(), 1500); // We do need to reload here because the table needs to show the new flight
                } else {
                    toastr.error(data.message || "Failed to clone flight.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function delayAllFlights() {
            try {
                const formData = new FormData();
                formData.append('hoursDelay', 2);

                const response = await fetch('/Management/DelayAllFlights', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();
                
                if (data.success) {
                    toastr.success(data.message);
                    // Optional: refresh data using fetch or turbo, for now just show toast
                } else {
                    toastr.error("Failed to delay flights.");
                }
            } catch (err) {
                console.error(err);
            }
        }


    </script>
}
