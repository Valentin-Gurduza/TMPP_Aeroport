@model IEnumerable<TMPP_Aeroport.Models.Flight>
@{
    ViewData["Title"] = "Flight Scheduler";
    Layout = "~/Views/Shared/_LayoutCorporate.cshtml";
    
    var sampleBoardingPass = ViewBag.SampleBoardingPass as TMPP_Aeroport.Domain.AbstractFactory.BoardingPass;
    var sampleBaggageTag = ViewBag.SampleBaggageTag as TMPP_Aeroport.Domain.AbstractFactory.BaggageTag;
}

<div class="max-w-6xl mx-auto space-y-8 animate-fade-in-up">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight flex items-center">
                <span class="material-symbols-outlined mr-3 text-4xl text-blue-600">event</span>
                Flight Scheduler
            </h1>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left: Clone Flight (Prototype) -->
        <div class="lg:col-span-2 bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
            <div class="bg-slate-50 border-b border-slate-200 px-6 py-4 flex items-center justify-between">
                <h2 class="text-lg font-bold text-slate-800 flex items-center">
                    <span class="material-symbols-outlined mr-2 text-blue-600">content_copy</span>
                    Recurrent Flight Scheduling
                </h2>
                <div class="flex items-center gap-4">
                    <button type="button" onclick="delayAllFlights()" class="px-3 py-1 bg-red-50 text-red-700 border border-red-200 rounded-lg text-xs font-bold shadow-sm hover:bg-red-100 transition flex items-center" title="Delay All +2h">
                        <span class="material-symbols-outlined text-[16px] mr-1">schedule</span> Delay All +2h
                    </button>
                </div>
            </div>
            
            <div class="p-0 overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-100 text-slate-500 text-xs uppercase tracking-wider font-bold">
                            <th class="p-4 border-b border-slate-200">Flight</th>
                            <th class="p-4 border-b border-slate-200">Route</th>
                            <th class="p-4 border-b border-slate-200">Status</th>
                            <th class="p-4 border-b border-slate-200 text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-sm font-medium text-slate-700">
                        @foreach (var f in Model.Take(6))
                        {
                            <tr class="hover:bg-slate-50 transition">
                                <td class="p-4">
                                    <div class="flex items-center">
                                        <span class="material-symbols-outlined text-slate-400 mr-2 text-base">flight</span>
                                        <span class="font-bold text-slate-800">@f.FlightNumber</span>
                                    </div>
                                </td>
                                <td class="p-4">OTP → @f.Destination</td>
                                <td class="p-4">
                                    <span class="px-2 py-1 rounded-md text-xs font-bold bg-slate-100 border border-slate-200 text-slate-600">Scheduled</span>
                                </td>
                                <td class="p-4 text-right flex items-center justify-end gap-2">
                                    <!-- Edit & Undo Modal Trigger -->
                                    <button type="button" onclick="openEditModal(@f.Id, '@f.Gate', '@f.DepartureTime.ToString("yyyy-MM-ddTHH:mm")')" class="inline-flex items-center px-3 py-1.5 bg-amber-50 text-amber-700 border border-amber-200 rounded-lg hover:bg-amber-100 transition text-xs font-bold shadow-sm">
                                        <span class="material-symbols-outlined text-sm mr-1">edit</span> Edit
                                    </button>
                                    <button type="button" onclick="undoFlight(@f.Id)" class="inline-flex items-center px-3 py-1.5 bg-slate-100 text-slate-700 border border-slate-300 rounded-lg hover:bg-slate-200 transition text-xs font-bold shadow-sm" title="Undo">
                                        <span class="material-symbols-outlined text-sm">undo</span>
                                    </button>
                                    <!-- Clone -->
                                    <button type="button" onclick="cloneFlight(@f.Id)" class="inline-flex items-center px-3 py-1.5 bg-blue-50 text-blue-700 border border-blue-200 rounded-lg hover:bg-blue-100 transition text-xs font-bold shadow-sm">
                                        <span class="material-symbols-outlined text-sm mr-1">content_copy</span> Clone
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Right: Abstract Factory -->
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden h-full">
                <div class="bg-slate-50 border-b border-slate-200 px-6 py-4 flex items-center justify-between">
                    <h2 class="text-lg font-bold text-slate-800 flex items-center">
                        <span class="material-symbols-outlined mr-2 text-green-600">factory</span>
                        Document Generator
                    </h2>
                </div>
                
                <div class="p-6">
                    <div class="mb-6">
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Test Document Generation</label>
                        <div class="flex space-x-2">
                            <select id="doc-type" class="flex-grow px-3 py-2 rounded-lg border border-slate-300 text-sm font-medium focus:border-green-500 focus:ring-2 focus:ring-green-200 outline-none">
                                <option value="economy">Economy Class</option>
                                <option value="business">Business Class</option>
                            </select>
                            <button type="button" onclick="generateDocument()" class="px-4 py-2 bg-green-600 text-white font-bold rounded-lg hover:bg-green-700 transition shadow-sm text-sm">
                                Generate
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Tailwind Modal for Document Result -->
<div id="doc-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        
        <div class="fixed inset-0 bg-slate-900 bg-opacity-75 transition-opacity backdrop-blur-sm" aria-hidden="true" onclick="closeModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

        <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
            <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div id="modal-icon-bg" class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full sm:mx-0 sm:h-10 sm:w-10">
                        <span class="material-symbols-outlined" id="modal-icon">receipt_long</span>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-lg leading-6 font-bold text-slate-900" id="modal-title">Generated Documents</h3>
                        <div class="mt-4 space-y-4" id="modal-content">
                            <!-- Content injected by JS -->
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-slate-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                <button type="button" onclick="closeModal()" class="w-full inline-flex justify-center rounded-lg border border-transparent shadow-sm px-4 py-2 bg-slate-800 text-base font-medium text-white hover:bg-slate-900 focus:outline-none sm:ml-3 sm:w-auto sm:text-sm">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Flight Modal -->
<div id="edit-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <div class="fixed inset-0 bg-slate-900 bg-opacity-75 transition-opacity backdrop-blur-sm" aria-hidden="true" onclick="closeEditModal()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-md sm:w-full">
            <div class="bg-white px-6 pt-5 pb-6">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-amber-100 sm:mx-0 sm:h-10 sm:w-10">
                        <span class="material-symbols-outlined text-amber-600">edit</span>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-lg leading-6 font-bold text-slate-900" id="modal-title">Edit Flight</h3>
                        <div class="mt-4 space-y-4">
                            <input type="hidden" id="edit-flight-id" />
                            <div>
                                <label class="block text-xs font-semibold text-slate-500 uppercase">Gate</label>
                                <input type="text" id="edit-gate" class="w-full mt-1 px-3 py-2 border rounded-lg focus:ring-amber-500 focus:border-amber-500" />
                            </div>
                            <div>
                                <label class="block text-xs font-semibold text-slate-500 uppercase">Departure Time</label>
                                <input type="datetime-local" id="edit-time" class="w-full mt-1 px-3 py-2 border rounded-lg focus:ring-amber-500 focus:border-amber-500" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-slate-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                <button type="button" onclick="saveEdit()" class="w-full inline-flex justify-center rounded-lg border border-transparent shadow-sm px-4 py-2 bg-amber-600 text-base font-medium text-white hover:bg-amber-700 focus:outline-none sm:ml-3 sm:w-auto sm:text-sm">
                    Save Changes
                </button>
                <button type="button" onclick="closeEditModal()" class="mt-3 w-full inline-flex justify-center rounded-lg border border-slate-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-slate-700 hover:bg-slate-50 focus:outline-none sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditModal(id, gate, time) {
            document.getElementById('edit-flight-id').value = id;
            document.getElementById('edit-gate').value = gate;
            document.getElementById('edit-time').value = time;
            document.getElementById('edit-modal').classList.remove('hidden');
        }

        function closeEditModal() {
            document.getElementById('edit-modal').classList.add('hidden');
        }

        async function saveEdit() {
            const id = document.getElementById('edit-flight-id').value;
            const gate = document.getElementById('edit-gate').value;
            const time = document.getElementById('edit-time').value;

            try {
                const formData = new FormData();
                formData.append('flightId', id);
                formData.append('newGate', gate);
                formData.append('newTime', time);

                const response = await fetch('/Management/EditFlightConfig', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();
                
                if (data.success) {
                    toastr.success(data.message);
                    closeEditModal();
                    setTimeout(() => location.reload(), 1500);
                } else {
                    toastr.error("Failed to edit flight.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function undoFlight(id) {
            try {
                const formData = new FormData();
                formData.append('flightId', id);

                const response = await fetch('/Management/UndoFlightConfig', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();
                
                if (data.success) {
                    toastr.success(data.message);
                    setTimeout(() => location.reload(), 1500);
                } else {
                    toastr.warning(data.message);
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function delayAllFlights() {
            try {
                const formData = new FormData();
                formData.append('hoursDelay', 2);

                const response = await fetch('/Management/DelayAllFlights', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();
                
                if (data.success) {
                    toastr.success(data.message);
                    setTimeout(() => location.reload(), 1500);
                } else {
                    toastr.error("Failed to delay flights.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function cloneFlight(id) {
            try {
                const response = await fetch(`/Management/CloneFlight?id=${id}`, {
                    method: 'POST'
                });
                const data = await response.json();
                
                if (data.success) {
                    toastr.success(`Flight cloned successfully. New flight: ${data.clonedFlight}`);
                    setTimeout(() => location.reload(), 1500);
                } else {
                    toastr.error("Failed to clone flight.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function generateDocument() {
            const type = document.getElementById('doc-type').value;
            try {
                const response = await fetch(`/Management/GenerateDocument?type=${type}`);
                const data = await response.json();
                
                if (data.success) {
                    showModal(data);
                }
            } catch (err) {
                console.error(err);
            }
        }

        function showModal(data) {
            const isBusiness = data.ticketType.toLowerCase() === 'business';
            
            // Icon styling
            const iconBg = document.getElementById('modal-icon-bg');
            const icon = document.getElementById('modal-icon');
            iconBg.className = `mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full sm:mx-0 sm:h-10 sm:w-10 ${isBusiness ? 'bg-amber-100 text-amber-600' : 'bg-green-100 text-green-600'}`;
            
            // Content
            const content = document.getElementById('modal-content');
            let html = `
                <!-- Boarding Pass -->
                <div class="border-2 border-dashed ${isBusiness ? 'border-amber-300 bg-amber-50 text-amber-900' : 'border-slate-300 bg-slate-50 text-slate-700'} p-4 rounded-xl relative">
                    <span class="absolute -top-3 left-4 bg-white px-2 text-xs font-bold uppercase ${isBusiness ? 'text-amber-600' : 'text-slate-500'}">Boarding Pass</span>
                    <div class="font-black text-xl mb-1">${data.passenger}</div>
                    <div class="text-sm font-medium mb-3">Flight: ${data.flight}</div>
                    ${data.details}
                </div>
                
                <!-- Baggage Tag -->
                <div class="border-2 border-dashed ${isBusiness ? 'border-amber-300 bg-amber-50 text-amber-900' : 'border-slate-300 bg-slate-50 text-slate-700'} p-4 rounded-xl relative">
                    <span class="absolute -top-3 left-4 bg-white px-2 text-xs font-bold uppercase ${isBusiness ? 'text-amber-600' : 'text-slate-500'}">Baggage Tag</span>
                    <div class="font-black text-lg mb-2">Code: ${data.tagCode}</div>
                    Color: ${data.tagColor}
                </div>
            `;
            content.innerHTML = html;
            
            document.getElementById('doc-modal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('doc-modal').classList.add('hidden');
        }
    </script>
}
