@model IEnumerable<string>
@{
    ViewData["Title"] = "System Audit Logs";
    Layout = "~/Views/Shared/_LayoutCorporate.cshtml";
}

<div class="max-w-5xl mx-auto space-y-6 animate-fade-in-up">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-800 dark:text-slate-200 tracking-tight flex items-center">
                <span class="material-symbols-rounded mr-3 text-4xl text-blue-600">admin_panel_settings</span>
                System Audit Logs
            </h1>
        </div>
        <div class="bg-slate-100 border border-slate-200 px-4 py-2 rounded-xl flex items-center space-x-2">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-blue-500"></span>
            </span>
            <span class="text-sm font-bold text-slate-600 uppercase tracking-wider">Live Capture</span>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 dark:text-slate-200 border border-slate-200 rounded-2xl shadow-sm overflow-hidden h-full flex flex-col">
        <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 border-b border-slate-200 px-6 py-4 flex items-center justify-between">
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">Terminal Output</h2>
            <div class="flex items-center space-x-4 w-1/2 justify-end">
                <div class="relative w-full max-w-sm">
                    <span class="material-symbols-rounded absolute left-3 top-2.5 text-slate-400">search</span>
                    <input type="text" id="log-search" onkeyup="filterLogs()" placeholder="Search logs..." class="w-full pl-10 pr-4 py-2 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition text-sm dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200 focus:dark:border-blue-500">
                </div>
                <button class="text-slate-400 hover:text-slate-600 transition" onclick="location.reload()" title="Refresh Logs">
                    <span class="material-symbols-rounded mt-1">refresh</span>
                </button>
            </div>
        </div>
        
        <div class="p-0 bg-slate-900 flex-grow h-[600px] overflow-y-auto font-mono text-sm">
            @if (Model != null && Model.Any())
            {
                <div class="p-6 space-y-2" id="logs-container">
                    @foreach (var log in Model)
                    {
                        var timestamp = log.Length > 20 ? log.Substring(0, 19) : "";
                        var msg = log.Length > 20 ? log.Substring(20) : log;
                        
                        <div class="log-row text-slate-300 hover:bg-slate-800 p-1 rounded transition">
                            <span class="text-slate-500 mr-2">@timestamp</span>
                            @if (msg.Contains("[Builder]")) { <span class="text-amber-400 font-bold">@msg</span> }
                            else if (msg.Contains("Error") || msg.Contains("Failed")) { <span class="text-red-400 font-bold">@msg</span> }
                            else { <span class="text-green-400">@msg</span> }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="p-10 text-center text-slate-500 flex flex-col items-center">
                    <span class="material-symbols-rounded text-5xl mb-4 opacity-50">description</span>
                    No audit logs available yet.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterLogs() {
            let input = document.getElementById('log-search');
            let filter = input.value.toLowerCase();
            let rows = document.getElementsByClassName('log-row');

            for (let i = 0; i < rows.length; i++) {
                let txtValue = rows[i].textContent || rows[i].innerText;
                if (txtValue.toLowerCase().indexOf(filter) > -1) {
                    rows[i].style.display = "";
                } else {
                    rows[i].style.display = "none";
                }
            }
        }
    </script>
}
