@model dynamic
@{
    ViewData["Title"] = "Analytics & Export";
    Layout = "~/Views/Shared/_LayoutCorporate.cshtml";
    
    var exportData = ViewBag.ExportData as List<string>;
    var format = ViewBag.Format as string;
}

<div class="max-w-5xl mx-auto space-y-6 animate-fade-in-up">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-800 dark:text-slate-200 tracking-tight flex items-center">
                <span class="material-symbols-rounded mr-3 text-4xl text-blue-600">analytics</span>
                System Analytics
            </h1>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-900 dark:text-slate-200 border border-slate-200 rounded-2xl shadow-sm overflow-hidden h-full flex flex-col">
        <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 border-b border-slate-200 px-6 py-4 flex items-center justify-between">
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">Export Controls</h2>
        </div>
        
        <div class="p-6">
            <form action="/Management/Analytics" method="get" class="flex flex-col sm:flex-row items-center space-y-4 sm:space-y-0 sm:space-x-4 mb-6">
                <div class="flex-grow">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Export Format</label>
                    <select name="format" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none font-medium text-slate-700 dark:text-slate-300 dark:bg-slate-900 dark:border-slate-700 dark:text-slate-200">
                        <option value="json" selected="@(format == "json")">JSON Format</option>
                        <option value="xml" selected="@(format == "xml")">XML Format</option>
                    </select>
                </div>
                <div class="pt-6">
                    <button type="submit" class="w-full sm:w-auto px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-bold shadow-md transition flex items-center justify-center">
                        <span class="material-symbols-rounded mr-2 text-sm">settings</span> Generate Data
                    </button>
                </div>
            </form>

            @if (exportData != null)
            {
                <div class="relative bg-slate-900 rounded-xl overflow-hidden shadow-inner">
                    <div class="absolute top-0 left-0 right-0 bg-slate-800 px-4 py-2 flex items-center justify-between border-b border-slate-700">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Preview (@(format?.ToUpper()))</span>
                        <a href="/Management/DownloadAnalytics?format=@format" class="text-xs font-bold text-blue-400 hover:text-blue-300 transition flex items-center">
                            <span class="material-symbols-rounded text-sm mr-1">download</span> Download File
                        </a>
                    </div>
                    <pre class="p-6 pt-12 font-mono text-sm text-slate-300 overflow-x-auto whitespace-pre-wrap h-[400px] overflow-y-auto">@string.Join("\n", exportData)</pre>
                </div>
            }
        </div>
    </div>
</div>
