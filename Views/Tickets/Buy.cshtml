@{
    ViewData["Title"] = "Book Ticket";
    var flight = ViewBag.Flight as TMPP_Aeroport.Models.Flight;
}

<div class="max-w-4xl mx-auto">
    <div class="mb-6 flex items-center gap-4">
        <a asp-controller="Flights" asp-action="Index" class="text-slate-400 hover:text-slate-600 transition">
            <span class="material-symbols-outlined text-2xl">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Book Flight Ticket</h1>
            <p class="text-sm text-slate-500">Select your seat and ticket class.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Flight Details -->
        <div class="lg:col-span-1 bg-white rounded-xl shadow-sm border border-slate-200 p-6 flex flex-col h-fit">
            <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-2xl">flight</span>
            </div>
            <h3 class="font-bold text-slate-800 text-lg">@flight?.FlightNumber</h3>
            <p class="text-slate-500 text-sm mb-4">To @flight?.Destination</p>
            
            <div class="space-y-3 pt-4 border-t border-slate-100 mt-auto">
                <div class="flex justify-between items-center">
                    <span class="text-xs text-slate-400 uppercase tracking-wider font-semibold">DEPARTURE</span>
                    <span class="text-sm font-semibold text-slate-800">@flight?.DepartureTime.ToString("dd MMM, HH:mm")</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-xs text-slate-400 uppercase tracking-wider font-semibold">AIRCRAFT</span>
                    <span class="text-sm font-semibold text-slate-800">@flight?.Aircraft?.Model</span>
                </div>
            </div>
        </div>

        <!-- Booking Form -->
        <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-slate-200 p-6">
            <form asp-action="BuyExecute" method="post" class="space-y-6">
                <input type="hidden" name="flightId" value="@flight?.Id" />
                
                <!-- Ticket Strategy (Lab 6 integration placeholder) -->
                <div>
                    <label class="block text-sm font-semibold text-slate-800 mb-3">Select Fare Class</label>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <label class="cursor-pointer">
                            <input type="radio" name="price" value="120" class="peer sr-only" checked />
                            <div class="p-4 rounded-xl border-2 border-slate-200 peer-checked:border-blue-600 peer-checked:bg-blue-50 transition">
                                <div class="flex justify-between items-center mb-1">
                                    <span class="font-bold text-slate-800">Standard Economy</span>
                                    <span class="font-bold text-blue-600">€120</span>
                                </div>
                                <p class="text-xs text-slate-500">Cabin bag only, random seat allocation.</p>
                            </div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="price" value="350" class="peer sr-only" />
                            <div class="p-4 rounded-xl border-2 border-slate-200 peer-checked:border-amber-500 peer-checked:bg-amber-50 transition">
                                <div class="flex justify-between items-center mb-1">
                                    <span class="font-bold text-slate-800">Business Flex</span>
                                    <span class="font-bold text-amber-600">€350</span>
                                </div>
                                <p class="text-xs text-slate-500">2x bags, lounge access, free changes.</p>
                            </div>
                        </label>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-slate-800 mb-1">Seat Preference</label>
                    <p class="text-xs text-slate-500 mb-3">Choose where you'd like to sit.</p>
                    <select name="seatNumber" class="w-full px-4 py-3 rounded-lg border border-slate-300 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" required>
                        <option value="">-- Select an available seat --</option>
                        <option value="12A">12A (Window)</option>
                        <option value="12B">12B (Middle)</option>
                        <option value="12C">12C (Aisle)</option>
                        <option value="14F">14F (Window)</option>
                        <option value="15D">15D (Aisle)</option>
                    </select>
                </div>

                <div class="pt-6 border-t border-slate-100">
                    <button type="submit" class="w-full py-3.5 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-sm font-bold tracking-wide transition shadow-sm flex justify-center items-center gap-2">
                        Proceed to Payment <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                    </button>
                    <p class="text-center text-xs text-slate-400 mt-3">You won't be charged yet. The ticket will be set to Waiting for Payment.</p>
                </div>
            </form>
        </div>
    </div>
</div>
