@{
    ViewData["Title"] = "Select Seats";
    var flight = ViewBag.Flight as TMPP_Aeroport.Models.Flight;
    var takenSeats = ViewBag.TakenSeats as List<string> ?? new List<string>();
    
    int capacity = flight?.Aircraft?.Capacity ?? 180;
    int rows = (int)Math.Ceiling(capacity / 6.0);
}

<div class="max-w-6xl mx-auto" x-data="seatSelector()">
    <div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div class="flex items-center gap-4">
            <a href="/Tickets/Book" class="flex h-10 w-10 items-center justify-center rounded-full bg-white text-gray-500 shadow-sm hover:bg-gray-50 hover:text-gray-700 transition dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-gray-300">
                <span class="material-symbols-rounded">arrow_back</span>
            </a>
            <div>
                <h1 class="text-2xl font-bold text-gray-800 dark:text-white/90">Select Your Seats</h1>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Flight @flight?.FlightNumber to @flight?.Destination</p>
            </div>
        </div>
        
        <!-- Summary Pill -->
        <div class="flex items-center gap-3 bg-white dark:bg-gray-800 px-4 py-2.5 rounded-full shadow-sm border border-gray-200 dark:border-gray-700">
            <span class="material-symbols-rounded text-blue-500">airline_seat_recline_extra</span>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                <span x-text="selectedSeats.length">0</span> seats selected
            </span>
            <div class="h-4 w-px bg-gray-300 dark:bg-gray-600 mx-1"></div>
            <span class="text-sm font-bold text-gray-900 dark:text-white" x-text="'€' + (selectedSeats.length * basePrice)">€0</span>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
        
        <!-- Airplane Visualization -->
        <div class="xl:col-span-2">
            <div class="bg-gray-100 dark:bg-gray-900/50 rounded-[3rem] border-8 border-white dark:border-gray-800 shadow-xl overflow-hidden relative max-h-[800px] flex flex-col">
                
                <!-- Cockpit -->
                <div class="h-32 bg-gray-200 dark:bg-gray-800 rounded-t-[100%] flex flex-col items-center justify-end pb-4 relative overflow-hidden">
                    <div class="absolute top-8 w-24 h-8 bg-blue-900/20 dark:bg-black/40 rounded-full blur-sm"></div>
                    <span class="material-symbols-rounded text-gray-400 dark:text-gray-600 text-3xl">flight</span>
                    <span class="text-xs font-bold text-gray-500 dark:text-gray-500 mt-2 tracking-widest uppercase">Front</span>
                </div>
                
                <!-- Cabin -->
                <div class="flex-1 overflow-y-auto px-8 py-8 no-scrollbar relative">
                    <div class="max-w-md mx-auto space-y-4">
                        @for (int r = 1; r <= rows; r++)
                        {
                            <div class="flex items-center justify-center gap-6">
                                <!-- Left side: A, B, C -->
                                <div class="flex gap-2">
                                    @foreach (var col in new[] { "A", "B", "C" })
                                    {
                                        string seatId = $"{r}{col}";
                                        bool isTaken = takenSeats.Contains(seatId);
                                        
                                        <button type="button" 
                                                @@click="toggleSeat('@seatId')"
                                                :class="getSeatClass('@seatId', @isTaken.ToString().ToLower())"
                                                class="w-10 h-10 rounded-t-lg rounded-b-sm border-2 transition-all duration-200 flex items-center justify-center relative group focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-1 dark:focus:ring-offset-gray-900 @(isTaken ? "cursor-not-allowed border-gray-300 bg-gray-200 dark:border-gray-700 dark:bg-gray-800" : "cursor-pointer")">
                                            <span class="text-[10px] font-bold @(isTaken ? "text-gray-400 dark:text-gray-600" : "")" 
                                                  :class="selectedSeats.includes('@seatId') ? 'text-white' : 'text-gray-600 dark:text-gray-400'">
                                                @seatId
                                            </span>
                                            @if(isTaken)
                                            {
                                                <span class="absolute material-symbols-rounded text-gray-400 dark:text-gray-600 text-[16px]">close</span>
                                            }
                                        </button>
                                    }
                                </div>
                                
                                <!-- Aisle -->
                                <div class="w-6 flex justify-center">
                                    <span class="text-[10px] font-bold text-gray-400 dark:text-gray-600">@r</span>
                                </div>
                                
                                <!-- Right side: D, E, F -->
                                <div class="flex gap-2">
                                    @foreach (var col in new[] { "D", "E", "F" })
                                    {
                                        string seatId = $"{r}{col}";
                                        bool isTaken = takenSeats.Contains(seatId);
                                        
                                        <button type="button" 
                                                @@click="toggleSeat('@seatId')"
                                                :class="getSeatClass('@seatId', @isTaken.ToString().ToLower())"
                                                class="w-10 h-10 rounded-t-lg rounded-b-sm border-2 transition-all duration-200 flex items-center justify-center relative group focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-1 dark:focus:ring-offset-gray-900 @(isTaken ? "cursor-not-allowed border-gray-300 bg-gray-200 dark:border-gray-700 dark:bg-gray-800" : "cursor-pointer")">
                                            <span class="text-[10px] font-bold @(isTaken ? "text-gray-400 dark:text-gray-600" : "")" 
                                                  :class="selectedSeats.includes('@seatId') ? 'text-white' : 'text-gray-600 dark:text-gray-400'">
                                                @seatId
                                            </span>
                                            @if(isTaken)
                                            {
                                                <span class="absolute material-symbols-rounded text-gray-400 dark:text-gray-600 text-[16px]">close</span>
                                            }
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
                
                <!-- Tail -->
                <div class="h-24 bg-gray-200 dark:bg-gray-800 rounded-b-[100%] flex items-start justify-center pt-4">
                     <span class="text-xs font-bold text-gray-500 dark:text-gray-500 tracking-widest uppercase">Rear</span>
                </div>
            </div>
            
            <!-- Legend -->
            <div class="flex items-center justify-center gap-6 mt-6">
                <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-t-lg border-2 border-blue-200 bg-white dark:border-gray-600 dark:bg-gray-800"></div>
                    <span class="text-sm text-gray-600 dark:text-gray-400">Available</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-t-lg border-2 border-blue-600 bg-blue-600 shadow-md shadow-blue-500/30"></div>
                    <span class="text-sm text-gray-600 dark:text-gray-400">Selected</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-t-lg border-2 border-gray-300 bg-gray-200 flex justify-center items-center dark:border-gray-700 dark:bg-gray-800">
                        <span class="material-symbols-rounded text-gray-400 text-[12px]">close</span>
                    </div>
                    <span class="text-sm text-gray-600 dark:text-gray-400">Taken</span>
                </div>
            </div>
        </div>

        <!-- Checkout Form -->
        <div class="xl:col-span-1">
            <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm sticky top-24">
                <h3 class="text-lg font-bold text-gray-800 dark:text-white/90 mb-4">Booking Summary</h3>
                
                <form asp-action="BuyExecute" method="post" @@submit="onSubmit">
                    <input type="hidden" name="flightId" value="@flight?.Id" />
                    <input type="hidden" name="seatNumbers" :value="selectedSeats.join(',')" />
                    
                    <!-- Fare Class -->
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Fare Class</label>
                        <div class="space-y-3">
                            <label class="block relative cursor-pointer group">
                                <input type="radio" name="fareClass" value="Economy" class="peer sr-only" @@change="basePrice = 120" checked />
                                <div class="p-4 rounded-xl border-2 border-gray-200 dark:border-gray-700 peer-checked:border-blue-600 peer-checked:bg-blue-50 dark:peer-checked:bg-blue-900/20 transition-all">
                                    <div class="flex justify-between items-center mb-1">
                                        <span class="font-bold text-gray-800 dark:text-white/90">Standard Economy</span>
                                        <span class="font-bold text-blue-600 dark:text-blue-400">€120</span>
                                    </div>
                                    <p class="text-xs text-gray-500 dark:text-gray-400">Cabin bag only</p>
                                </div>
                            </label>
                            
                            <label class="block relative cursor-pointer group">
                                <input type="radio" name="fareClass" value="Business" class="peer sr-only" @@change="basePrice = 350" />
                                <div class="p-4 rounded-xl border-2 border-gray-200 dark:border-gray-700 peer-checked:border-amber-500 peer-checked:bg-amber-50 dark:peer-checked:bg-amber-900/20 transition-all">
                                    <div class="flex justify-between items-center mb-1">
                                        <span class="font-bold text-gray-800 dark:text-white/90">Business Flex</span>
                                        <span class="font-bold text-amber-600 dark:text-amber-400">€350</span>
                                    </div>
                                    <p class="text-xs text-gray-500 dark:text-gray-400">Lounge access, 2x bags</p>
                                </div>
                            </label>
                        </div>
                    </div>
                    
                    <div class="border-t border-gray-100 dark:border-gray-800 pt-4 mb-6">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-gray-500 dark:text-gray-400">Seats (<span x-text="selectedSeats.length"></span>)</span>
                            <span class="font-medium text-gray-800 dark:text-white/90" x-text="'€' + (selectedSeats.length * basePrice)">€0</span>
                        </div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-gray-500 dark:text-gray-400">Taxes & Fees</span>
                            <span class="font-medium text-green-600 dark:text-green-400">Included</span>
                        </div>
                        <div class="flex justify-between items-center pt-4 border-t border-gray-100 dark:border-gray-800">
                            <span class="text-lg font-bold text-gray-800 dark:text-white/90">Total</span>
                            <span class="text-2xl font-bold text-blue-600 dark:text-blue-400" x-text="'€' + (selectedSeats.length * basePrice)">€0</span>
                        </div>
                    </div>
                    
                    <button type="submit" 
                            :disabled="selectedSeats.length === 0"
                            :class="selectedSeats.length === 0 ? 'bg-gray-300 text-gray-500 cursor-not-allowed dark:bg-gray-700' : 'bg-blue-600 hover:bg-blue-700 text-white shadow-lg shadow-blue-600/30'"
                            class="w-full py-4 rounded-xl text-sm font-bold tracking-wide transition-all flex justify-center items-center gap-2">
                        <span>Checkout</span>
                        <span class="material-symbols-rounded">shopping_cart_checkout</span>
                    </button>
                    
                    <p class="text-center text-xs text-gray-400 mt-4 px-4">
                        You won't be charged yet. The tickets will be added to your account for payment.
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function seatSelector() {
            return {
                selectedSeats: [],
                basePrice: 120, // default economy
                
                toggleSeat(seatId) {
                    // Pre-rendered isTaken seats don't call this because we can check class or we could check here
                    // But Alpine can't easily read Razor variables inside function without passing them.
                    // We handle isTaken via a param in getSeatClass, but for logic we just check DOM class or pass array.
                    // Actually, easiest is to check if it's already in selectedSeats, if not, add it.
                    // If it is, remove it. 
                    // The button click is disabled for taken seats via CSS pointer-events or we just don't do anything if it's taken.
                    // We need to prevent taking taken seats. 
                    // Let's rely on the fact that we can check `selectedSeats`.
                    
                    const index = this.selectedSeats.indexOf(seatId);
                    if (index > -1) {
                        this.selectedSeats.splice(index, 1);
                    } else {
                        // Max 9 seats per transaction
                        if (this.selectedSeats.length < 9) {
                            this.selectedSeats.push(seatId);
                        } else {
                            toastr.warning("You can select up to 9 seats per booking.");
                        }
                    }
                },
                
                getSeatClass(seatId, isTaken) {
                    if (isTaken) return ''; // classes are applied directly in razor for taken
                    
                    if (this.selectedSeats.includes(seatId)) {
                        return 'border-blue-600 bg-blue-600 text-white shadow-md shadow-blue-500/30 scale-105';
                    } else {
                        return 'border-blue-200 bg-white hover:border-blue-400 hover:bg-blue-50 dark:border-gray-600 dark:bg-gray-800 dark:hover:border-blue-500 dark:hover:bg-gray-700 text-gray-600';
                    }
                },
                
                onSubmit(e) {
                    if (this.selectedSeats.length === 0) {
                        e.preventDefault();
                        toastr.error("Please select at least one seat before proceeding.");
                    }
                }
            };
        }
    </script>
}
