@{
    ViewData["Title"] = "Check Flight Prices";
}

<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold mb-4 border border-blue-200">
        <span class="material-symbols-outlined text-[14px] text-blue-600">calculate</span>
        TICKET PRICING ENGINE
    </div>
    <h1 class="text-3xl font-bold text-slate-800">Check Flight Prices</h1>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-blue-50 px-6 py-4 border-b border-blue-100 flex items-center gap-3">
            <span class="material-symbols-outlined text-blue-600">settings</span>
            <h3 class="font-bold text-slate-800 tracking-wide">FLIGHT & ALGORITHM</h3>
        </div>
        
        <div class="p-6">
            <form action="/Tickets/StrategyDemo" method="get" class="space-y-6">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Select Flight</label>
                    <div class="relative">
                        <select name="flightId" onchange="this.form.submit()" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none font-bold text-slate-700 bg-white" required>
                            <option value="">-- Choose a Flight --</option>
                            @if(ViewBag.Flights != null)
                            {
                                foreach(var f in (List<TMPP_Aeroport.Models.Flight>)ViewBag.Flights)
                                {
                                    <option value="@f.Id" selected="@(ViewBag.SelectedFlight?.Id == f.Id)">
                                        @f.FlightNumber: @f.Origin &rarr; @f.Destination (@f.DepartureTime.ToString("dd MMM HH:mm"))
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Pricing Strategy (Loyalty / Timing)</label>
                    <div class="grid gap-3">
                        <label class="relative flex items-start p-4 cursor-pointer rounded-xl border @(ViewBag.SelectedStrategy == "regular" ? "border-blue-500 bg-blue-50" : "border-slate-200 bg-white hover:bg-slate-50") transition">
                            <div class="flex items-center h-5">
                                <input name="strategyType" onchange="this.form.submit()" type="radio" value="regular" class="w-4 h-4 text-blue-600 border-slate-300 focus:ring-blue-500" @(ViewBag.SelectedStrategy == "regular" ? "checked" : "")>
                            </div>
                            <div class="ml-3 flex-1 flex justify-between">
                                <div class="text-sm">
                                    <span class="font-medium text-slate-900 block">Regular Pricing</span>
                                    <span class="text-slate-500">Standard rate applies</span>
                                </div>
                                <span class="text-sm font-bold text-blue-600">1x</span>
                            </div>
                        </label>
                        
                        <label class="relative flex items-start p-4 cursor-pointer rounded-xl border @(ViewBag.SelectedStrategy == "frequentflyer" ? "border-blue-500 bg-blue-50" : "border-slate-200 bg-white hover:bg-slate-50") transition">
                            <div class="flex items-center h-5">
                                <input name="strategyType" onchange="this.form.submit()" type="radio" value="frequentflyer" class="w-4 h-4 text-blue-600 border-slate-300 focus:ring-blue-500" @(ViewBag.SelectedStrategy == "frequentflyer" ? "checked" : "")>
                            </div>
                            <div class="ml-3 flex-1 flex justify-between">
                                <div class="text-sm">
                                    <span class="font-medium text-slate-900 block">Frequent Flyer (@ViewBag.FrequentFlyerPoints pts)</span>
                                    <span class="text-slate-500">Points-based discount</span>
                                </div>
                                <span class="text-sm font-bold text-indigo-600">Variable</span>
                            </div>
                        </label>
                        
                        <label class="relative flex items-start p-4 cursor-pointer rounded-xl border @(ViewBag.SelectedStrategy == "lastminute" ? "border-blue-500 bg-blue-50" : "border-slate-200 bg-white hover:bg-slate-50") transition">
                            <div class="flex items-center h-5">
                                <input name="strategyType" onchange="this.form.submit()" type="radio" value="lastminute" class="w-4 h-4 text-blue-600 border-slate-300 focus:ring-blue-500" @(ViewBag.SelectedStrategy == "lastminute" ? "checked" : "")>
                            </div>
                            <div class="ml-3 flex-1 flex justify-between">
                                <div class="text-sm">
                                    <span class="font-medium text-slate-900 block">Last Minute Surge</span>
                                    <span class="text-slate-500">High demand penalty</span>
                                </div>
                                <span class="text-sm font-bold text-red-600">1.5x</span>
                            </div>
                        </label>
                    </div>
                </div>
    
                <!-- Submit button removed as form auto-submits on change -->
            </form>
        </div>
    </div>

    <div class="bg-gradient-to-br from-slate-800 to-slate-900 rounded-2xl shadow-xl border border-slate-700 text-center flex flex-col justify-center min-h-[400px] relative overflow-hidden">
        <span class="material-symbols-outlined absolute -right-4 -top-4 text-[150px] opacity-10 text-white">sell</span>
        
        <div class="relative z-10 p-8 flex flex-col h-full">
            <div class="w-20 h-20 bg-blue-500/20 rounded-full flex items-center justify-center mx-auto mb-6 border border-blue-500/30 shadow-[0_0_30px_rgba(37,99,235,0.2)] shrink-0">
                <span class="material-symbols-outlined text-blue-400 text-4xl">sell</span>
            </div>
            
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Calculated Ticket Price</h3>
            
            <div class="text-6xl font-black text-white tracking-tighter mb-4 drop-shadow-[0_0_15px_rgba(255,255,255,0.2)]">
                $@(((double)ViewBag.FinalPrice).ToString("0.00"))
            </div>
            
            <div class="inline-flex items-center justify-center gap-2 bg-black/30 border border-white/10 px-4 py-2 rounded-full text-sm text-slate-300 mx-auto w-fit mb-8">
                <span>Calculated using</span>
                <span class="font-bold text-blue-400">@ViewBag.SelectedStrategy.ToString().ToUpper()</span>
                <span>Strategy</span>
            </div>

            <div class="mt-auto">
                @if(ViewBag.SelectedFlight != null)
                {
                    <a href="/Tickets/Buy/@ViewBag.SelectedFlight.Id" class="w-full py-3.5 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl shadow-lg shadow-emerald-900/50 transition inline-flex justify-center items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">shopping_cart</span>
                        Proceed to Book @ViewBag.SelectedFlight.FlightNumber
                    </a>
                }
                else
                {
                    <div class="text-slate-500 text-sm italic">Select a flight to view booking options.</div>
                }
            </div>
        </div>
    </div>
</div>
