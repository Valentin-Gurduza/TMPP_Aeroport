@model TMPP_Aeroport.Models.Ticket
@{
    ViewData["Title"] = "Payment Simulation";
}

<div class="max-w-xl mx-auto">
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold text-slate-800 dark:text-slate-200 mb-2">Checkout</h1>
        <p class="text-slate-500">Complete your payment to issue the ticket.</p>
    </div>

    <div class="bg-white dark:bg-slate-900 dark:text-slate-200 rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <!-- Order Summary -->
        <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 p-6 border-b border-slate-200">
            <div class="flex justify-between items-center mb-4">
                <span class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Flight</span>
                <span class="font-bold text-slate-800 dark:text-slate-200">@Model.Flight?.FlightNumber</span>
            </div>
            <div class="flex justify-between items-center mb-4">
                <span class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Seat</span>
                <span class="font-bold text-slate-800 dark:text-slate-200">@Model.SeatNumber</span>
            </div>
            <div class="flex justify-between items-center text-lg mt-6 pt-4 border-t border-slate-200">
                <span class="font-bold text-slate-800 dark:text-slate-200">Total Amount</span>
                <span class="font-black text-blue-600">€@Model.Price.ToString("0.00")</span>
            </div>
        </div>

        <!-- Payment Form -->
        <div class="p-6">
            <div class="flex items-center gap-2 mb-6">
                <span class="material-symbols-rounded text-green-500">lock</span>
                <span class="text-sm font-medium text-slate-600">Secure simulated payment</span>
            </div>

            <form asp-action="PayExecute" method="post" class="space-y-4">
                <input type="hidden" name="id" value="@Model.Id" />
                
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Card Number</label>
                    <input type="text" value="4522 1122 3344 5566" readonly class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-slate-50 dark:bg-slate-800 dark:text-slate-200 text-slate-600 font-mono text-sm focus:outline-none" />
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Expiry</label>
                        <input type="text" value="12/28" readonly class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-slate-50 dark:bg-slate-800 dark:text-slate-200 text-slate-600 font-mono text-sm focus:outline-none" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">CVC</label>
                        <input type="text" value="123" readonly class="w-full px-4 py-3 rounded-lg border border-slate-300 bg-slate-50 dark:bg-slate-800 dark:text-slate-200 text-slate-600 font-mono text-sm focus:outline-none" />
                    </div>
                </div>

                <div class="pt-6">
                    <button type="submit" class="w-full py-4 bg-emerald-600 hover:bg-emerald-700 active:bg-emerald-800 text-white rounded-xl font-bold tracking-wide transition shadow-lg shadow-emerald-600/30 flex justify-center items-center gap-2">
                        <span class="material-symbols-rounded text-[20px]">credit_card</span>
                        Pay €@Model.Price.ToString("0.00")
                    </button>
                    <p class="text-center text-xs text-slate-400 mt-4">This will change the Ticket State to 'Issued' in DB.</p>
                </div>
            </form>
        </div>
    </div>
</div>
