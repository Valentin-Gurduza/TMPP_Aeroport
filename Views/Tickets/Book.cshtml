@model IEnumerable<TMPP_Aeroport.Models.Flight>

@{
    ViewData["Title"] = "Book Flights";
}

<div class="max-w-6xl mx-auto space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold text-gray-800 dark:text-white/90">Find a Flight</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Select your destination and book your seats now.</p>
        </div>
    </div>

    <!-- Filters (Mock UI) -->
    <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-gray-900 shadow-sm flex flex-wrap gap-4">
        <div class="flex-1 min-w-[200px]">
            <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300">From</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">flight_takeoff</span>
                <input type="text" value="SAMS Hub" readonly class="w-full rounded-lg border border-gray-200 bg-gray-50 py-3 pl-12 pr-4 text-gray-600 outline-none dark:border-gray-800 dark:bg-gray-800 dark:text-gray-400" />
            </div>
        </div>
        <div class="flex-1 min-w-[200px]">
            <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300">To</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">flight_land</span>
                <select class="w-full rounded-lg border border-gray-300 bg-transparent py-3 pl-12 pr-4 text-gray-800 outline-none transition focus:border-blue-500 active:border-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90">
                    <option value="">Any Destination</option>
                    @foreach(var dest in Model.Select(m => m.Destination).Distinct())
                    {
                        <option value="@dest">@dest</option>
                    }
                </select>
            </div>
        </div>
        <div class="flex items-end">
            <button class="flex items-center gap-2 rounded-lg bg-blue-600 px-6 py-3 font-medium text-white hover:bg-blue-700 transition w-full sm:w-auto">
                <span class="material-symbols-outlined text-[20px]">search</span>
                Search
            </button>
        </div>
    </div>

    <!-- Flight List -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        @foreach (var flight in Model)
        {
            <!-- dynamic calculation just for display -->
            decimal basePrice = flight.Aircraft?.Type == "Wide-body" ? 250m : 120m;
            
            <div class="group rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900 overflow-hidden transition-all hover:shadow-lg hover:border-blue-200 dark:hover:border-blue-900 flex flex-col h-full">
                <!-- Flight Header -->
                <div class="p-5 border-b border-gray-100 dark:border-gray-800 flex justify-between items-center bg-gray-50/50 dark:bg-gray-800/20">
                    <div class="flex items-center gap-3">
                        <div class="h-10 w-10 rounded-xl bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400 flex items-center justify-center">
                            <span class="material-symbols-outlined">airlines</span>
                        </div>
                        <div>
                            <h4 class="font-bold text-gray-800 dark:text-white/90">@flight.FlightNumber</h4>
                            <p class="text-xs text-gray-500 dark:text-gray-400">@flight.Aircraft?.Airline</p>
                        </div>
                    </div>
                    <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400 border border-emerald-100 dark:border-emerald-800">
                        Scheduled
                    </span>
                </div>
                
                <!-- Flight Body -->
                <div class="p-6 flex-1 flex flex-col">
                    <div class="flex justify-between items-center mb-6 relative">
                        <div class="absolute left-0 right-0 top-1/2 -translate-y-1/2 border-t-2 border-dashed border-gray-200 dark:border-gray-700 -z-10"></div>
                        
                        <div class="bg-white dark:bg-gray-900 pr-2">
                            <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Departure</p>
                            <h3 class="text-2xl font-bold text-gray-800 dark:text-white/90 leading-none">@flight.DepartureTime.ToString("HH:mm")</h3>
                            <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-1">@flight.Origin</p>
                        </div>
                        
                        <div class="bg-white dark:bg-gray-900 flex items-center justify-center px-2">
                            <span class="material-symbols-outlined text-blue-500 transform rotate-90 text-[20px]">flight</span>
                        </div>
                        
                        <div class="bg-white dark:bg-gray-900 pl-2 text-right">
                            <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Arrival</p>
                            <h3 class="text-2xl font-bold text-gray-800 dark:text-white/90 leading-none">@(flight.ArrivalTime?.ToString("HH:mm") ?? "--:--")</h3>
                            <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-1">@flight.Destination</p>
                        </div>
                    </div>
                    
                    <div class="mt-auto pt-4 flex items-center justify-between">
                        <div>
                            <p class="text-xs text-gray-500 dark:text-gray-400 mb-0.5">Starting from</p>
                            <p class="text-xl font-bold text-gray-800 dark:text-white/90">€@basePrice</p>
                        </div>
                        <a href="/Tickets/Buy/@flight.Id" class="inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-700 transition">
                            Book Seats
                            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                        </a>
                    </div>
                </div>
            </div>
        }

        @if(!Model.Any())
        {
            <div class="col-span-full py-12 text-center bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800">
                <span class="material-symbols-outlined text-gray-300 text-6xl mb-4">flight_off</span>
                <h3 class="text-lg font-medium text-gray-700 dark:text-gray-300">No scheduled flights found</h3>
                <p class="text-gray-500 dark:text-gray-400">Please check back later.</p>
            </div>
        }
    </div>
</div>
