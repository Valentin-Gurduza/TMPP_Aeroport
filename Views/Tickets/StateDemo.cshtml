@{
    ViewData["Title"] = "Ticket Machine (State)";
}

<div class="mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-100 text-blue-800 text-xs font-bold mb-4 border border-blue-200">
        <span class="material-symbols-outlined text-[14px]">point_of_sale</span>
        AUTOMATED VENDING
    </div>
    <h1 class="text-3xl font-bold text-slate-800">Ticket Vending Machine</h1>
    <p class="text-slate-500 mt-1">State Pattern — Machine alters behavior when its internal state changes.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
    <section class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="bg-slate-50 px-6 py-4 border-b border-slate-200 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-blue-600">touch_app</span>
                <h3 class="font-bold text-slate-800 tracking-wide">MACHINE CONTROLS</h3>
            </div>
            <span class="px-3 py-1 text-[10px] font-bold font-mono bg-blue-100 rounded-full border border-blue-200 text-blue-800 tracking-wider">
                STATE: @ViewBag.CurrentState
            </span>
        </div>
        
        <div class="p-6">
            <form action="/Tickets/StateDemo" method="get" class="grid grid-cols-2 gap-4">
                <div class="col-span-2 p-5 bg-slate-900 rounded-xl border border-slate-800 mb-2 shadow-inner relative overflow-hidden">
                    <div class="absolute -right-4 -bottom-4 opacity-10">
                        <span class="material-symbols-outlined text-[80px] text-white">receipt</span>
                    </div>
                    <div class="relative z-10 flex justify-between items-end">
                        <div>
                            <div class="text-slate-400 text-[10px] font-bold uppercase tracking-widest mb-1">TICKET PRICE: $50</div>
                            <div class="text-4xl font-mono font-bold text-emerald-400 drop-shadow-[0_0_8px_rgba(52,211,153,0.3)]">
                                BALANCE: $@ViewBag.Balance
                            </div>
                        </div>
                    </div>
                </div>

                <button type="submit" name="actionType" value="Insert" class="py-4 bg-emerald-50 text-emerald-700 border border-emerald-200 rounded-xl flex flex-col items-center hover:bg-emerald-100 transition active:scale-95 shadow-sm">
                    <span class="material-symbols-outlined mb-2 text-2xl">payments</span>
                    <span class="text-xs font-bold uppercase tracking-wider">INSERT $10</span>
                    <input type="hidden" name="amount" value="10" disabled="@(Context.Request.Query["actionType"] != "Insert")" id="amt10" />
                </button>
                <script>
                    document.querySelectorAll('button[name="actionType"][value="Insert"]').forEach(btn => {
                        btn.onclick = () => document.getElementById('amt10').disabled = false;
                    });
                </script>

                <button type="submit" name="actionType" value="Request" class="py-4 bg-amber-50 text-amber-700 border border-amber-200 rounded-xl flex flex-col items-center hover:bg-amber-100 transition active:scale-95 shadow-sm">
                    <span class="material-symbols-outlined mb-2 text-2xl">receipt_long</span>
                    <span class="text-xs font-bold uppercase tracking-wider">REQUEST TICKET</span>
                </button>

                <button type="submit" name="actionType" value="Dispense" class="col-span-2 py-4 bg-blue-600 text-white border border-blue-700 rounded-xl flex flex-col items-center hover:bg-blue-700 transition active:scale-[0.98] shadow-md shadow-blue-600/20 mt-2">
                    <span class="material-symbols-outlined mb-1 text-2xl">print</span>
                    <span class="text-sm font-bold uppercase tracking-wider">DISPENSE TICKET</span>
                </button>
            </form>

            <form action="/Tickets/StateDemo" method="get" class="mt-6 border-t border-slate-100 pt-4 text-center">
                <button type="submit" name="actionType" value="ResetLogs" class="text-[10px] font-bold text-slate-400 hover:text-slate-600 uppercase tracking-widest transition-colors inline-flex items-center gap-1">
                    <span class="material-symbols-outlined text-[14px]">delete</span>
                    CLEAR MACHINE LOGS
                </button>
            </form>
        </div>
    </section>

    <section class="bg-slate-900 border border-slate-800 rounded-2xl shadow-lg flex flex-col min-h-[400px] overflow-hidden">
        <div class="bg-slate-950 px-6 py-4 border-b border-white/10 flex justify-between items-center">
            <h3 class="text-xs font-bold text-blue-400 uppercase tracking-widest">MACHINE AUDIT LOG</h3>
            <span class="material-symbols-outlined text-sm text-blue-400">terminal</span>
        </div>
        <div class="p-6 flex-1 font-mono text-sm space-y-3 overflow-y-auto max-h-[400px] flex flex-col-reverse">
            @if (ViewBag.Logs != null && ViewBag.Logs.Count > 0)
            {
                var logs = (List<string>)ViewBag.Logs;
                for (int i = logs.Count - 1; i >= 0; i--)
                {
                    <div class="text-slate-300 border-b border-white/5 pb-2 flex gap-3">
                        <span class="text-blue-500">></span>
                        <span>@logs[i]</span>
                    </div>
                }
            }
            else
            {
                <div class="text-slate-500 italic flex items-center justify-center h-full opacity-50">
                    Awaiting transactions...
                </div>
            }
        </div>
    </section>
</div>

<!-- Hidden Ticket Template for PDF Generation -->
<div id="ticket-template" style="display:none;">
    <div style="width: 600px; padding: 40px; background: white; color: black; font-family: 'Inter', sans-serif; border: 1px solid #e2e8f0; position: relative;">
        <div style="text-align: center; border-bottom: 2px solid #1e293b; padding-bottom: 20px; margin-bottom: 20px;">
            <h1 style="margin: 0; font-size: 28px; text-transform: uppercase; font-weight: 800; color: #1e293b;">TMPP Airlines</h1>
            <p style="margin: 5px 0 0 0; font-size: 14px; font-weight: 600; color: #64748b; letter-spacing: 2px;">BOARDING PASS / TICKET</p>
        </div>
        
        <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div>
                <p style="margin: 0; font-size: 10px; font-weight: 700; color: #94a3b8; letter-spacing: 1px;">PASSENGER NAME</p>
                <h2 style="margin: 0; font-size: 20px; font-weight: 700; color: #0f172a;">GUEST PASSENGER</h2>
            </div>
            <div style="text-align: right;">
                <p style="margin: 0; font-size: 10px; font-weight: 700; color: #94a3b8; letter-spacing: 1px;">DATE ISSUED</p>
                <h2 style="margin: 0; font-size: 16px; font-weight: 600; color: #0f172a;">@DateTime.Now.ToString("dd MMM yyyy HH:mm")</h2>
            </div>
        </div>

        <div style="display: flex; justify-content: space-between; margin-bottom: 30px; background: #f8fafc; padding: 20px; border-radius: 12px; border: 1px solid #e2e8f0;">
            <div>
                <p style="margin: 0; font-size: 10px; font-weight: 700; color: #94a3b8; letter-spacing: 1px;">FROM</p>
                <h2 style="margin: 0; font-size: 28px; font-weight: 800; color: #1d4ed8;">ANY</h2>
            </div>
            <div style="text-align: center; align-self: center;">
                <span style="font-size: 24px; color: #94a3b8;">✈️</span>
            </div>
            <div style="text-align: right;">
                <p style="margin: 0; font-size: 10px; font-weight: 700; color: #94a3b8; letter-spacing: 1px;">TO</p>
                <h2 style="margin: 0; font-size: 28px; font-weight: 800; color: #1d4ed8;">ANYWHERE</h2>
            </div>
        </div>

        <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div>
                <p style="margin: 0; font-size: 10px; font-weight: 700; color: #94a3b8; letter-spacing: 1px;">FLIGHT</p>
                <h3 style="margin: 0; font-size: 18px; font-weight: 700; color: #0f172a;">TMPP-001</h3>
            </div>
            <div>
                <p style="margin: 0; font-size: 10px; font-weight: 700; color: #94a3b8; letter-spacing: 1px;">GATE</p>
                <h3 style="margin: 0; font-size: 18px; font-weight: 700; color: #0f172a;">A12</h3>
            </div>
            <div>
                <p style="margin: 0; font-size: 10px; font-weight: 700; color: #94a3b8; letter-spacing: 1px;">SEAT</p>
                <h3 style="margin: 0; font-size: 18px; font-weight: 700; color: #0f172a;">14B</h3>
            </div>
            <div>
                <p style="margin: 0; font-size: 10px; font-weight: 700; color: #94a3b8; letter-spacing: 1px;">CLASS</p>
                <h3 style="margin: 0; font-size: 18px; font-weight: 700; color: #0f172a;">ECONOMY</h3>
            </div>
        </div>
        
        <div style="margin-top: 30px; text-align: center; border-top: 1px dashed #cbd5e1; padding-top: 20px;">
            <p style="margin: 0; font-size: 12px; font-family: monospace; color: #475569;">TICKET NO: @Guid.NewGuid().ToString().Substring(0, 13).ToUpper()</p>
            <p style="margin: 5px 0 0 0; font-size: 9px; color: #94a3b8;">Generated by TMPP Vending Machine (State Pattern)</p>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

@if (ViewBag.ShouldDownloadPDF == true)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const element = document.getElementById('ticket-template');
            element.style.display = 'block';

            const opt = {
                margin:       0.5,
                filename:     'TMPP_Ticket.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2 },
                jsPDF:        { unit: 'in', format: 'a5', orientation: 'landscape' }
            };

            html2pdf().set(opt).from(element).save().then(() => {
                element.style.display = 'none';
                
                const toast = document.createElement('div');
                toast.innerHTML = '<span class="material-symbols-outlined">check_circle</span> PDF Ticket Downloaded Successfully!';
                toast.style.cssText = 'position:fixed; bottom:20px; right:20px; background:#10b981; color:white; padding:15px 25px; border-radius:8px; font-family:"Inter",sans-serif; font-weight:600; font-size:14px; display:flex; gap:10px; align-items:center; box-shadow:0 10px 25px rgba(0,0,0,0.2); z-index:9999; animation: slideIn 0.3s ease-out;';
                document.body.appendChild(toast);
                
                setTimeout(() => {
                    toast.style.animation = 'slideOut 0.3s ease-in forwards';
                    setTimeout(() => toast.remove(), 300);
                }, 4000);
            });
        });
    </script>
    
    <style>
        @@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        @@keyframes slideOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
    </style>
}
