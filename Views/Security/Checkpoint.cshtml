@model dynamic
@{
    ViewData["Title"] = "Security Checkpoint";
    Layout = "~/Views/Shared/_LayoutCorporate.cshtml";
    
    var baggageLogs = ViewBag.BaggageLogs as List<string>;
    var isApproved = ViewBag.IsApproved as bool?;
}

<div class="max-w-4xl mx-auto space-y-6 animate-fade-in-up">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight flex items-center">
                <span class="material-symbols-outlined mr-3 text-4xl text-blue-600">policy</span>
                Security Checkpoint
            </h1>
            <p class="text-slate-500 mt-2 text-lg">Chain of Responsibility: Multi-stage Baggage Screening</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        <!-- Input Form -->
        <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden h-full">
            <div class="bg-slate-50 border-b border-slate-200 px-6 py-4">
                <h2 class="text-lg font-bold text-slate-800">Scan Baggage</h2>
            </div>
            
            <div class="p-6">
                <form action="/Security/Checkpoint" method="get" class="space-y-6">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Baggage Weight (kg)</label>
                        <input type="number" step="0.1" name="weight" value="20" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition outline-none font-medium text-slate-700" required />
                    </div>

                    <div class="space-y-3 pt-2">
                        <label class="flex items-center space-x-3 p-3 border border-slate-200 rounded-lg cursor-pointer hover:bg-slate-50 transition">
                            <input type="checkbox" name="hasSuspicious" value="true" class="w-5 h-5 text-blue-600 rounded border-slate-300 focus:ring-blue-500" />
                            <span class="text-sm font-bold text-slate-700">Contains Suspicious Items (Fails X-Ray)</span>
                        </label>

                        <label class="flex items-center space-x-3 p-3 border border-slate-200 rounded-lg cursor-pointer hover:bg-slate-50 transition">
                            <input type="checkbox" name="hasExplosive" value="true" class="w-5 h-5 text-blue-600 rounded border-slate-300 focus:ring-blue-500" />
                            <span class="text-sm font-bold text-slate-700">Contains Explosive Traces</span>
                        </label>
                    </div>

                    <button type="submit" class="w-full py-3 bg-slate-800 hover:bg-slate-900 text-white rounded-xl font-bold shadow-md transition flex items-center justify-center">
                        <span class="material-symbols-outlined mr-2">conveyor_belt</span>
                        Send Through Scanner
                    </button>
                </form>
            </div>
        </div>

        <!-- Screening Results -->
        <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden h-full flex flex-col">
            <div class="bg-slate-50 border-b border-slate-200 px-6 py-4 flex items-center justify-between">
                <h2 class="text-lg font-bold text-slate-800">Screening Process Logs</h2>
                @if (isApproved.HasValue)
                {
                    if (isApproved.Value)
                    {
                        <span class="bg-green-100 text-green-800 border border-green-200 px-3 py-1 rounded-full text-xs font-bold flex items-center">
                            <span class="material-symbols-outlined text-sm mr-1">check_circle</span> APPROVED
                        </span>
                    }
                    else
                    {
                        <span class="bg-red-100 text-red-800 border border-red-200 px-3 py-1 rounded-full text-xs font-bold flex items-center">
                            <span class="material-symbols-outlined text-sm mr-1">cancel</span> REJECTED
                        </span>
                    }
                }
            </div>
            
            <div class="p-6 bg-slate-900 flex-grow font-mono text-sm text-slate-300">
                @if (baggageLogs != null && baggageLogs.Any())
                {
                    <ul class="space-y-3">
                        @foreach (var log in baggageLogs)
                        {
                            <li class="flex items-start">
                                @if (log.Contains("FAILED") || log.Contains("REJECTED") || log.Contains("ALERT"))
                                {
                                    <span class="text-red-500 mr-2">✖</span>
                                    <span class="text-red-400 font-bold">@log</span>
                                }
                                else if (log.Contains("PASSED") || log.Contains("CLEAR"))
                                {
                                    <span class="text-green-500 mr-2">✔</span>
                                    <span class="text-green-400">@log</span>
                                }
                                else
                                {
                                    <span class="text-blue-500 mr-2">ℹ</span>
                                    <span>@log</span>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-slate-500 italic h-full flex items-center justify-center">
                        Waiting for baggage scan...
                    </div>
                }
            </div>
        </div>
    </div>
</div>
