@{
    ViewData["Title"] = "Security Checkpoint - Live Scanner";
    Layout = "~/Views/Shared/_LayoutCorporate.cshtml";
}

<style>
    .conveyor-item {
        transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        transform-origin: center;
        /* Ensure smooth width collapse */
        overflow: hidden;
        white-space: nowrap;
    }
    .conveyor-item.entering {
        transform: translateX(-30px) scale(0.9);
        opacity: 0;
    }
    .conveyor-item.moving {
        transform: translateX(0) scale(1);
        opacity: 1;
        width: 12rem; /* w-48 = 12rem */
        padding-left: 1rem;
        padding-right: 1rem;
        margin-right: 1.5rem; /* space-x-6 = 1.5rem margin */
    }
    .conveyor-item.cleared {
        transform: translateX(50px) scale(0.5);
        opacity: 0;
        width: 0 !important;
        margin-right: 0 !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        border-width: 0 !important;
    }
    .conveyor-item.ejected {
        transform: translateY(-50px) scale(0.5) rotate(15deg);
        opacity: 0;
        width: 0 !important;
        margin-right: 0 !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        border-width: 0 !important;
    }
</style>

<div class="max-w-7xl mx-auto space-y-6 animate-fade-in-up pt-4">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-800 dark:text-slate-200 tracking-tight flex items-center">
                <span class="material-symbols-rounded mr-3 text-4xl text-blue-600">policy</span>
                Security Checkpoint (Live Scanner)
            </h1>
        </div>
        <div>
            <button onclick="fetchPendingBaggages()" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 dark:text-slate-300 font-bold rounded-lg transition border border-slate-300">
                <span class="material-symbols-rounded align-middle mr-1 text-sm">refresh</span> Refresh Queue
            </button>
        </div>
    </div>

    <!-- Conveyor Belt Queue -->
    <div class="bg-white dark:bg-slate-900 dark:text-slate-200 border border-slate-200 rounded-2xl shadow-sm overflow-hidden mb-6 relative">
        <div class="bg-slate-50 dark:bg-slate-800 dark:text-slate-200 border-b border-slate-200 px-6 py-4 flex justify-between items-center">
            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">Live Security Conveyor</h2>
            <div class="flex space-x-4">
                <button onclick="toggleBelt()" id="btn-toggle-belt" class="flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-bold rounded-lg transition shadow-md">
                    <span class="material-symbols-rounded text-sm mr-2" id="icon-toggle-belt">play_arrow</span>
                    <span id="text-toggle-belt">Start Belt</span>
                </button>
            </div>
        </div>
        
        <!-- Animated Scanner Zones overlay -->
        <div class="absolute inset-0 top-[68px] pointer-events-none flex justify-center items-stretch z-10 opacity-20">
            <div class="w-1/4 border-r-4 border-blue-500 border-dashed relative">
                <div class="absolute bottom-2 right-2 text-blue-800 font-black text-2xl">WEIGHT</div>
            </div>
            <div class="w-1/4 border-r-4 border-purple-500 border-dashed relative">
                <div class="absolute bottom-2 right-2 text-purple-800 font-black text-2xl">X-RAY</div>
            </div>
            <div class="w-1/4 border-r-4 border-red-500 border-dashed relative">
                <div class="absolute bottom-2 right-2 text-red-800 font-black text-2xl">EXPLOSIVES</div>
            </div>
        </div>

        <div class="p-6 bg-slate-200 overflow-x-auto relative min-h-[200px]">
            <div id="conveyor-belt" class="flex min-w-max pb-4 relative z-20 items-center h-full">
                <!-- Items populated via JS -->
                <div class="text-slate-500 italic w-full text-center py-4" id="conveyor-empty">No pending baggage on the belt.</div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Manual Inspection Queue (Flagged) -->
        <div class="bg-white dark:bg-slate-900 dark:text-slate-200 border border-slate-200 rounded-2xl shadow-sm overflow-hidden h-[400px] flex flex-col">
            <div class="bg-red-50 border-b border-red-200 px-6 py-4 flex items-center justify-between">
                <h2 class="text-lg font-bold text-red-800 flex items-center">
                    <span class="material-symbols-rounded mr-2">warning</span> Requires Manual Inspection
                </h2>
                <span class="bg-red-200 text-red-800 text-xs font-bold px-2 py-1 rounded-full" id="flagged-count">0</span>
            </div>
            <div class="p-4 overflow-y-auto flex-1 space-y-3" id="flagged-queue">
                <div class="text-slate-500 italic text-center py-4" id="flagged-empty">No flagged baggage.</div>
            </div>
        </div>

        <!-- Scanner Live Logs -->
        <div class="bg-slate-900 border border-slate-800 rounded-2xl shadow-sm overflow-hidden h-[400px] flex flex-col">
            <div class="bg-slate-800 border-b border-slate-700 px-6 py-4">
                <h2 class="text-lg font-bold text-white flex items-center">
                    <span class="material-symbols-rounded mr-2">terminal</span> Scanner Logs
                </h2>
            </div>
            <div class="p-4 overflow-y-auto flex-1 font-mono text-sm text-slate-300" id="scanner-logs">
                <div class="text-slate-600 italic text-center py-4" id="logs-empty">System ready. Waiting for scan...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/security-scanner.js" asp-append-version="true"></script>
}
