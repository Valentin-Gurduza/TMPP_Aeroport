@page
@model RegisterModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "_LayoutLogin";
}

<div class="flex min-h-screen bg-slate-50">
    <!-- Left branding panel -->
    <div class="hidden lg:flex lg:w-1/2 bg-blue-600 flex-col justify-between p-12">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-white text-3xl">flight_takeoff</span>
            <span class="text-white font-bold text-xl tracking-tight">SAMS Enterprise</span>
        </div>
        <div>
            <h2 class="text-white text-4xl font-bold leading-tight mb-4">Join the Airport<br/>Management<br/>Platform</h2>
            <p class="text-blue-200 text-base leading-relaxed">Register to get access to flights, passenger management, ATC operations and ground staff tools based on your assigned role.</p>
        </div>
        <div class="space-y-3">
            <div class="flex items-center gap-3 bg-blue-500/30 rounded-lg px-4 py-2.5">
                <span class="material-symbols-outlined text-white text-base">admin_panel_settings</span>
                <span class="text-blue-100 text-sm"><strong class="text-white">Admin</strong> — Full system access</span>
            </div>
            <div class="flex items-center gap-3 bg-blue-500/30 rounded-lg px-4 py-2.5">
                <span class="material-symbols-outlined text-white text-base">settings_input_antenna</span>
                <span class="text-blue-100 text-sm"><strong class="text-white">ATC_Manager</strong> — Tower & flight control</span>
            </div>
            <div class="flex items-center gap-3 bg-blue-500/30 rounded-lg px-4 py-2.5">
                <span class="material-symbols-outlined text-white text-base">work</span>
                <span class="text-blue-100 text-sm"><strong class="text-white">Ground_Staff</strong> — Baggage & operations</span>
            </div>
            <div class="flex items-center gap-3 bg-blue-500/30 rounded-lg px-4 py-2.5">
                <span class="material-symbols-outlined text-white text-base">person</span>
                <span class="text-blue-100 text-sm"><strong class="text-white">Passenger</strong> — Tickets & check-in</span>
            </div>
        </div>
    </div>

    <!-- Right register panel -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-8">
        <div class="w-full max-w-sm">
            <!-- Mobile logo -->
            <div class="flex items-center gap-2 mb-8 lg:hidden">
                <div class="w-9 h-9 bg-blue-600 rounded-lg flex items-center justify-center">
                    <span class="material-symbols-outlined text-white text-lg">flight_takeoff</span>
                </div>
                <span class="font-bold text-slate-900">SAMS Enterprise</span>
            </div>

            <h1 class="text-2xl font-bold text-slate-900 mb-1">Create Account</h1>
            <p class="text-slate-500 text-sm mb-8">Fill in your details to register in the system</p>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">First Name</label>
                        <input name="FirstName" type="text"
                               class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 bg-white text-slate-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                               placeholder="Ion" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Last Name</label>
                        <input name="LastName" type="text"
                               class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 bg-white text-slate-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                               placeholder="Popescu" />
                    </div>
                </div>

                <div>
                    <label asp-for="Input.Email" class="block text-sm font-medium text-slate-700 mb-1.5">Email Address</label>
                    <input asp-for="Input.Email"
                           class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 bg-white text-slate-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                           autocomplete="username"
                           placeholder="ion.popescu@example.com" />
                    <span asp-validation-for="Input.Email" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Input.Password" class="block text-sm font-medium text-slate-700 mb-1.5">Password</label>
                    <input asp-for="Input.Password"
                           class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 bg-white text-slate-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                           autocomplete="new-password"
                           placeholder="Min. 8 chars, 1 uppercase, 1 digit" />
                    <span asp-validation-for="Input.Password" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-slate-700 mb-1.5">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword"
                           class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 bg-white text-slate-900 text-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                           autocomplete="new-password"
                           placeholder="Re-enter password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-500 mt-1 block"></span>
                </div>

                <button type="submit" id="registerSubmit"
                        class="w-full py-2.5 bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white text-sm font-semibold rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 shadow-sm">
                    Create Account
                </button>
            </form>

            <p class="text-center text-sm text-slate-500 mt-6">
                Already have an account?
                <a asp-page="./Login" class="text-blue-600 font-semibold hover:underline">Sign in</a>
            </p>
        </div>
    </div>
</div>
